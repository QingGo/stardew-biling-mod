          "DisplayName": "Jade Stone / Jade Stone",
          "Description": "Break apart to obtain jade. / Break apart to obtain jade."
        },
        "50": {
          "DisplayName": "Snowy Stone / Snowy Stone",
          "Description": "Break apart to obtain stone, ores, or geodes. / Break apart to obtain stone, ores, or geodes."
        },
        "Book_Marlon": {
          "DisplayName": "Mapping Cave Systems / 洞穴地图绘制法",
          "Description": "You get a 50% discount on Marlon's item retrieval service. / 马龙取回物品时费用给你打五折。"
        },
        "717": {
          "DisplayName": "Crab / 螃蟹",
          "Description": "A marine crustacean with two powerful pincers. / 长着两个强壮螯的海生甲壳纲生物。"
