    {
      "Action": "EditData",
      "Target": "Data/Weapons",
      "When": {
        "BilingualMode": "true"
      },
      "Fields": {
        "66": {
          "DisplayName": "Iridium Scythe / 铱镰刀",
          "Description": "Can be used to harvest any crops. It's also excellent at gathering hay. / 可以收割所有作物，收集干草效果极佳。"
        },
        "19": {
          "DisplayName": "Shadow Dagger / 暗影匕首",
          "Description": "When you hold the blade to your ear you can hear 1,000 souls shrieking. / 把刀放到耳旁，能听见千百条灵魂的哀嚎。"
        },
        "3": {
          "DisplayName": "Holy Blade / 圣剑",
          "Description": "It feels hopeful to wield. / 握在手里，充满正能量。"
        },
        "65": {
          "DisplayName": "Meowmere / 彩虹猫之刃",
          "Description": "An unusual weapon from a far away land... / 来自异界的罕见武器……"
        },
        "46": {
          "DisplayName": "Kudgel / 长柄锤",
          "Description": "A brute's companion. / 野蛮人的最佳伙伴。"
        },
        "31": {
          "DisplayName": "Femur / 股骨",
          "Description": "An old, heavy bone caked in centuries of grime. / 一根古老沉重的骨头，覆盖着数个世纪的尘垢。"
        },
        "33": {
          "DisplayName": "Master Slingshot / 高级弹弓",
          "Description": "Requires stones for ammo. / 需要石子当弹药。"
        },
        "7": {
          "DisplayName": "Templar's Blade / 圣堂之刃",
          "Description": "It once belonged to an honorable knight. / 曾属于一位高尚的圣殿骑士。"
        },
        "36": {
          "DisplayName": "Maru's Wrench / 玛鲁的扳手",
          "Description": "A big, metal wrench. It smells like Maru. / 巨大的金属扳手。闻起来很有玛鲁的味道。"
        },
        "59": {
          "DisplayName": "Dragontooth Shiv / 龙牙小刀",
          "Description": "The blade was forged from a magical tooth. / 这把刀是用一颗充满魔力的牙齿锻造而成的。"
        },
        "16": {
          "DisplayName": "Carving Knife / 刻刀",
          "Description": "A small, light blade. / 很轻的小刀。"
        },
        "28": {
          "DisplayName": "The Slammer / 巨锤",
          "Description": "An extremely heavy gavel that'll send foes flying. / 超级重的锤子，能够击飞敌人。"
        },
        "41": {
          "DisplayName": "Seb's Lost Mace / 塞巴斯蒂安的遗失之锤",
          "Description": "One of Sebastian's medieval replicas. / 塞巴斯蒂安的中世纪仿制品之一。"
        },
        "9": {
          "DisplayName": "Lava Katana / 熔岩武士刀",
          "Description": "A powerful blade forged in a pool of churning lava. / 用火山熔岩打造的强大刀刃。"
        },
        "29": {
          "DisplayName": "Galaxy Hammer / 银河之锤",
          "Description": "It's made from an ultra-light material you've never seen before. / 用一种你闻所未闻的超轻材料打造而成。"
        },
        "32": {
          "DisplayName": "Slingshot / 弹弓",
          "Description": "Requires stones for ammo. / 需要石子当弹药。"
        },
        "53": {
          "DisplayName": "Golden Scythe / 金色的镰刀",
          "Description": "It's more powerful than a normal scythe. / 它比传统的镰刀更强大。"
        },
        "23": {
          "DisplayName": "Galaxy Dagger / 银河匕首",
          "Description": "It's unlike anything you've seen. / 你闻所未闻。"
        },
        "58": {
          "DisplayName": "Dragontooth Club / 龙牙棒",
          "Description": "This club was crafted from a magical tooth. / 这根棍子是用一颗充满魔力的牙齿锻造而成的。"
        },
        "26": {
          "DisplayName": "Lead Rod / 铅棒",
          "Description": "It's incredibly heavy. / 异常的沉。"
        },
        "15": {
          "DisplayName": "Forest Sword / 森林剑",
          "Description": "Made powerful by forest magic. / 由森林魔法打造的强力之剑。"
        },
        "4": {
          "DisplayName": "Galaxy Sword / 银河剑",
          "Description": "It's unlike anything you've ever seen. / 谁与争锋。"
        },
        "52": {
          "DisplayName": "Tempered Broadsword / 淬火阔剑",
          "Description": "It looks like it could withstand anything. / 看上去能够抵挡任何东西。"
        },
        "27": {
          "DisplayName": "Wood Mallet / 木锤",
          "Description": "The solid head packs a punch. Relatively light for a club. / 坚固的头部威力强大。对于一把棍棒来说，重量有点轻。"
