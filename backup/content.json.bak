          "Description": "A wearable shirt. / 可以穿的上衣。"
        },
        "1232": {
          "DisplayName": "Trash Can Shirt / 垃圾桶 T 恤",
          "Description": "You're wearing a trash can. / 你穿着一个垃圾桶。"
        },
        "1284": {
          "DisplayName": "Globby Shirt / 杂乱 T 恤",
          "Description": "It's got an indistinguishable glob pattern. / 图案杂乱，难以辨认。"
        },
        "1157": {
          "DisplayName": "Fishing Vest / 钓鱼背心",
          "Description": "Lots of pockets to store your tackle. / 有很多口袋，可以装下你的渔具。"
        },
        "1155": {
          "DisplayName": "Bomber Jacket / 轰炸机夹克",
          "Description": "A thick, sturdy jacket worn by fighter pilots long ago. / 很久以前战斗机驾驶员穿的厚实耐用的夹克衫。"
        },
        "1123": {
          "DisplayName": "Shirt And Tie / 领带衬衫",
          "Description": "A white dress shirt and a tie. / 有领带的白衬衫。"
        },
        "1293": {
          "DisplayName": "Banana Shirt / 香蕉 T 恤",
          "Description": "Consider this shirt, if you happen to love bananas. / 如果你喜欢香蕉，可以试试这件 T 恤。"
        },
        "1140": {
          "DisplayName": "Button Down Shirt / 纽扣衬衫",
          "Description": "A simple, clean shirt. / 简单的纯色衬衫。"
        },
        "1198": {
          "DisplayName": "Vintage Polo / 老式 Polo 衫",
          "Description": "It's faded from age and smells like old closet. / 由于年代久远已经褪色，散发着旧衣柜的味道。"
        },
        "1045": {
          "DisplayName": "Shirt / 上衣",
          "Description": "A wearable shirt. / 可以穿的上衣。"
        },
        "1210": {
          "DisplayName": "Heart Shirt / 爱心 T 恤",
          "Description": "Wear your heart on your sleeves with this extra soft garment. / 把你的爱心穿在这超软的衣袖上。"
        },
        "1195": {
          "DisplayName": "Bandana Shirt / 丝巾上衣",
          "Description": "A shirt with a bandana that keeps your neck very clean. / 这件上衣围有丝巾，可以让你的脖子保持洁净。"
        },
        "1277": {
          "DisplayName": "Silky Shirt / 丝绸上衣",
          "Description": "It's made from a smooth silky substance. / 面料是光滑的丝绸物质。"
        },
        "1236": {
          "DisplayName": "Sauce-Stained Shirt / 酱汁 T 恤",
          "Description": "It's already covered in spaghetti sauce so you don't have to feel guilty about it! / 上面的意面酱汁是本来就有的，所以你不用感到内疚！"
        },
        "1008": {
          "DisplayName": "\"Good Grief\" Shirt / “Good Grief”衫",
          "Description": "A good ol' shirt... / 过去的好 T 恤衫……"
        },
        "1124": {
          "DisplayName": "Shirt / 上衣",
          "Description": "A wearable shirt. / 可以穿的上衣。"
        },
        "1200": {
          "DisplayName": "Star Shirt / 星星 T 恤",
          "Description": "The star is supposed to glow in the dark, but it doesn't. / 这颗星星本应该在黑暗中闪闪发光，然而并没有。"
        }
      }
    },
    {
      "Action": "EditData",
      "Target": "Data/Pants",
      "When": {
        "BilingualMode": "true"
