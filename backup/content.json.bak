      "Entries": {
        "HarveysMallet_Description": "It brings back memories of Harvey's clinic. / 让人想起哈维的诊所。",
        "ObsidianEdge_Description": "It's incredibly sharp. / 这东西锋利无比。",
        "OssifiedBlade_Description": "A large, sharp blade formed from bone. / 由骨头形成的巨大而锋利的剑刃。",
        "CarvingKnife_Description": "A small, light blade. / 很轻的小刀。",
        "TemplarsBlade_Name": "Templar's Blade / 圣堂之刃",
        "PiratesSword_Name": "Pirate's Sword / 海盗剑",
        "WoodenBlade_Name": "Wooden Blade / 木剑",
        "HolyBlade_Description": "It feels hopeful to wield. / 握在手里，充满正能量。",
        "CrystalDagger_Name": "Crystal Dagger / 水晶匕首",
        "Slingshot_Name": "Slingshot / 弹弓",
        "GalaxyDagger_Description": "It's unlike anything you've seen. / 你闻所未闻。",
        "ForestSword_Name": "Forest Sword / 森林剑",
        "InfinityDagger_Description": "The true form of the Galaxy Dagger. / 银河匕首的真实形态。",
        "DwarfSword_Description": "It's ancient, but the blade never dulls. / 很古老，但剑锋未曾变钝。",
        "MarusWrench_Name": "Maru's Wrench / 玛鲁的扳手",
        "GalaxySlingshot_Name": "Galaxy Slingshot / 银河弹弓",
        "DwarfDagger_Name": "Dwarf Dagger / 矮人匕首",
        "LavaKatana_Description": "A powerful blade forged in a pool of churning lava. / 用火山熔岩打造的强大刀刃。",
        "Scythe_Name": "Scythe / 镰刀",
        "TheSlammer_Name": "The Slammer / 巨锤",
        "ElliottsPencil_Description": "Elliott used this to write his book. It's sharp! / 艾利欧特用它来写书。非常尖锐！",
        "DragontoothShiv_Name": "Dragontooth Shiv / 龙牙小刀",
        "ElfBlade_Name": "Elf Blade / 精灵之刃",
        "SilverSaber_Description": "Plated with silver to deter rust. / 镀银以防锈。",
        "AbbysPlanchette_Name": "Abby's Planchette / 阿比盖尔的占卜写板",
        "DarkSword_Description": "It's glowing with vampire energy. / 散发着神秘的能量。",
        "LeahsWhittler_Description": "Leah's favorite tool for shaping driftwood. / 莉亚用来削木的最爱工具。",
        "SamsOldGuitar_Name": "Sam's Old Guitar / 山姆的旧吉他",
        "TheSlammer_Description": "An extremely heavy gavel that'll send foes flying. / 超级重的锤子，能够击飞敌人。",
        "DarkSword_Name": "Dark Sword / 黑暗剑",
        "InfinityDagger_Name": "Infinity Dagger / 无限匕首",
        "MasterSlingshot_Description": "Requires stones for ammo. / 需要石子当弹药。",
        "DragontoothCutlass_Description": "The blade was forged from a magical tooth. / 这把刀是用一颗充满魔力的牙齿锻造而成的。",
        "PiratesSword_Description": "It looks like a pirate owned this once. / 看上去曾经是一位海盗的武器。",
