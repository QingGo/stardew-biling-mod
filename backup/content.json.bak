        "Hoe_Steel_Name": "Steel Hoe / 钢锄头",
        "Axe_Description": "Used to chop wood. / 用于砍柴。",
        "Lantern_Name": "Lantern / 灯笼",
        "TrashCan_Name": "Trash Can / 垃圾桶",
