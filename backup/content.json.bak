        "TrashCan_Steel_Name": "Steel Trash Can / 钢垃圾桶",
        "FishingRod_Iridium_Name": "Iridium Rod / 铱金鱼竿",
        "Pan_Gold_Name": "Gold Pan / 金淘盘",
