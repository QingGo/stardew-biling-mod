        "SolarEssence_Name": "Solar Essence / 太阳精华",
        "Book_Crabbing_Name": "The Art O' Crabbing / 捕蟹秘籍",
        "TripleShotEspresso_Name": "Triple Shot Espresso / 三倍浓缩咖啡",
        "DriedFruit_CollectionsTabName": "Dried Fruit / 果干",
        "SkillBook4_Name": "Combat Quarterly / 战斗季刊",
        "DinosaurEgg_Name": "Dinosaur Egg / 恐龙蛋",
        "DuckEgg_Name": "Duck Egg / 鸭蛋",
        "TeaLeaves_Name": "Tea Leaves / 茶叶",
        "Weeds_FiberOrMixedSeeds_Name": "Weeds / 杂草",
        "Hedge_Name": "Hedge / 树篱",
        "WoodFloor_Name": "Wood Floor / 木地板",
        "CarrotSeeds_Name": "Carrot Seeds / 胡萝卜种子",
        "Hay_Description": "Dried grass used as animal food. / 晾干的草料，可以用来喂动物。",
        "Sap_Description": "A fluid obtained from trees. / 树里取出来的液体。",
        "PiratesLocket_Name": "Pirate's Locket / 海盗项链",
        "Pufferfish_Name": "Pufferfish / 河豚",
        "AppleSapling_Description": "Takes 28 days to produce a mature Apple tree. Bears fruit in the fall. Only grows if the 8 surrounding \"tiles\" are empty. / 28 天成熟为成年苹果树。秋天结果。只有在附近 8 块“地块”都空置的情况下才会成长。",
        "LuckyRing_Description": "The lunar emblem is said to bring good luck to whoever wears it. / 象征月亮的标志，据说可以给佩戴它的人带来好运。",
        "PumpkinSeeds_Name": "Pumpkin Seeds / 南瓜种子",
        "Lumber_Name": "Lumber / 木材",
        "MsAngler_Name": "Ms. Angler / 雌鮟鱇鱼",
        "WoodPath_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "Hashbrowns_Name": "Hashbrowns / 薯饼",
        "RicePudding_Name": "Rice Pudding / 大米布丁",
        "GreenTea_Description": "A pleasant, energizing beverage made from lightly processed tea leaves. / 由轻加工的茶叶制成的令人愉快的提神饮料。",
        "JazzSeeds_Name": "Jazz Seeds / 蓝爵士种子",
        "RingofYoba_Description": "Occasionally shields the wearer from damage. / 偶尔为佩戴者抵挡伤害。",
        "Book_Mystery_Name": "Book of Mysteries / 谜之书",
        "Limestone_Name": "Limestone / 石灰石",
        "Parsnip_Name": "Parsnip / 防风草",
        "QualityBobber_Description": "Boosts the quality of fish that you catch. / 提高你钓到的鱼的品质。",
        "DwarvishTranslationGuide_Name": "Dwarvish Translation Guide / 矮人语教程",
        "Book_Marlon_Name": "Mapping Cave Systems / 洞穴地图绘制法",
        "Spinner_Description": "The shape makes it spin around in the water. Slightly increases the bite-rate when fishing. / 它的形状会使它在水中打转。稍稍提升钓鱼时的上钩率。",
        "Potato_Description": "A widely cultivated tuber. / 一种栽种范围很广的块茎植物。",
        "SeaJelly_Description": "A rare jelly found in the ocean. / 存在于海里的罕见凝胶。",
        "Opal_Name": "Opal / 猫眼石",
        "CombinedRing_Description": "... / ……",
        "SkeletalTail_Name": "Skeletal Tail / 尾部骨骼",
        "Book_Trash_Description": "You have a greater chance to find items in the trash. / 在垃圾桶里找到物品的几率更高。",
        "DeluxeRetainingSoil_Description": "This soil has a 100% chance of staying watered overnight. Mix into tilled soil. / 这种土壤能够隔夜依然百分百保持湿润。使用时加到犁过的土地中。",
        "VoidSalmon_Name": "Void Salmon / 虚空鲑鱼",
        "HorseFlute_Description": "Playing this flute will summon your horse. Only works outdoors. / 吹这支笛子可以召唤出你的马，只在户外有效。",
        "WarriorRing_Description": "Occasionally infuses the wearer with \"warrior energy\" after slaying a monster. / 在杀死怪物后，偶尔输送“战士能量”给佩戴者。",
        "Book_Trash_Name": "The Alleyway Buffet / 小巷自助餐",
        "DwarvishTranslationGuide_Description": "Teaches you dwarvish. / 教你矮人语。",
        "Stardrop_Name": "Stardrop / 星之果实",
        "CarrotSeeds_Description": "Plant in the spring. Takes 3 days to grow. / 春天播种，3 天长成。",
        "StoneBase_Name": "Stone Base / 石基",
        "CompleteBreakfast_Description": "You'll feel ready to take on the world! / 你会准备好征服世界的！",
        "Corn_Name": "Corn / 玉米",
        "IceCrystal_Description": "Might contain refined quartz. / Might contain fibers or mixed seeds.",
        "DuckFeather_Name": "Duck Feather / 鸭毛",
        "JojaCola_Name": "Joja Cola / Joja 可乐",
        "VoidEssence_Description": "It's quivering with dark energy. / 黑暗能量在其中涌动着。",
        "ShrimpCocktail_Name": "Shrimp Cocktail / 虾鸡尾酒",
        "CinderShardStone_Description": "Break apart to obtain cinder shards. / Break apart to obtain cinder shards.",
        "MinersTreat_Name": "Miner's Treat / 矿工特供",
        "Milk_Description": "A jug of cow's milk. / 一壶牛奶。",
        "Topaz_Description": "Fairly common but still prized for its beauty. / 很常见，但是因为漂亮还是很有价值。",
        "PetLicense_Name": "Pet License / 宠物饲养证",
        "BlueSlimeEgg_Name": "Blue Slime Egg / 蓝色史莱姆蛋",
        "VegetableMedley_Name": "Vegetable Medley / 蔬菜杂烩",
        "Book_Artifact_Name": "Treasure Appraisal Guide / 古代珍宝鉴定指南",
        "GeodeStone_Description": "Break apart to obtain geodes. / Break apart to obtain geodes.",
        "RefinedQuartz_Name": "Refined Quartz / 精炼石英",
        "Cookie_Description": "Very chewy. / 非常难嚼。",
        "HorseFlute_Name": "Horse Flute / 马笛",
        "TomKhaSoup_Name": "Tom Kha Soup / 椰汁汤",
        "ChewingStick_Description": "Ancient people chewed on these to keep their teeth clean. / 古代人通过嚼这些来保持口腔清洁。",
        "Alamite_Name": "Alamite / 透闪石",
        "Baryte_Name": "Baryte / 重晶石",
        "Hedge_Description": "A shaped bush that acts like a fence. / 造型灌木，可当作围栏使用。",
        "Angler_Description": "Uses a bioluminescent dangler to attract prey. / 它用发光的拟饵来吸引猎物。",
        "FairyStone_Name": "Fairy Stone / 精灵石",
        "DressedSpinner_Name": "Dressed Spinner / 精装旋式鱼饵",
        "PrehistoricHandaxe_Description": "One of the earliest tools employed by humans. This \"crude\" tool was created by striking one rock with another to form a sharp edge. / 人类最早的工具之一。用两块石头互相撞击以形成锋利的边缘，这种\"粗糙的\"工具就是这样造出来的。",
        "DeluxeBait_Name": "Deluxe Bait / 高级鱼饵",
        "ArtifactSpot_Name": "Artifact Spot / 远古斑点",
        "Stone_NodeStoneOnly_Description": "Break apart to obtain stone. / Break apart to obtain stone.",
        "AncientSeeds_Name": "Ancient Seeds / 上古种子",
        "ChallengeBait_Description": "A \"perfect\" catch yields triple the fish. However, each time a fish escapes the \"fishing bar\", the catch is reduced. / “完美”钓鱼时可获得三条鱼。鱼每逃离“钓鱼条”一次，产量就减少一条。",
        "SpiritTorch_Description": "It's unclear where the blue color comes from... / 不清楚这些蓝色的亮光是从哪来的……",
        "RadishSalad_Name": "Radish Salad / 萝卜沙拉",
        "OmniGeodeStone_Name": "Omni Geode Stone / Omni Geode Stone",
        "MagnifyingGlass": "Magnifying Glass / 放大镜",
        "DwarfScrollIV_Description": "A yellowed scroll of parchment filled with dwarven script. This one's tied with a golden chain. / 一个写满矮人语的黄色羊皮卷轴。这一个上面系着金色链子。",
        "OrangeSapling_Description": "Takes 28 days to produce a mature Orange tree. Bears fruit in the summer. Only grows if the 8 surrounding \"tiles\" are empty. / 28 天成熟为成年橙子树。夏天结果。只有在附近 8 块“地块”都空置的情况下才会成长。",
        "Herring_Name": "Herring / 鲱鱼",
        "Moss_Name": "Moss / 苔藓",
        "RedSnapper_Name": "Red Snapper / 红鲷鱼",
        "Orpiment_Name": "Orpiment / 雌黄",
        "SalmonDinner_Name": "Salmon Dinner / 鲑鱼晚餐",
        "Artichoke_Description": "The bud of a thistle plant. The spiny outer leaves conceal a fleshy, filling interior. / 一种蓟科植物的芽。带有尖刺的外围叶子下，隐藏着一颗多肉而结实的内芯。",
        "MagicBait_Description": "Allows you to catch fish from any season, time, or weather, from whichever type of water you cast into. / 能让你在所有类型的水中钓出所有季节、时间、天气的鱼。",
        "UnmilledRice_Description": "Rice in its rawest form. Run this through a mill to increase the value. / 大米以未加工的形式。通过磨机运行以增加价值。",
        "Book_Void_Description": "Monsters have a small chance to drop double loot. / 怪物有小概率掉落双倍战利品。",
        "Jamborite_Description": "The crystals are so tightly packed it almost looks fuzzy. / 这些晶石是如此紧密地排列在一起，以至于它们看起来都有些模糊了。",
        "Anchor_Name": "Anchor / 锚",
        "GlowstoneRing_Name": "Glowstone Ring / 辉石戒指",
        "PineappleSeeds_Description": "Plant these in warm weather. Takes 14 days to mature, and keeps producing fruit after that. / 在温暖的天气里种下去。14 天成熟，之后会持续生产果实。",
        "PrehistoricSkull_Description": "This is definitely a mammalian skull. / 这绝对是一个哺乳类动物的头盖骨。",
        "VoidSalmon_Description": "A salmon, twisted by void energy. The fresh meat is jet black, but rapidly turns pink when exposed to air. / 一条鲑鱼，被虚空力量所扭曲。新鲜的肉是墨黑色的，但当暴露于空气中时很快变成粉红色的了。",
        "Hops_Name": "Hops / 啤酒花",
        "Coal_Name": "Coal / 煤炭",
        "GourmetTomatoSalt_Name": "Gourmet Tomato Salt / 美食家番茄盐",
        "StardewValleyRose_Name": "Stardew Valley Rose / 星露谷玫瑰",
        "Hay_Name": "Hay / 干草",
        "GoldenMask_Name": "Golden Mask / 黄金面具",
        "RadioactiveBar_Description": "Known by the Zuzu City Safety Commission to cause irreversible bodily harm. / 祖祖城安委会已知它会对人体造成不可逆的伤害。",
        "Lionfish_Name": "Lionfish / 狮子鱼",
        "DrumBlock_Description": "Plays a drum sound when you walk past. / 走上去的时候会发出鼓声。",
        "IronFence_Description": "Lasts longer than a stone fence. / 比石围栏更耐用。",
        "HardwoodFence_Description": "The most durable type of fence. / 一种最耐用的围栏。",
        "Sardine_Name": "Sardine / 沙丁鱼",
        "StrangeBun_Name": "Strange Bun / 奇怪的小面包",
        "PineTar_Description": "A pungent substance derived from pine sap. / 从松树树液中提取的刺鼻的物质。",
        "WildBait_Description": "A unique recipe from Linus that gives you a chance to catch two fish at once. / 用莱纳斯的独特配方制作，有机会一次钓到两条鱼。",
        "Magnet_Description": "Increases the chance of finding treasures when fishing. However, fish aren't crazy about the taste. / 增加钓鱼时发现宝藏的概率。但是，鱼儿可不喜欢它的味道。",
        "Truffle_Name": "Truffle / 松露",
        "FriedMushroom_Description": "Earthy and aromatic. / 原生态的香味。",
        "Octopus_Description": "A mysterious and intelligent creature. / 一种神秘聪明的生物。",
        "Nekoite_Description": "The delicate shards form a tiny pink meadow. / 这些精致的碎片能够拼成一片小小的粉色牧场。",
        "ArtichokeDip_Name": "Artichoke Dip / 水煮洋蓟",
        "WinterRoot_Description": "A starchy tuber. / 一种淀粉块茎植物。",
        "ParsnipSoup_Description": "It's fresh and hearty. / 鲜美又贴心。",
        "Ruby_Description": "A precious stone that is sought after for its rich color and beautiful luster. / 一种因其浓艳的颜色和美丽的光泽受人追捧的珍贵宝石。",
        "ArcticShard_Description": "This shard glows with an otherworldly blue light. / 这块碎片散发出超脱尘世的蓝色光芒。",
        "SnakeSkull_Description": "A preserved skull that once belonged to a snake. / 一个保存完好的蛇头骨。",
        "Melon_Description": "A cool, sweet summer treat. / 凉爽香甜的夏日食品。",
        "Esperite_Description": "The crystals glow bright green when stimulated. / 受到激发后，这种晶石会发出明亮的绿色荧光。",
        "PoppyseedMuffin_Name": "Poppyseed Muffin / 虞美人籽松糕",
        "DriedStarfish_Description": "A starfish from the primordial ocean. It's an unusually pristine specimen! / 原始海洋里的海星。这是个非常纯净的标本！",
        "RedSlimeEgg_Description": "Can be hatched in a slime incubator. / 可以在史莱姆孵化器中孵化。",
        "DarkTalisman": "Dark Talisman / 黑暗护身符",
        "TaroRoot_Name": "Taro Root / 芋头",
        "GourmetTomatoSalt_Description": "A rare, delicious and savory salt. / 一种稀有、美味、可口的盐。",
        "Salmon_Name": "Salmon / 鲑鱼",
        "Chub_Name": "Chub / 鲢鱼",
        "LargeBrownEgg_Description": "It's an uncommonly large brown egg! / 这是个非常大的棕色鸡蛋！",
        "PumpkinSoup_Description": "A seasonal favorite. / 秋之最爱。",
        "DriedMushrooms_CollectionsTabName": "Dried Mushrooms / 蘑菇干货",
        "Catfish_Description": "An uncommon fish found in streams. / 一种能在小溪里找到的罕见鱼类。",
        "IronFence_Name": "Iron Fence / 铁围栏",
        "RefinedQuartz_Description": "A more pure form of quartz. / 一种纯度更高的石英。",
        "SpeedGro_Description": "Stimulates leaf production. Guaranteed to increase growth rate by at least 10%. Mix into tilled soil. / 促进叶子生长。保证能让植物的生长速度加快 10%。使用时加到犁过的土地中。",
        "Glacierfish_Description": "Builds a nest on the underside of glaciers. / 会在冰川的底部搭巢。",
        "Strawberry_Description": "A sweet, juicy favorite with an appealing red color. / 香甜多汁的红色浆果。",
        "PressureNozzle_Description": "Place on a sprinkler to increase its watering range. / 安装在洒水器上，增加灌溉范围。",
        "QiGem_Name": "Qi Gem / 齐钻",
        "Blueberry_Description": "A popular berry reported to have many health benefits. The blue skin has the highest nutrient concentration. / 一种据说拥有多种益处的浆果。蓝莓拥有最高浓度的营养。 ",
        "Sandstone_Name": "Sandstone / 沙岩",
        "SummerSquash_Description": "A curved yellow squash that is harvested while immature, and still tender. / 未成熟时收获的金皮西葫芦嫩瓜。",
        "DriedFruit_Description": "Chewy pieces of dried {0}. / 用{0}制成的果干，有嚼劲。",
        "TreeFertilizer_Description": "Sprinkle on a wild tree to ensure rapid growth, even in winter. Doesn't work on fruit trees. / 洒在野树上，使其快速生长，冬天也一样。在果树上不起作用。",
        "TripleShotEspresso_Description": "It's more potent than regular coffee! / 它比普通咖啡更有效！",
        "DwarfGadget_Name": "Dwarf Gadget / 矮人小工具",
        "Apple_Name": "Apple / 苹果",
        "RhubarbSeeds_Description": "Plant these in the spring. Takes 13 days to mature. / 春天播种。13 天成熟。",
        "GrassBook_Name": "Ol' Slitherlegs / 草中窜",
        "StarfruitSeeds_Name": "Starfruit Seeds / 杨桃种子",
        "Geode_Name": "Geode / 晶球",
        "WoodFence_Description": "Keeps grass and animals contained! / 让小草以及动物呆在里面！",
        "TroutSoup_Description": "Pretty salty. / 很咸。",
        "IridiumOre_Name": "Iridium Ore / 铱矿石",
        "Sashimi_Description": "Raw fish sliced into thin pieces. / 切成薄片的生鱼。",
        "WeatheredFloor_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "ChippedAmphora_Name": "Chipped Amphora / 有缺口的土罐",
        "Book_PriceCatalogue_Name": "Price Catalogue / 价格目录",
        "GoldenPumpkin_Name": "Golden Pumpkin / 黄金南瓜",
        "RainbowShell_Description": "It's a very beautiful shell. / 它是个非常美丽的贝壳。",
        "HaleysLostBracelet_Description": "A family heirloom. / A family heirloom.",
        "RustySpoon_Name": "Rusty Spoon / 生锈的汤匙",
        "MysticStone_Description": "Break apart to obtain stone, ores, or geodes. / Break apart to obtain stone, ores, or geodes.",
        "LavaEel_Name": "Lava Eel / 岩浆鳗鱼",
        "ClayStone_Description": "Break apart to obtain clay. / Break apart to obtain clay.",
        "CrispyBass_Name": "Crispy Bass / 香酥鲈鱼",
        "GoatMilk_Name": "Goat Milk / 羊奶",
        "OstrichEgg_Description": "It may be the world's largest egg. / 这可能是世界上最大的鸟蛋了。",
        "VoidGhostPendant_Description": "It's symbolic to the shadow people. As a gift, it signifies the desire to move in together as friends. / 它对影子人有重要象征意义。拿它送礼，就代表想要交朋友并住在一起。",
        "LavaEel_Description": "It can somehow survive in pools of red-hot lava. / 它可以在炽热的岩浆中生存。",
        "CherrySapling_Description": "Takes 28 days to produce a mature Cherry tree. Bears fruit in the spring. Only grows if the 8 surrounding \"tiles\" are empty. / 28 天成熟为成年樱桃树。春天结果。只有在附近 8 块“地块”都空置的情况下才会成长。",
        "SonofCrimsonfish_Description": "He hatched in the warm summer water, and followed in the footsteps of his father. / 它在温暖的夏水中孵化而出，追随父亲的足迹。",
        "CraftingRecipe_WinterSeeds": "Wild Seeds (Wi) / 野生种子（冬季）",
        "FireQuartz_Name": "Fire Quartz / 火水晶",
        "Stardrop_Description": "A mysterious fruit that empowers those who eat it. The flavor is like a dream... a powerful personal experience, yet difficult to describe to others. / 一种神秘莫测的水果，给予食用者力量。它有梦幻般的味道……给人留下十分强烈的回忆，然而只可意会不可言传。",
        "GlacierfishJr_Description": "The original Glacierfish had a son... / 冰川鱼有了子嗣……",
        "SnowYam_Description": "This little yam was hiding beneath the snow. / 这种小山药隐藏在雪地下。",
        "SupplyCrate_Description": "... / ……",
        "IronBar_Description": "A bar of pure iron. / 一条纯铁锭。",
        "Emerald_Name": "Emerald / 绿宝石",
        "RusticPlankFloor_Description": "Place on the ground to create paths or to decorate your floors. / 放在地上修建小路，也可以装饰地板。",
        "SpiceBerry_Description": "It fills the air with a pungent aroma. / 让空气中满满都是芬香的香味。",
        "Geode_Description": "A blacksmith can break this open for you. / 你可以找铁匠破开这块晶球。",
        "HardwoodFence_Name": "Hardwood Fence / 硬木围栏",
        "AncientDoll_Description": "An ancient doll covered in grime. This doll may have been used as a toy, a decoration, or a prop in some kind of ritual. / 一个满身污垢的古代玩偶。它可以用做玩具，也可以用做装饰，还可以用做某种仪式的道具。",
        "GravelPath_Name": "Gravel Path / 砾石小径",
        "TomatoSeeds_Description": "Plant these in the summer. Takes 11 days to mature, and continues to produce after first harvest. / 夏天播种。11 天成熟，收获之后还能继续结果。",
        "FriedCalamari_Description": "It's so chewy. / 它太有嚼劲了。",
        "SmallmouthBass_Name": "Smallmouth Bass / 小嘴鲈鱼",
        "GreenAlgae_Description": "It's really slimy. / 它黏黏的。",
        "Shrimp_Name": "Shrimp / 虾",
        "BakedFish_Description": "Baked fish on a bed of herbs. / 香草烤鱼。",
        "Crocus_Name": "Crocus / 番红花",
        "OilofGarlic_Name": "Oil of Garlic / 蒜油",
        "PurpleBook_Name": "Book Of Stars / 星之书",
        "Legend_Name": "Legend / 传说之鱼",
        "Chanterelle_Description": "A tasty mushroom with a fruity smell and slightly peppery flavor. / 一种美味的蘑菇，味道像水果，稍辣。",
        "Ginger_Name": "Ginger / 姜",
        "EarthCrystal_Description": "A resinous substance found near the surface. / 在地表附近发现的树脂状物质。",
        "Stone_NodeStoneOnly_Name": "Stone / 石头",
        "CalicoEggStone_Name": "Calico Egg Stone / 卡利科三花石头",
        "SkillBook3_Description": "Read this to gain some mining experience. / 阅读即可获得采矿经验。",
        "EnergyTonic_Name": "Energy Tonic / 能量滋补水",
        "RoastedHazelnuts_Name": "Roasted Hazelnuts / 烤榛子",
        "ParsnipSoup_Name": "Parsnip Soup / 防风草汤",
        "StarShards_Name": "Star Shards / 陶瓷碎片",
        "OmniGeodeStone_Description": "Break apart to obtain omni geodes. / Break apart to obtain omni geodes.",
        "DeluxeSpeedGro_Name": "Deluxe Speed-Gro / 高级生长激素",
        "Coffee_Description": "It smells delicious. This is sure to give you a boost. / 闻上去就很好喝。它肯定能让你充满活力。",
        "AncientDrum_Name": "Ancient Drum / 古代鼓",
        "ArtichokeDip_Description": "It's cool and refreshing. / 清凉而爽口。",
        "FossilizedRibs_Name": "Fossilized Ribs / 肋骨化石",
        "PrehistoricHandaxe_Name": "Prehistoric Handaxe / 史前手斧",
        "AncientSeeds_Description": "Could these still grow? / 还能长出来吗？",
        "FiddleheadRisotto_Name": "Fiddlehead Risotto / 意式蕨菜炖饭",
        "Powdermelon_Description": "Named for the powdery coating that forms on the surface, this melon is crisp and sweet, with a delicate flavor. / 因表面结一层白霜而得名，瓜肉鲜脆清甜。",
        "CalicoEggStone_Description": "Break apart to obtain Calico Eggs. / 砸开即可获得卡利科三花蛋。",
        "PrehistoricScapula_Description": "Commonly known as a \"shoulder blade\"... It's unclear what species it belonged to. / 一般都被说成是“肩部刀刃”……无法确定这是什么生物的骨头。",
        "ThunderEgg_Description": "According to legend, angry thunder spirits would throw these stones at one another. / 根据传说，愤怒的雷霆神灵会朝彼此扔这些石头。",
        "PineappleSeeds_Name": "Pineapple Seeds / 菠萝种子",
        "SweetGemBerry_Description": "It's by far the sweetest thing you've ever smelled. / 它远比你尝过的任何东西都甜。",
        "VoidEgg_Name": "Void Egg / 虚空蛋",
        "JadeRing_Description": "Increases critical strike power by 10%. / 增加 10% 的致命一击能量。",
        "Holly_Name": "Holly / 冬青树",
        "PrehistoricScapula_Name": "Prehistoric Scapula / 史前肩胛骨",
        "SummerSquash_Name": "Summer Squash / 金皮西葫芦",
        "RedCabbage_Name": "Red Cabbage / 红叶卷心菜",
        "SuperCucumber_Name": "Super Cucumber / 大海参",
        "PrismaticShard_Description": "A very rare and powerful substance with unknown origins. / 一种来源未知的超稀有强力材料。",
        "MagnetRing_Description": "Increases your radius for collecting items. / 增加你收集物品的半径。",
        "Carp_Description": "A common pond fish. / 一种常见的池鱼。",
        "AgedRoe_Flavored_Name": "Aged {0} Roe / 腌制的{0}鱼籽",
        "Oyster_Description": "Constantly filters water to find food. In the process, it removes dangerous toxins from the environment. / 以滤水的方式觅食。在这个过程中，会清除环境中的有毒有害物质。",
        "Shad_Name": "Shad / 西鲱",
        "BrickFloor_Description": "Place on the ground to create paths or to decorate your floors. / 放在地上修建小路，也可以装饰地板。",
        "Albacore_Name": "Albacore / 青花鱼",
        "FireworksRed_Description": "An old tradition for celebrations and festivities. Handle with care! / 一种庆祝节日和活动的传统习俗。小心燃放！",
        "CarpSurprise_Description": "It's bland and oily. / 它的味道很清淡但是很油。",
        "OmniGeode_Name": "Omni Geode / 万象晶球",
        "PineTar_Name": "Pine Tar / 松焦油",
        "RareSeed_Name": "Rare Seed / 稀有种子",
        "Jade_Description": "A pale green ornamental stone. / 一种淡绿色的装饰石。",
        "JadeStone_Name": "Jade Stone / Jade Stone",
        "Walleye_Name": "Walleye / 大眼鱼",
        "Sunflower_Name": "Sunflower / 向日葵",
        "ThornsRing_Name": "Thorns Ring / 荆棘戒指",
        "GoldBar_Name": "Gold Bar / 金锭",
        "LuckyLunch_Name": "Lucky Lunch / 幸运午餐",
        "Granite_Description": "A speckled Mineral that is commonly used in construction. / 有着斑点的矿石，经常用于建筑。",
        "MushroomTreeSeed_Description": "Place this on your farm to plant a mushroom tree. / 把它种在你的农场上，可以种出蘑菇树。",
        "ButterflyPowder_Name": "Butterfly Powder / 蝴蝶粉",
        "TropicalCurry_Name": "Tropical Curry / 热带咖喱",
        "GreenBean_Description": "A juicy little bean with a cool, crisp snap. / 爽脆口感的多汁小豆子。",
        "MutantCarp_Description": "The strange waters of the sewer turned this carp into a monstrosity. / 下水道中古怪的水让这条鲤鱼变得畸形了。",
        "Jelly_Flavored_(O)282_Name": "Cranberry Jelly / ",
        "Amethyst_Description": "A purple variant of quartz. / 一种紫色的水晶。",
        "Beer_Description": "Drink in moderation. / 请适度饮酒。",
        "TropicalCurry_Description": "An exotic, fragrant curry served in a pineapple bowl. / 盛在菠萝碗里的别具异国风味的咖喱。",
        "MushroomTreeSeed_Name": "Mushroom Tree Seed / 蘑菇树种子",
        "CraftingRecipe_IronBar": "Transmute (Fe) / 铁锭",
        "MovieTicket_Description": "Admits one to the movie theater. Giving this to a friend invites them to the movies with you. / 允许一个人进入电影院。送给朋友就可以邀请他们和你一起看电影。",
        "PalmFossil_Name": "Palm Fossil / 棕榈化石",
        "Stonefish_Name": "Stonefish / 石鱼",
        "Kale_Name": "Kale / 甘蓝菜",
        "FairySeeds_Name": "Fairy Seeds / 玫瑰仙子种子",
        "Stone_Name": "Stone / 石头",
        "WheatSeeds_Name": "Wheat Seeds / 小麦种子",
        "RhubarbPie_Description": "Mmm, tangy and sweet! / 嗯嗯，又香又甜！",
        "Weeds_Description": "A bunch of obnoxious weeds. / 一束令人讨厌的野草。",
        "Shad_Description": "Lives in a school at sea, but returns to the rivers to spawn. / 结群生活在海里，但会回到河里产卵。",
        "IridiumSprinkler_Name": "Iridium Sprinkler / 铱制洒水器",
        "Gate_Description": "Allows you to pass through a fence. / 让你有办法穿过围栏。",
        "AlgaeSoup_Description": "It's a little slimy. / 有些粘稠。",
        "Basalt_Description": "Forms near searing hot magma. / 在灼热的岩浆附近形成。",
        "CranberryCandy_Name": "Cranberry Candy / 蔓越莓糖果",
        "Chub_Description": "A common freshwater fish known for its voracious appetite. / 一种常见的淡水鱼，因贪吃的食性而广为人知。",
        "CrystalFloor_Name": "Crystal Floor / 水晶地板",
        "MysticSyrup_Name": "Mystic Syrup / 神秘糖浆",
        "SpringOnion_Description": "These grow wild during the spring. / 在春天时疯狂生长。",
        "Trash_Name": "Trash / 垃圾",
        "Lionfish_Description": "An aggressive, predatory fish with venomous spines. / 好斗的食肉性鱼，有毒刺。",
        "Weeds_FiberOrMixedSeeds_Ugly_Description": "Ugly weeds. Might contain fibers or mixed seeds. / 一束令人讨厌的野草。 Might contain fibers or mixed seeds.",
        "Grape_Description": "A sweet cluster of fruit. / 一串的香甜水果。",
        "DragonTooth_Name": "Dragon Tooth / 龙牙",
        "IridiumBand_Name": "Iridium Band / 铱环",
        "TroutDerbyTag_Name": "Golden Tag / 黄金标签",
        "Juice_Name": "Juice / 果汁",
        "Jelly_Description": "Gooey. / 黏糊糊的。",
        "IronOre_Name": "Iron Ore / 铁矿石",
        "Jasper_Description": "When polished, this stone becomes attractively luminous. Prized by ancient peoples for thousands of years. / 仔细打磨之后，这块石头能发出迷人的光彩。几千年以来都被人们作为奖品。",
        "WheatSeeds_Description": "Plant these in the summer or fall. Takes 4 days to mature. Harvest with the scythe. / 夏天或秋天播种。4 天成熟。用镰刀收获。",
        "TreasureTotem_Name": "Treasure Totem / 宝藏图腾",
        "RainbowShell_Name": "Rainbow Shell / 彩虹贝壳",
        "GalaxySoul_Description": "Forge 3 of these into a Galaxy weapon to unleash its final form. / 将 3 份银河之魂锻造进银河武器即可解锁最终形态。",
        "BeanStarter_Description": "Plant these in the spring. Takes 10 days to mature, but keeps producing after that. Grows on a trellis. / 春天播种。10 天成熟，但是之后会不断结果。在架子上生长。",
        "Slime_Description": "A shimmering, gelatinous glob with no smell. / 没有气味、发着微光的一团凝胶。",
        "Diamond_Name": "Diamond / 钻石",
        "SunflowerSeeds_Name": "Sunflower Seeds / 向日葵种子",
        "OceanStone_Description": "An old legend claims these stones are the mosaics of ancient mermaids. / 古老的传说声称这些石头是远古美人鱼的镶嵌画。",
        "RareDisc_Description": "A heavy black disc studded with peculiar red stones. When you hold it, you're overwhelmed with a feeling of dread. / 一个镶着奇异红石头的厚重黑色圆盘。当你握住它的时候，恐惧漫上了心头。",
        "Starfruit_Name": "Starfruit / 杨桃",
        "Torch_Description": "Provides a modest amount of light. / 能提供少许亮光。",
        "CaveCarrot_Description": "A starchy snack found in caves. It helps miners work longer. / 一种生长在山洞中的淀粉植物。能让矿工们更长时间工作。",
        "Sap_Name": "Sap / 树液",
        "EmeraldRing_Description": "Increases weapon speed by 10%. / 增加 10% 的武器速度。",
        "WinterRoot_Name": "Winter Root / 冬根",
        "Aquamarine_Description": "A shimmery blue-green gem. / 一种闪闪发亮的蓝绿色宝石。",
        "QualityRetainingSoil_Description": "This soil has a good chance of staying watered overnight. Mix into tilled soil. / 这种土壤有很大几率隔夜依然保持湿润。使用时加到犁过的土地中。",
        "Cranberries_Name": "Cranberries / 蔓越莓",
        "BatWing_Description": "The material is surprisingly delicate. / 这个素材出奇的精致。",
        "DressedSpinner_Description": "The metal tab and colorful streamers create an enticing spectacle for fish. Increases the bite-rate when fishing. / 金属片和彩色飘带构成的景象会吸引来鱼。增加钓鱼时的上钩率。",
        "Anchovy_Name": "Anchovy / 鳀鱼",
        "FallSeeds_Name": "Fall Seeds / 秋季种子",
        "SnowYam_Name": "Snow Yam / 雪山药",
        "Book_Crabbing_Description": "Crab pots have a 25% chance to yield double. / 蟹笼有 25% 的几率产出双倍。",
        "Lunarite_Description": "The cratered white orbs form a tight cluster. / 这些坑坑洼洼的矿石会紧密的聚集在一起。",
        "WhiteAlgae_Name": "White Algae / 白藻",
        "QualitySprinkler_Name": "Quality Sprinkler / 优质洒水器",
        "Stuffing_Description": "Ahh... the smell of warm bread and sage. / 啊……热面包和鼠尾草的香味。",
        "FriedMushroom_Name": "Fried Mushroom / 炒蘑菇",
        "Wheat_Name": "Wheat / 小麦",
        "FarAwayStone_Name": "Far Away Stone / 异界晶石",
        "BatWing_Name": "Bat Wing / 蝙蝠翅膀",
        "GoldenWalnut_Description": "To the parrots of Ginger Island, this nut is the finest delicacy. / 对姜岛的鹦鹉来说，这种坚果是最好的美味。",
        "RedPlate_Description": "Full of antioxidants. / 充满了抗氧化物。",
        "GoldenAnimalCracker_Description": "Give this to a farm animal to permanently double its produce yield. Doesn't work on pigs. / 给一只农场动物吃即可使其产量永久翻倍，对猪无效。",
        "DuckMayonnaise_Description": "It's a rich, yellow mayonnaise. / 香味浓郁的黄色蛋黄酱。",
        "SmallmouthBass_Description": "A freshwater fish that is very sensitive to pollution. / 一种对污染很敏感的淡水鱼。",
        "PoppySeeds_Name": "Poppy Seeds / 虞美人种子",
        "QiBean_Description": "Plant these in any season. Water every day to produce a Qi Fruit. Takes 4 days to mature. / 所有季节都可以种植。每天浇水可以产出齐瓜。4 天成熟。",
        "MermaidsPendant_Name": "Mermaid's Pendant / 美人鱼吊坠",
        "Oil_Description": "All purpose cooking oil. / 可煎可炸的万用食用油。",
        "RainTotem_Name": "Rain Totem / 雨水图腾",
        "QiSeasoning_Name": "Qi Seasoning / 齐氏调味料",
        "Orange_Description": "Juicy, tangy, and bursting with sweet summer aroma. / 多汁芬香，满满的都是夏天的香味。",
        "PurpleMushroom_Name": "Purple Mushroom / 紫蘑菇",
        "Vinegar_Name": "Vinegar / 醋",
        "LostBook_Description": "Writings from a wide variety of time periods. / 多个时代的作品。",
        "Omelet_Name": "Omelet / 煎蛋卷",
        "Book_Bombs_Description": "Bombs deal 25% less damage to you. / 炸弹对你造成的伤害减少 25%。",
        "CranberrySeeds_Name": "Cranberry Seeds / 蔓越莓种子",
        "Sashimi_Name": "Sashimi / 生鱼片",
        "SoggyNewspaper_Description": "This is trash. / 这是垃圾。",
        "Fluorapatite_Name": "Fluorapatite / 氟磷灰石",
        "CopperOre_Description": "A common ore that can be smelted into bars. / 一种常见的矿石，能被熔炼成铜锭。",
        "SeafoamPudding_Name": "Seafoam Pudding / 海泡布丁",
        "SpecialCharmDescription": "You received the {0}! You feel an aura of good fortune surrounding you (luck is permanently increased)! / 你收到了{0}！你会感觉到有福气光环环绕着自己（运气永久增加）！",
        "Stone_NodeWithCoal_Description": "Break apart to obtain stone with a chance of coal. / Break apart to obtain stone with a chance of coal.",
        "SalmonDinner_Description": "The lemon spritz makes it special. / 柠檬汁给它增添了特别的味道。",
        "Milk_Name": "Milk / 牛奶",
        "Honey_Name": "Honey / 蜂蜜",
        "PinkCake_Description": "There's little heart candies on top. / 蛋糕上面有小小的心型蜡烛。",
        "Wine_Name": "Wine / 果酒",
        "FriedEgg_Description": "Sunny-side up. / 正面像太阳一样。",
        "Poi_Description": "A traditional food with a delicate, sweet flavor when eaten fresh. / 一种传统食物，趁还新鲜时食用有一种细腻、微甜的味道。",
        "IridiumMilk_Name": "Iridium Milk / 铱奶",
        "Coconut_Name": "Coconut / 椰子",
        "SpringSeeds_Name": "Spring Seeds / 春季种子",
        "DwarfScrollII_Name": "Dwarf Scroll II / 矮人卷轴 II",
        "SpringOnionBugs": "Spring Onion Mastery / 青葱技术",
        "IceCream_Description": "It's hard to find someone who doesn't like this. / 很难找到一个不喜欢它的人。",
        "BananaSapling_Name": "Banana Sapling / 香蕉树苗",
        "Roe_Name": "Roe / 鱼籽",
        "Peach_Name": "Peach / 桃子",
        "AppleSapling_Name": "Apple Sapling / 苹果树苗",
        "DuckFeather_Description": "It's so colorful. / 真是五颜六色。",
        "Vinegar_Description": "An aged fermented liquid used in many cooking recipes. / 酿造过的酸性液体，许多配方中都会用到。",
        "Driftwood_Name": "Driftwood / 浮木",
        "Stonefish_Description": "A bizarre fish that's shaped like a brick. / 一种形状像砖块的奇怪鱼类。",
        "WoodFence_Name": "Wood Fence / 木围栏",
        "MummifiedFrog_Name": "Mummified Frog / 青蛙木乃伊",
        "WeatheredFloor_Name": "Weathered Floor / 风化地板",
        "CheeseCauliflower_Description": "It smells great! / 闻起来棒极了！",
        "GoldenMask_Description": "A creepy golden mask probably used in an ancient magic ritual. A socket in the forehead contains a large purple gemstone. / 一个大概被用于古代法术仪式的恐怖黄金面具。前额部位嵌着一个巨大的紫色宝石。",
        "BananaSapling_Description": "Takes 28 days to produce a mature Banana tree. Bears fruit in the summer, or all year round when planted on Ginger Island. / 28 天成熟为香蕉树。夏季结果实；种在姜岛上，一年四季都会结果实。",
        "Lumber_Description": "A versatile resource used for building and fuel. / 建房子以及当燃料的常用资源。",
        "Weeds_FiberOrMixedSeeds_Description": "Might contain fibers or mixed seeds. / Might contain fibers or mixed seeds.",
        "RustyCog_Name": "Rusty Cog / 生锈的齿轮",
        "SpicyEel_Description": "It's really spicy! Be careful. / 真的很辣！小心点。",
        "PrehistoricVertebra_Description": "A segment of some prehistoric creature's spine. / 某个史前生物脊椎的一部分。",
        "WildPlum_Description": "Tart and juicy with a pungent aroma. / 酸甜多汁，香味浓烈。",
        "Neptunite_Name": "Neptunite / 柱星叶石",
        "GalaxySoul_Name": "Galaxy Soul / 银河之魂",
        "BlueDiscus_Description": "A brightly colored tropical fish that is popular in aquariums. / 色彩鲜艳的热带鱼，在水族馆很受欢迎。",
        "Seaweed_Name": "Seaweed / 海草",
        "ArtichokeSeeds_Description": "Plant these in the fall. Takes 8 days to mature. / 秋天播种。8 天成熟。",
        "BlueJazz_Name": "Blue Jazz / 蓝爵",
        "Cockle_Description": "A common saltwater clam. / 一种常见的咸水蛤。",
        "Halibut_Name": "Halibut / 大比目鱼",
        "Tomato_Description": "Rich and slightly tangy, the Tomato has a wide variety of culinary uses. / 口感丰富，味道略有些强烈。西红柿有非常广泛的烹饪用途。",
        "Legend_Description": "The king of all fish! They said he'd never be caught. / 万鱼之王！传说它永远不会被抓到。",
        "Goby_Name": "Goby / 虾虎鱼",
        "Sunflower_Description": "A common misconception is that the flower turns so it's always facing the sun. / 一直被误会为向着太阳转动。",
        "MagmaGeodeStone_Description": "Break apart to obtain magma geodes. / Break apart to obtain magma geodes.",
        "Caviar_Description": "The cured roe of a sturgeon fish. Considered to be a luxurious delicacy! / 腌制的鲟鱼籽。普遍认为这是一种奢华的美食！",
        "DeluxeFertilizer_Description": "Greatly improves soil quality, increasing your chance to grow quality crops. Mix into tilled soil. / 大幅提高土壤品质，增加你种出高品质作物的可能性。使用时加到犁过的土地中。",
        "EmeraldStone_Name": "Emerald Stone / Emerald Stone",
        "FiddleheadFern_Description": "The young shoots are an edible specialty. / 这些嫩芽是一种可食用的特产。",
        "RabbitsFoot_Name": "Rabbit's Foot / 兔子的脚",
        "Amaranth_Description": "A purple grain cultivated by an ancient civilization. / 远古文明广泛耕种的一种紫色谷物。",
        "FriedCalamari_Name": "Fried Calamari / 炸鱿鱼",
        "SkillBook2_Name": "Woodcutter's Weekly / 樵夫周刊",
        "Book_Mystery_Description": "You have a slightly greater chance to find Mystery Boxes. / 你找到谜之盒的几率稍微变高了一些。",
        "Pancakes_Name": "Pancakes / 薄煎饼",
        "Book_Friendship_Name": "Friendship 101 / 交友导论",
        "GhostCrystal_Description": "There is an aura of coldness around this crystal. / 这块水晶的附近有着冰冷的光环。",
        "SummerSeeds_Name": "Summer Seeds / 夏季种子",
        "CobblestonePath_Name": "Cobblestone Path / 鹅卵石小径",
        "Weeds_Fiber_Ugly_Name": "Weeds / 杂草",
        "LostBook_Name": "Lost Book / 遗失之书",
        "Radish_Name": "Radish / 萝卜",
        "WinterSeeds_Description": "An assortment of wild winter seeds. / 各种各样的冬季种子。",
        "Coral_Description": "A colony of tiny creatures that clump together to form beautiful structures. / 小生物的聚集地，它们聚集起来形成美妙的形状。",
        "HotPepper_Name": "Hot Pepper / 辣椒",
        "TulipBulb_Description": "Plant in spring. Takes 6 days to produce a colorful flower. Assorted colors. / 春天下种。6 天产出鲜艳花朵。多种颜色。",
        "PowdermelonSeeds_Name": "Powdermelon Seeds / 霜瓜种子",
        "AncientFruitPot": "Her roots grow very deep... she wouldn't be happy in there. / 她的根长得很深……她在那里不会高兴。",
        "FossilizedSkull_Description": "It's a perfect specimen! / 这是一个完美的标本！",
        "Mayonnaise_Description": "It looks spreadable. / 看起来很适合抹在面包上。",
        "Book_Diamonds_Description": "All stones have a chance to drop a diamond when mined by hand. / 手动凿开石头时有几率掉落钻石。",
        "ChippedAmphora_Description": "An ancient vessel made of ceramic material. Used to transport both dry and wet goods. / 陶瓷做的古老容器。用来运送各种货物。",
        "StrawFloor_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "QualityRetainingSoil_Name": "Quality Retaining Soil / 高级保湿土壤",
        "SoggyNewspaper_Name": "Soggy Newspaper / 湿透的报纸",
        "BatteryPack_Description": "It's fully charged with precious energy. / 充满了宝贵的能量。",
        "Beer_Name": "Beer / 啤酒",
        "Spinner_Name": "Spinner / 旋式鱼饵",
        "CalicoEgg_Description": "A unique egg that can be found during the Desert Festival. / 沙漠节期间可以获得的一种特别的蛋。",
        "RedMushroom_Description": "A spotted mushroom sometimes found in caves. / 这种斑点蘑菇偶尔出现在山洞中。",
        "StardropTea_Name": "Stardrop Tea / 星之果茶",
        "Coal_Description": "A combustible rock that is useful for crafting and smelting. / 一种可燃的矿石，可用于加工和熔炼。",
        "SweetGemBerry_Name": "Sweet Gem Berry / 宝石甜莓",
        "GoldStone_Name": "Gold Stone / Gold Stone",
        "BrownEgg_Name": "Egg / 蛋",
        "BoneFlute_Description": "It's a prehistoric wind instrument carved from an animal's bone. It produces an eerie tone. / 一个用动物骨头雕刻而成的史前管乐器。它发出的声音很诡异。",
        "QualityFertilizer_Name": "Quality Fertilizer / 高级肥料",
        "Arrowhead_Name": "Arrowhead / 箭头",
        "DrumBlock_Name": "Drum Block / 鼓块",
        "BlueJazz_Description": "The flower grows in a sphere to invite as many butterflies as possible. / 这种花朵为圆球状，以便吸引更多的蝴蝶而来。",
        "Book_Roe_Name": "Jewels Of The Sea / 海之宝石",
        "WarpTotemFarm_Name": "Warp Totem: Farm / 传送图腾：农场",
        "Mudstone_Name": "Mudstone / 泥石",
        "SupplyCrate_Name": "SupplyCrate / 补给箱",
        "GoldOre_Description": "A precious ore that can be smelted into bars. / 一种珍贵的矿石，能被熔炼成金锭。",
        "MutantCarp_Name": "Mutant Carp / 变种鲤鱼",
        "Wine_Flavored_Name": "{0} Wine / {0}果酒",
        "CookoutKit_Description": "Use this to create a cooking campfire, allowing you to cook on-the-go! / 可以生成一个用于烹饪的营火，让你随时随地都能烹饪！",
        "AgedRoe_Description": "Fish eggs aged in salt to bring out the flavor. / 在盐中腌制使之入味的鱼籽。",
        "DwarfScrollI_Description": "A yellowed scroll of parchment filled with dwarven script. This one's tied with a red bow. / 一个写满矮人语的黄色羊皮卷轴。这一个上面系着红色蝴蝶结。",
        "Morel_Description": "Sought after for its unique nutty flavor. / 因为独特的味道而深受欢迎。",
        "MahoganySeed_Name": "Mahogany Seed / 桃花心木种子",
        "Malachite_Description": "A popular ornamental stone, used in sculpture and to make green paint. / 一种非常受欢迎的装饰品，经常用在雕塑中，也被用来做绿色的颜料。",
        "FireOpal_Name": "Fire Opal / 赤红猫眼石",
        "SnakeVertebrae_Description": "It appears this serpent may have been extremely flexible. / 这条蛇似乎非常灵活。",
        "Weeds_Name": "Weeds / 杂草",
        "Woodskip_Description": "A very sensitive fish that can only live in pools deep in the forest. / 一种十分敏感的鱼，只能在森林深处的水池中生存。",
        "CommonMushroom_Description": "Slightly nutty, with good texture. / 稍微坚硬，肉质滑。",
        "PaleBroth_Name": "Pale Broth / 清汤",
        "LGoatMilk_Name": "L. Goat Milk / 大瓶羊奶",
        "Book_Speed2_Description": "You run a little bit faster. / 你的跑步速度变快了一点。",
        "FossilizedSpine_Description": "A column of interlocking vertebrae. / 一列紧密连接的脊椎骨。",
        "LobsterBisque_Name": "Lobster Bisque / 龙虾浓汤",
        "Dolomite_Description": "It can occur in coral reefs, often near an underwater volcano. / 有时会在珊瑚礁上出现，大部分时候是在水下火山附近。",
        "Moss_Description": "A special type of plant that grows in shady areas. / 生长在阴暗处的特殊植物。",
        "MagicBait_Name": "Magic Bait / 魔法鱼饵",
        "Amethyst_Name": "Amethyst / 紫水晶",
        "GoldenCoconut_Name": "Golden Coconut / 金色椰子",
        "FarAwayStone_Description": "A stone of unknown origins. Looks like it could be placed into something. / 来历不明的晶石，似乎能装到什么东西上面。",
        "Herring_Description": "A common ocean fish. / 一种常见的海鱼。",
        "BugMeat_Description": "It's a juicy wad of bug flesh. / 一小团多汁的虫肉。",
        "Hazelnut_Name": "Hazelnut / 榛子",
        "OilofGarlic_Description": "Drink this and weaker monsters will avoid you. / 喝下它，弱小的魔物就会避开你。",
        "RiverJelly_Description": "A rare jelly found in freshwater. / 存在于淡水里的罕见凝胶。",
        "Sandstone_Description": "A common type of stone with red and brown striations. / 一种常见的石头，有着红色和棕色的辉纹。",
        "Nekoite_Name": "Nekoite / 新硅钙石",
        "Stuffing_Name": "Stuffing / 塞料面包",
        "PrehistoricTool_Name": "Prehistoric Tool / 史前工具",
        "BerryBasket_Description": "The fibers are stained with berry juice. / 编条上占满了浆果汁。",
        "SlimeCrate_Name": "Slime Crate / 史莱姆箱",
        "Seaweed_Description": "It can be used in cooking. / 它可以被用于烹饪。",
        "Mussel_Name": "Mussel / 蚌",
        "DwarfScrollI_Name": "Dwarf Scroll I / 矮人卷轴 I",
        "ThunderEgg_Name": "Thunder Egg / 雷公蛋",
        "TrimmedLuckyPurpleShorts_Name": "Trimmed Lucky Purple Shorts / 镶边幸运紫色短裤",
        "Trilobite_Name": "Trilobite / 三叶虫",
        "PrehistoricVertebra_Name": "Prehistoric Vertebra / 史前脊骨",
        "SurvivalBurger_Description": "A convenient snack for the explorer. / 探险家们的便携小吃。",
        "CactusFruit_Name": "Cactus Fruit / 仙人掌果子",
        "Escargot_Description": "Butter-soaked snails cooked to perfection. / 淋上黄油的田螺，做的恰到火候。",
        "GoldenCoconut_Description": "This is one tough nut to crack, but a professional might be able to break it open. / 这玩意儿很难开，但是有专家可以敲开。",
        "RadioactiveCarp_Name": "Radioactive Carp / 放射性鲤鱼",
        "Tilapia_Description": "A primarily vegetarian fish that prefers warm water. / 一种主要食素、喜爱温水的鱼。",
        "FluteBlock_Description": "Plays a flute sound when you walk past. / 走上去的时候会发出笛子的声音。",
        "GlazedYams_Name": "Glazed Yams / 琉璃山药",
        "Book_Artifact_Description": "You will fetch a better price when selling artifacts. / 出售古物时价格更高。",
        "CalicoEgg_Name": "Calico Egg / 卡利科三花蛋",
        "AncientDoll_Name": "Ancient Doll / 古代玩偶",
        "Sugar_Name": "Sugar / 糖",
        "LemonStone_Description": "Some claim the powdered crystal is a dwarvish delicacy. / 有些人说这种粉状的晶石是矮人的佳肴。",
        "EggplantParmesan_Name": "Eggplant Parmesan / 帕尔玛奶酪茄子",
        "WiltedBouquet_Description": "A gift that shows you want to stop dating someone. / 表示你不想再和某人约会的礼物。",
        "TaroRoot_Description": "This starchy root is one of the most ancient crops. / 这种根茎富含淀粉，是最古老的农作物之一。",
        "IridiumBar_Name": "Iridium Bar / 铱锭",
        "DecorativePot_Description": "A replica of an ancient pot. / 一件古代壶的复制品。",
        "PepperPoppers_Description": "Spicy breaded peppers filled with cheese. / 裹着面包屑的辣青椒装满了乳酪。",
        "PumpkinPie_Description": "Silky pumpkin cream in a flaky crust. / 古怪的脆皮里面有丝滑的南瓜酱。",
        "GoldenEgg_Description": "A very rare and special egg with a solid gold shell. / 非常独特、罕见的蛋，金色的蛋壳非常坚固。",
        "SpringSeeds_Description": "An assortment of wild spring seeds. / 各种各样的春季种子。",
        "SweetPea_Description": "A fragrant summer flower. / 芬香的夏天花朵。",
        "WarpTotemBeach_Name": "Warp Totem: Beach / 传送图腾：海滩",
        "CrabPot_Description": "Place it in the water, load it with bait, and check the next day to see if you've caught anything. Works in streams, lakes, and the ocean. / 放在水中，装上诱饵，隔一天再检查有没有抓到东西。可以在溪流、湖泊和大海使用。",
        "AmaranthSeeds_Name": "Amaranth Seeds / 苋菜种子",
        "Stone_NodeWithCoal_Name": "Stone / 石头",
        "Leek_Description": "A tasty relative of the onion. / 洋葱的美味近亲。",
        "GoatCheese_Name": "Goat Cheese / 山羊奶酪",
        "LargeMilk_Description": "A large jug of cow's milk. / 一大壶牛奶。",
        "Morel_Name": "Morel / 羊肚菌",
        "SonofCrimsonfish_Name": "Son of Crimsonfish / 绯红鱼之子",
        "ChickenStatue_Description": "It's a statue of a chicken on a bronze base. The ancient people of this area must have been very fond of chickens. / 一个青铜底座的鸡雕像。这个地区的古代人一定很喜欢鸡。",
        "BarbedHook_Name": "Barbed Hook / 倒刺钩",
        "Sandfish_Description": "It tries to hide using camouflage. / 它用保护色隐藏自己。",
        "DeluxeSpeedGro_Description": "Stimulates leaf production. Guaranteed to increase growth rate by at least 25%. Mix into tilled soil. / 促进叶子生长。保证能让植物的生长速度加快 25%。使用时加到犁过的土地中。",
        "BlueberryTart_Description": "It's subtle and refreshing. / 味道微妙而又清新。",
        "TroutDerbyTag_Description": "Turn this in to the Trout Derby booth for a reward. / 交给鳟鱼大赛摊位即可获得奖励。",
        "CopperOre_Name": "Copper Ore / 铜矿石",
        "SlimeCharmerRing_Description": "Prevents damage from slimes. / 防止史莱姆的破坏。",
        "OrnamentalFan_Name": "Ornamental Fan / 装饰用扇子",
        "VegetableMedley_Description": "This is very nutritious. / 这非常有营养。",
        "DiamondStone_Description": "Break apart to obtain diamonds. / Break apart to obtain diamonds.",
        "Blobfish_Description": "This odd creature floats above the ocean floor, consuming any edible material in its path. / 这些古怪的生物漂浮在海底上，吃掉所经之地的任何可食材料。",
        "Garlic_Name": "Garlic / 蒜",
        "Clam_Name": "Clam / 蛤",
        "GrassStarter_Name": "Grass Starter / 草籽",
        "Escargot_Name": "Escargot / 法式田螺",
        "PoppySeeds_Description": "Plant in summer. Produces a bright red flower in 7 days. / 夏天下种。7 天产出大红花。",
        "SeafoamPudding_Description": "This briny pudding will really get you into the maritime mindset! / 这种咸布丁真的会让你感受到大海的气息！",
        "FriedEel_Description": "Greasy but flavorful. / 油腻而可口。",
        "AmphibianFossil_Name": "Amphibian Fossil / 两栖动物化石",
        "Enricher_Description": "Place on a sprinkler and load with fertilizer to automatically apply it when planting seeds nearby. / 安装在洒水器上并装入肥料，在其附近播撒种子时便会自动施肥。",
        "GoldenPumpkin_Description": "It's valuable but has no other purpose. / 十分贵重，但没有任何实际作用。",
        "Book_Marlon_Description": "You get a 50% discount on Marlon's item retrieval service. / 马龙取回物品时费用给你打五折。",
        "LGoatMilk_Description": "A gallon of creamy goat's milk. / 一加仑口感细腻的山羊奶。",
        "Bixite_Name": "Bixite / 黑方石",
        "RadioactiveOre_Name": "Radioactive Ore / 放射性矿石",
        "Celestine_Description": "Some early life forms had bones made from this. / 有些早期生物的骨头的成分就是这种石头。",
        "PrismaticJelly_Name": "Prismatic Jelly / 五彩胶冻",
        "Rhubarb_Description": "The stalks are extremely tart, but make a great dessert when sweetened. / 根茎极酸，但是加糖后是一种美味的甜品。",
        "GemStone_Name": "Gem Stone / Gem Stone",
        "FiberSeeds_Description": "Plant these in any season. Does not require watering. Harvest with the scythe. Takes 7 days to grow. / 所有季节都可以种植。不需要浇水。用镰刀收割。7 天长成。",
        "ArtifactTrove_Description": "A blacksmith can open this for you. These troves often contain ancient relics and curiosities. / 铁匠可以帮你打开。这些宝藏一般会藏有古董和奇珍异宝。",
        "SeaJelly_Name": "Sea Jelly / 海凝胶",
        "DriedFruit_Name": "Dried / Dried",
        "MagnetRing_Name": "Magnet Ring / 磁铁戒指",
        "WildBait_Name": "Wild Bait / 万能鱼饵",
        "IridiumSprinkler_Description": "Waters the 24 adjacent tiles every morning. / 每天早晨灌溉临近的 24 个地块。",
        "Cranberries_Description": "These tart red berries are a traditional winter food. / 这些红色的酸梅是传统的冬天食品。",
        "RadishSeeds_Name": "Radish Seeds / 萝卜种子",
        "AquamarineStone_Description": "Break apart to obtain aquamarines. / Break apart to obtain aquamarines.",
        "RingofYoba_Name": "Ring of Yoba / 由巴的戒指",
        "PetrifiedSlime_Description": "This little guy may be 100,000 years old. / 这小家伙也许有十万岁了。",
        "Blueberry_Name": "Blueberry / 蓝莓",
        "ExplosiveAmmo_Name": "Explosive Ammo / 爆炸弹丸",
        "MakiRoll_Name": "Maki Roll / 生鱼寿司",
        "FarmersLunch_Name": "Farmer's Lunch / 农夫午餐",
        "FieldSnack_Description": "A quick snack to fuel the hungry forager. / 给饥饿的采集者迅速补充能量。",
        "BananaPudding_Description": "A creamy dessert with a wonderful tropical flavor. / 奶油甜点，具有美妙的热带风味。",
        "FossilizedSkull_Name": "Fossilized Skull / 颅骨化石",
        "MossySeed_Name": "Mossy Seed / 长满苔藓的种子",
        "IridiumBand_Description": "Glows, attracts items, and increases attack damage by 10%. / 光辉，吸引物品，增加 10% 的攻击伤害。",
        "BasicRetainingSoil_Description": "This soil has a chance of staying watered overnight. Mix into tilled soil. / 这种土壤有一定几率隔夜依然保持湿润。使用时加到犁过的土地中。",
        "WarpTotemIsland_Name": "Warp Totem: Island / 传送图腾：姜岛",
        "DwarfGadget_Description": "It's a piece of the advanced technology once known to the dwarves. It's still glowing and humming, but you're unable to understand how it works. / 这个小工具是矮人先进工艺的一小块结晶。它还在发光和响动，但是你无法理解它的工作原理。",
        "AncientFruit_Description": "It's been dormant for eons. / 千万年来冬眠中的水果。",
        "Periwinkle_Name": "Periwinkle / 玉黍螺",
        "MagicInk": "Magic Ink / 魔法墨水",
        "Snail_Name": "Snail / 蜗牛",
        "PrehistoricRib_Description": "Little gouge marks on the side suggest that this rib was someone's dinner. / 肋骨一侧的浅沟说明这根肋骨曾经是什么人的晚餐。",
        "Pufferfish_Description": "Inflates when threatened. / 它受到威胁时会膨胀。",
        "LostAxe_Description": "Robin's been looking everywhere for it. / 罗宾正到处在找它。",
        "Book_QueenOfSauce_Description": "Learn any Queen Of Sauce recipes that you don't already know. / 可以学习你尚未掌握的酱料女皇食谱。",
        "PepperPoppers_Name": "Pepper Poppers / 爆炒青椒",
        "SeaUrchin_Name": "Sea Urchin / 海胆",
        "Pomegranate_Name": "Pomegranate / 石榴",
        "QiFruit_Name": "Qi Fruit / 齐瓜",
        "Weeds_Fiber_Ugly_Description": "Ugly weeds. Cut to obtain wild seeds. / 一束令人讨厌的野草。 Cut to obtain wild seeds.",
        "PowdermelonSeeds_Description": "This special melon grows in the winter. Takes 7 days to grow. / 冬天生长的特殊瓜类，7 天成熟。",
        "GreenRainWeeds_Description": "Might contain fibers or mixed seeds. / 可能含有纤维或混合种子。",
        "DriedMushrooms_Name": "Dried / Dried",
        "SkillBook1_Name": "Bait And Bobber / 鱼饵和浮漂",
        "EggplantParmesan_Description": "Tangy, cheesy, and wonderful. / 味道浓烈，芝香浓郁，好吃极了。",
        "AmethystRing_Description": "Increases knockback by 10%. / 增加 10% 的击退率。",
        "WarMemento_Description": "It's a faded photograph of a soldier... / 这是一张褪色的士兵照片……",
        "Blackberry_Name": "Blackberry / 黑莓",
        "CranberrySauce_Name": "Cranberry Sauce / 红莓酱",
        "QiBean_Name": "Qi Bean / 齐豆",
        "CinderShard_Name": "Cinder Shard / 火山晶石",
        "StrangeDoll_Description": "??? / ???",
        "NautilusShell_Description": "An ancient shell. / 一种古老的贝壳生物。",
        "MysteryBox_Description": "A blacksmith can open this for you. Who knows what might be inside? / 铁匠可以帮你打开。谁知道里面装着什么？",
        "ProtectionRing_Description": "Stay invincible for a little while longer after taking damage. / 在受到伤害后，保持一定时间的无敌状态。",
        "StoneWalkwayFloor_Name": "Stone Walkway Floor / 石制走道地板",
        "DinosaurEgg_Description": "A giant dino egg... The entire shell is still intact! / 一个巨大的恐龙蛋……它的壳还保存的很完整呢！",
        "WarpTotemIsland_Description": "Warp directly to Ginger Island. Consumed on use. / 直接将你传送到姜岛。消耗品。",
        "BurglarsRing_Description": "Monsters have a greater chance of dropping loot. / 怪物有很大机会掉落战利品。",
        "GlowstoneRing_Description": "Emits a constant light, and also increases your radius for collecting items. / 散发出稳定的光芒，并增加收集物品的范围。",
        "RadioactiveBar_Name": "Radioactive Bar / 放射性矿锭",
        "FluteBlock_Name": "Flute Block / 长笛块",
        "LegendII_Description": "The successor to the original Legend. / 传说之鱼的继任者。",
        "SpecificBait_Name": "Bait / 鱼饵",
        "PaleAle_Name": "Pale Ale / 淡啤酒",
        "SteppingStonePath_Name": "Stepping Stone Path / 垫脚石小径",
        "RoastedHazelnuts_Description": "The roasting process creates a rich forest flavor. / 烤制工序使香味格外浓郁。",
        "CrabshellRing_Name": "Crabshell Ring / 蟹壳戒指",
        "TeaSapling_Name": "Tea Sapling / 茶苗",
        "MegaBomb_Description": "Generates a powerful explosion. Use with extreme caution. / 会发生大爆炸。使用时请格外小心。",
        "Lingcod_Description": "A fearsome predator that will eat almost anything it can cram into its mouth. / 可怕的捕食者，会吞下一切可以吃下的东西。",
        "Sturgeon_Description": "An ancient bottom-feeder with a dwindling population. Females can live up to 150 years. / 古老的生物链底层生物，数量一直在减少。雌性的寿命长达 150 年。",
        "MysticStone_Name": "Mystic Stone / Mystic Stone",
        "JackOLantern_Name": "Jack-O-Lantern / 南瓜灯",
        "HotJavaRing_Name": "Hot Java Ring / 热咖啡戒指",
        "RedCabbage_Description": "Often used in salads and coleslaws. The color can range from purple to blue to green-yellow depending on soil conditions. / 常用来做沙拉或者凉拌卷心菜。由于土地条件不同，颜色可能是紫色或者蓝色或者黄绿色。",
        "PressureNozzle_Name": "Pressure Nozzle / 加压喷头",
        "BokChoySeeds_Description": "Plant these in the fall. Takes 4 days to mature. / 秋天播种。4 天成熟。",
        "DarkTalismanDescription": "You've found the {0}! It's covered in bug slime... / 你找到了{0}！它沾满了虫泥……",
        "Bullhead_Name": "Bullhead / 大头鱼",
        "RadioactiveOre_Description": "It's glowing with dangerous energy... Can be smelted into bars. / 它散发出危险的能量……可以熔炼成矿锭。",
        "Wool_Name": "Wool / 动物毛",
        "Twig_Description": "A broken branch. Chop with an axe to obtain wood. / A broken branch. Chop with an axe to obtain wood.",
        "CaskNoCellar": "Only works in Cellar. / 仅限地窖中使用。",
        "BokChoySeeds_Name": "Bok Choy Seeds / 小白菜种子",
        "Book_Speed_Name": "Way Of The Wind pt. 1 / 风之道 第一部分",
        "CobblestonePath_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "TigerTrout_Description": "A rare hybrid trout that cannot bear offspring of its own. / 一种不能繁殖后代的稀有杂交鳟鱼。",
        "WhiteAlgae_Description": "It's super slimy. / 它超级黏。",
        "AncientDrum_Description": "It's a drum made from wood and animal skin. It has a low, reverberating tone. / 这是一个用木头和动物皮做的鼓。它能发出低沉、经久不息的声音。",
        "CranberrySauce_Description": "A festive treat. / 秋日特供。",
        "ArtichokeSeeds_Name": "Artichoke Seeds / 洋蓟种子",
        "Coconut_Description": "A seed of the coconut palm. It has many culinary uses. / 椰树的种子。用途广泛。",
        "SnowyStone_Description": "Break apart to obtain stone, ores, or geodes. / Break apart to obtain stone, ores, or geodes.",
        "Coffee_Name": "Coffee / 咖啡",
        "Crocus_Description": "A flower that can bloom in the winter. / 冬天开花的一种花朵。",
        "TrapBobber_Name": "Trap Bobber / 陷阱浮标",
        "IridiumOre_Description": "An exotic ore with many curious properties. Can be smelted into bars. / 一种有着很多稀奇属性的独特矿石。能被熔炼成铱锭。",
        "CompleteBreakfast_Name": "Complete Breakfast / 完美早餐",
        "GoldenEgg_Name": "Golden Egg / 金蛋",
        "Esperite_Name": "Esperite / 硅钙石",
        "BananaPudding_Name": "Banana Pudding / 香蕉布丁",
        "SeaCucumber_Name": "Sea Cucumber / 海参",
        "MahoganySeed_Description": "This can be planted to grow a mahogany tree. / 可以种出一棵桃花心木。",
        "QiGem_Description": "A special currency honored by Mr. Qi. / 齐先生的特殊货币。",
        "MuscleRemedy_Description": "When you've pushed your body too hard, drink this to remove 'Exhaustion'. / 当你使自己的身体过度劳累时，喝下它来解除“筋疲力尽”的状态。",
        "ClayStone_Name": "Clay Stone / Clay Stone",
        "RootsPlatter_Description": "This'll get you digging for more. / 让人食指大动，停不下来。",
        "Starfruit_Description": "An extremely juicy fruit that grows in hot, humid weather. Slightly sweet with a sour undertone. / 美味多汁的热带水果。稍甜，夹着酸味。",
        "Slimejack_Description": "He's coated in a very thick layer of slime. He keeps slipping out of your hands! / 它身上裹了厚厚一层粘液，拿在手里总是要滑脱！",
        "Mango_Name": "Mango / 芒果",
        "Truffle_Description": "A gourmet type of mushroom with a unique taste. / 一种味道极佳的菌类，有着独特的风味。",
        "AutumnsBounty_Description": "A taste of the season. / 秋日的风味。",
        "Pickles_Description": "A jar of your home-made pickles. / 一罐自制的腌菜。",
        "Book_Defense_Description": "Gain +1 Defense. / 获得 +1 防御。",
        "PeachSapling_Description": "Takes 28 days to produce a mature Peach tree. Bears fruit in the summer. Only grows if the 8 surrounding \"tiles\" are empty. / 28 天成熟为成年桃子树。夏天结果。只有在附近 8 块“地块”都空置的情况下才会成长。",
        "BugSteak_Name": "Bug Steak / 虫肉块",
        "Bread_Name": "Bread / 面包",
        "TentKit_Name": "Tent Kit / 便携帐篷",
        "NapalmRing_Description": "When you defeat an enemy, they explode. / 当你击败敌人时，它们会爆炸。",
        "Apple_Description": "A crisp fruit used for juice and cider. / 爽口的水果，可做果汁和醋。",
        "Cauliflower_Name": "Cauliflower / 花椰菜",
        "Enricher_Name": "Enricher / 施肥器",
        "Book_QueenOfSauce_Name": "Queen Of Sauce Cookbook / 酱料女皇烹饪秘籍",
        "Hazelnut_Description": "That's one big hazelnut! / 真是巨大的一颗榛子！",
        "JackOLantern_Description": "A whimsical fall decoration. / 秋天的怪异装饰品。",
        "LeadBobber_Name": "Lead Bobber / 铅制浮标",
        "NautilusFossil_Name": "Nautilus Fossil / 鹦鹉螺化石",
        "TeaSapling_Description": "Takes 20 days to mature. Produces tea leaves during the final week of each season, except winter. No watering necessary! / 需要 20 天才能成熟。在每个季节的最后一周产出茶叶，冬季除外。无需浇水！",
        "DwarfScrollII_Description": "A yellowed scroll of parchment filled with dwarven script. This one's tied with a green ribbon. / 一个写满矮人语的黄色羊皮卷轴。这一个上面系着绿色丝带。",
        "BoneFragment_Name": "Bone Fragment / 骨头碎片",
        "Trilobite_Description": "A long extinct relative of the crab. / 一种早已灭绝的生物，和螃蟹有亲缘关系。",
        "Beet_Description": "A sweet and earthy root vegetable. As a bonus, the leaves make a great salad. / 香甜的根茎植物。它的叶子非常适合做沙拉。",
        "SkillBook3_Name": "Mining Monthly / 采矿月刊",
        "GreenSlimeEgg_Description": "Can be hatched in a slime incubator. / 可以在史莱姆孵化器中孵化。",
        "Orange_Name": "Orange / 橙子",
        "Helvite_Description": "It grows in a triangular column. / 出现的时候总按三角形排列。",
        "LobsterBisque_Description": "This delicate soup is a secret family recipe of Willy's. / 这碗精致的汤用了威利家秘传的配方。",
        "Hardwood_Name": "Hardwood / 硬木",
        "Twig_Name": "Twig / 嫩枝",
        "Weeds_DryBush_Name": "Weeds / 杂草",
        "BlueberrySeeds_Name": "Blueberry Seeds / 蓝莓种子",
        "IronOre_Description": "A fairly common ore that can be smelted into bars. / 一种常见的矿石，能被熔炼成铁锭。",
        "Octopus_Name": "Octopus / 章鱼",
        "BasicFertilizer_Description": "Improves soil quality a little, increasing your chance to grow quality crops. Mix into tilled soil. / 稍微提高土壤品质，增加你种出高品质作物的几率。使用时加到犁过的土地中。",
        "AmethystStone_Description": "Break apart to obtain amethysts. / Break apart to obtain amethysts.",
        "StarfruitSeeds_Description": "Plant these in the summer. Takes 13 days to mature. / 夏天播种。13 天成熟。",
        "TeaLeaves_Description": "The young leaves of the tea plant. Can be brewed into the popular, energizing beverage. / 茶树幼叶。可冲泡成受人欢迎的提神茶水。",
        "RustyCog_Description": "A well preserved cog that must have been part of some ancient machine. This could be dwarven technology. / 一个保存完好的齿轮，它一定是某个古代机器的一部分。这可能是矮人工艺出品。",
        "Hashbrowns_Description": "Crispy and golden-brown! / 金黄酥脆！",
        "MagmaGeode_Name": "Magma Geode / 岩浆晶球",
        "Book_AnimalCatalogue_Name": "Animal Catalogue / 动物目录",
        "Parsnip_Description": "A spring tuber closely related to the carrot. It has an earthy taste and is full of nutrients. / 一种和胡萝卜很相似的春季块茎植物。它营养丰富且带有泥土的气息。",
        "Tomato_Name": "Tomato / 西红柿",
        "Obsidian_Name": "Obsidian / 黑曜石",
        "WeddingRing_Name": "Wedding Ring / 结婚戒指",
        "Anchovy_Description": "A small silver fish found in the ocean. / 一种海里的小银鱼。",
        "WhiteEgg_Name": "Egg / 蛋",
        "Pancakes_Description": "A double stack of fluffy, soft pancakes. / 双层的松软煎饼。",
        "CookoutKit_Name": "Cookout Kit / 野炊工具",
        "KaleSeeds_Name": "Kale Seeds / 甘蓝种子",
        "Wheat_Description": "One of the most widely cultivated grains. Makes a great flour for breads and cakes. / 被广泛种植的谷物之一。能做成制作蛋糕和面包的上好面粉。",
        "Coleslaw_Name": "Coleslaw / 卷心菜沙拉",
        "TeaSet_Description": "Fine porcelain. / 上好的瓷器。",
        "WoodPath_Name": "Wood Path / 木头小径",
        "Cloth_Name": "Cloth / 布料",
        "GingerAle_Name": "Ginger Ale / 姜汁汽水",
        "SmallGlowRing_Name": "Small Glow Ring / 小型光辉戒指",
        "ThornsRing_Description": "When enemies damage you, they will take damage themselves. / 当敌人对你造成伤害时，他们也将受到伤害。",
        "DeluxeBait_Description": "Causes fish to bite even faster and increases size of the \"fishing bar\". / 使鱼更快咬钩，并且让“钓鱼条”更长。",
        "SkillBook0_Description": "Read this to gain some farming experience. / 阅读即可获得耕种经验。",
        "VoidEgg_Description": "A jet-black egg with red flecks. It's warm to the touch. / 有红色斑点的黝黑的蛋。摸起来热热的。",
        "PepperSeeds_Name": "Pepper Seeds / 辣椒种子",
        "JournalScrap_Name": "Journal Scrap / 日记残页",
        "SnakeVertebrae_Name": "Snake Vertebrae / 蛇脊椎骨",
        "GoldCoin_Name": "Gold Coin / 金币",
        "Book_Riding_Name": "Horse: The Book / 马术秘籍",
        "StardewValleyRose_Description": "A rose that reminds you of the valley. It smells heavenly. / 会让你想起星露谷的玫瑰。香气令人愉悦。",
        "SkillBook4_Description": "Read this to gain some combat experience. / 阅读即可获得战斗经验。",
        "Chowder_Name": "Chowder / 海鲜杂烩汤",
        "Cherry_Description": "It's popular, and ripens sooner than most other fruits. / 很受欢迎，比一般水果更快成熟。",
        "CornSeeds_Description": "Plant these in the summer or fall. Takes 14 days to mature, and continues to produce after first harvest. / 夏天或秋天播种。14 天成熟，收获之后还能继续结果。",
        "Yam_Description": "A starchy tuber with a lot of culinary versatility. / 淀粉块茎植物，有很多食用方式。",
        "PierresMissingStocklist_Description": "Pierre might be interested in this. / 皮埃尔可能会感兴趣。",
        "GoldenMysteryBox_Name": "Golden Mystery Box / 金色谜之盒",
        "Tulip_Description": "The most popular spring flower. Has a very faint sweet smell. / 最受欢迎的春天花朵。淡淡的芳香味。",
        "RedMullet_Name": "Red Mullet / 红鲻鱼",
        "RustySpoon_Description": "A plain old spoon, probably ten years old. Not very interesting. / 一个普通的旧汤匙，大概有 10 年之久了。没什么意思。",
        "PiratesLocket_Description": "It's an old pirate's keepsake. / 这是老海盗的纪念品。",
        "Daffodil_Name": "Daffodil / 黄水仙",
        "FriedEel_Name": "Fried Eel / 炒鳗鱼",
        "CherrySapling_Name": "Cherry Sapling / 樱桃树苗",
        "FrozenGeode_Description": "A blacksmith can break this open for you. / 你可以找铁匠破开这块晶球。",
        "GlowRing_Name": "Glow Ring / 光辉戒指",
        "SkeletalHand_Description": "It's a wonder all these ancient little pieces lasted so long. / 这些史前遗迹能够存在这么久真是个奇迹。",
        "SpecialCharm": "Special Charm / 特殊魅力",
        "CranberrySeeds_Description": "Plant these in the fall. Takes 7 days to mature, and continues to produce after first harvest. / 秋天播种。7 天成熟，收获之后还能继续结果。",
        "Cockle_Name": "Cockle / 鸟蛤",
        "WheatFlour_Description": "A common cooking ingredient made from crushed wheat seeds. / 碾碎麦粒后得到的普通食材。",
        "DiamondStone_Name": "Diamond Stone / Diamond Stone",
        "MsAngler_Description": "Uses a bioluminescent dangler to attract prey. / 它用发光的拟饵来吸引猎物。",
        "Book_Woodcutting_Description": "Felled trees have a 5% chance to yield double the wood. / 砍倒的树有 5% 的几率掉落双倍木头。",
        "GreenBean_Name": "Green Bean / 青豆",
        "MinersTreat_Description": "This should keep your energy up. / 让你持续充满能量。",
        "SteppingStonePath_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "Pumpkin_Description": "A fall favorite, grown for its crunchy seeds and delicately flavored flesh. As a bonus, the hollow shell can be carved into a festive decoration. / 秋天的农作物，因为它香脆的种子以及甜美的果肉而深受喜爱。而且，南瓜壳还能用做节日饰品。",
        "FireworksGreen_Name": "Fireworks (Green) / 烟花（绿色）",
        "SkeletalTail_Description": "It's pretty short for a tail. / 这尾巴还真短。",
        "Weeds_DryBush_Description": "A cluster of dry old bushes. Might contain fibers or mixed seeds. / 一簇干燥、老灌木丛。 Might contain fibers or mixed seeds.",
        "WrigglingWorm_Description": "It's a wriggling, wet worm. / 一条湿漉漉的，还在蠕动的蚯蚓。",
        "BokChoy_Name": "Bok Choy / 小白菜",
        "Raisins_Name": "Raisins / 葡萄干",
        "Helvite_Name": "Helvite / 日光榴石",
        "Jelly_Flavored_Name": "{0} Jelly / {0}果酱",
        "RiceShoot_Name": "Rice Shoot / 稻苗",
        "PrehistoricTool_Description": "Some kind of gnarly old digging tool. / 某种粗糙古老的挖掘工具。",
        "HyperSpeedGro_Name": "Hyper Speed-Gro / 顶级生长激素",
        "Anchor_Description": "It may have belonged to ancient pirates. / 它可能属于古代海盗。",
        "Slimejack_Name": "Slimejack / 史莱姆鱼",
        "OrangeSapling_Name": "Orange Sapling / 橙子树苗",
        "Shrimp_Description": "A scavenger that feeds off the ocean floor. Widely prized for its meat. / 在海洋地层觅食的清道夫。其肉广为人们喜爱。",
        "Lingcod_Name": "Lingcod / 蛇齿单线鱼",
        "RedCabbageSeeds_Description": "Plant these in the summer. Takes 9 days to mature. / 夏天播种。9 天成熟。",
        "Juice_Description": "A sweet, nutritious beverage. / 一种甜润，富含营养的饮料。",
        "VolcanoGoldNode_Description": "Break apart to obtain gold ore. / 凿开可以获得金矿石。",
        "MagicRockCandy_Name": "Magic Rock Candy / 魔法糖冰棍",
        "SkillBook2_Description": "Read this to gain some foraging experience. / 阅读即可获得采集经验。",
        "SlimeCrate_Description": "Use this to transport a domesticated slime to another location. / 可以用来将一只家养的史莱姆转移到其他地方。",
        "StoneWalkwayFloor_Description": "Place on the ground to create paths or to decorate your floors. / 放在地上修建小路，也可以装饰地板。",
        "DecorativePot_Name": "Decorative Pot / 装饰壶",
        "FossilStone_Description": "Break apart to obtain fossils and bones. / Break apart to obtain fossils and bones.",
        "Carrot_Name": "Carrot / 胡萝卜",
        "TulipBulb_Name": "Tulip Bulb / 郁金香球茎",
        "Pizza_Name": "Pizza / 披萨",
        "SkillBook0_Name": "Stardew Valley Almanac / 星露谷年历",
        "CrabshellRing_Description": "The top of the ring is made from enchanted crab shell. / 戒指的顶部是由附魔的蟹壳制成的。",
        "Rice_Description": "A basic grain often served under vegetables. / 基本的粮食，可以配菜食用。",
        "DriedFruit_CollectionsTabDescription": "Chewy pieces of dried fruit. / 有嚼劲的果干。",
        "Tuna_Description": "A large fish that lives in the ocean. / 一种住在海里的大型鱼。",
        "VoidEssence_Name": "Void Essence / 虚空精华",
        "SpecificBait_Flavored_Name": "{0} Bait / {0}鱼饵",
        "AncientSeed_Name": "Ancient Seed / 古代种子",
        "BlueSlimeEgg_Description": "Can be hatched in a slime incubator. / 可以在史莱姆孵化器中孵化。",
        "Pickles_Name": "Pickles / 腌菜",
        "PierresMissingStocklist_Name": "Pierre's Missing Stocklist / 皮埃尔丢失的存货单",
        "SeaUrchin_Description": "A slow-moving, spiny creature that some consider a delicacy. / 一种动作缓慢的带刺生物，一些人把它们当作佳肴。",
        "FairyDust_Description": "Sprinkle on kegs, furnaces, and other refining equipment to instantly receive their product. / 洒在小桶、熔炉和其他精炼设备上，可以立刻获得正在生产的产品。",
        "Basalt_Name": "Basalt / 玄武岩",
        "Jasper_Name": "Jasper / 碧玉",
        "DragonTooth_Description": "These are rumored to be the teeth of ancient serpents. The enamel is made of pure iridium! / 传言说这是古代巨蛇的牙。它的牙釉质是由纯铱构成的！",
        "Fiber_Description": "Raw material sourced from plants. / 源自植物的原生材料。",
        "FrozenGeode_Name": "Frozen Geode / 冰封晶球",
        "MagicRockCandy_Description": "A rare and powerful candy infused with the essence of the prismatic shard. / 稀有而强力的糖果，灌注了五彩碎片的精华。",
        "GrassBook_Description": "You will now run a lot faster through grass and crops. / 在草丛和庄稼中的移动速度大幅增加。",
        "RareDisc_Name": "Rare Disc / 稀有圆盘",
        "FruitSalad_Description": "A delicious combination of summer fruits. / 美味的夏季水果拼盘。",
        "OrnateNecklace_Description": "A fancy necklace found in the water outside of the bath house. It's still wet... / 在浴室外的水中找到的华丽项链。还是湿的……",
        "Bait_Name": "Bait / 鱼饵",
        "YamSeeds_Description": "Plant these in the fall. Takes 10 days to mature. / 秋天播种。10 天成熟。",
        "MelonSeeds_Name": "Melon Seeds / 甜瓜种子",
        "OstrichEgg_Name": "Ostrich Egg / 鸵鸟蛋",
        "AncientSword_Description": "It's the remains of an ancient sword. Most of the blade has turned to rust, but the hilt is very finely crafted. / 这是一把古剑的残骸。绝大部分刀刃都生锈了，但是剑柄很精致。",
        "Radish_Description": "A crisp and refreshing root vegetable with hints of pepper when eaten raw. / 新鲜清爽的块茎蔬菜，生吃的时候加一点胡椒。",
        "RhubarbSeeds_Name": "Rhubarb Seeds / 大黄种子",
        "Halibut_Description": "A flat fish that lives on the ocean floor. / 形状扁平、居住在大洋底的鱼。",
        "Book_WildSeeds_Name": "Raccoon Journal / 浣熊日记",
        "Pearl_Description": "A rare treasure from the sea. / 来自海洋的珍宝。",
        "GingerAle_Description": "A zesty soda known for its soothing effect on the stomach. / 一种好喝的苏打水，因为对胃有舒缓作用而为人们所知晓。",
        "OrnateNecklace_Name": "Ornate Necklace / 华丽的项链",
        "StardropTea_Description": "A very special gift that would delight anyone. / 非常特别的礼物，所有人都喜爱。",
        "Aerinite_Description": "These crystals are curiously light. / 这个晶石不可思议地轻。",
        "MapleBar_Description": "It's a sweet doughnut topped with a rich maple glaze. / 浇上枫糖的甜甜圈。",
        "BatteryPack_Name": "Battery Pack / 电池组",
        "Spaghetti_Description": "An old favorite. / 经典老菜。",
        "Clay_Description": "Used in crafting and construction. / 用于加工和建筑。",
        "EmeraldRing_Name": "Emerald Ring / 绿宝石戒指",
        "Pomegranate_Description": "Within the fruit are clusters of juicy seeds. / 果子里是满满的多汁种子。",
        "FireworksRed_Name": "Fireworks (Red) / 烟花（红色）",
        "MossSoup_Name": "Moss Soup / 苔藓汤",
        "SonarBobber_Name": "Sonar Bobber / 声纳浮漂",
        "PeachSapling_Name": "Peach Sapling / 桃子树苗",
        "Apricot_Name": "Apricot / 杏子",
        "SeaCucumber_Description": "A slippery, slimy creature found on the ocean floor. / 一种在海底能找到的黏滑生物。",
        "Salad_Description": "A healthy garden salad. / 健康的田园沙拉。",
        "Sprinkler_Name": "Sprinkler / 洒水器",
        "MangoSapling_Name": "Mango Sapling / 芒果幼苗",
        "PurpleMushroom_Description": "A rare mushroom found deep in caves. / 一种在山洞深处的稀有蘑菇。",
        "Jagoite_Description": "A high volume of tiny crystals makes it very glittery. / 含有大量的小水晶，让它闪闪发光。",
        "Alamite_Description": "Its distinctive fluorescence makes it a favorite among rock collectors. / 它与众不同的荧光使它成为许多岩石收集爱好者的最爱。",
        "CinderShard_Description": "You can feel a warm glow from within this stone. / 你可以从石头里感受到温度。",
        "SquidInkRavioli_Description": "Temporarily protects from debuffs. / 暂时免疫负面效果。",
        "BurglarsRing_Name": "Burglar's Ring / 窃贼戒指",
        "CraftingRecipe_FallSeeds": "Wild Seeds (Fa) / 野生种子（秋季）",
        "Broccoli_Description": "The flowering head of a broccoli plant. The tiny buds give it a unique texture. / 西蓝花的花球，微小的花蕾口感独特。",
        "RareSeed_Description": "Sow in fall. Takes all season to grow. / 秋天播种。需要一个季度生长。",
        "Roe_Description": "Fresh fish eggs. These can be aged in a preserves jar to bring out more flavor. / 新鲜的鱼卵。可以把它们在一个罐头瓶中腌制，从而产生特殊风味。",
        "WarpTotemQisArena_Description": "Warp to Qi's Arena. Be prepared for a challenge!. / 传送到齐先生的场地。做好准备迎接挑战！",
        "Cheese_Name": "Cheese / 奶酪",
        "LemonStone_Name": "Lemon Stone / 柠檬石",
        "SweetPea_Name": "Sweet Pea / 甜豌豆",
        "QiSeasoning_Description": "Just a dash will elevate any dish to extraordinary heights. Automatically applied when cooking. / 只要一点点，就能让任何食物变成珍馐美馔。在烹饪过程中自动添加。",
        "SuperMeal_Description": "It's a really energizing meal. / 真是充满能量的一餐。",
        "BrokenCD_Description": "It's a JojaNet 2.0 trial CD. They must've made a billion of these things. / 这是 JojaNet 2.0 试用版 CD。他们肯定制作了上亿张。",
        "IcePip_Name": "Ice Pip / 冰柱鱼",
        "Lobster_Name": "Lobster / 龙虾",
        "Raisins_Description": "It's said to be the Junimos' favorite food. / 据说是祝尼魔最喜欢的食物。",
        "CaveJelly_Description": "A rare jelly found in underground lakes. / 存在于地下湖泊里的罕见凝胶。",
        "VoidMayonnaise_Name": "Void Mayonnaise / 虚空蛋黄酱",
        "Lobster_Description": "A large ocean-dwelling crustacean with a strong tail. / 居住在海中、尾部强壮的大型甲壳纲动物。",
        "Opal_Description": "Its internal structure causes it to reflect a rainbow of light. / 它的内部结构导致它能够反射出彩虹的光辉。",
        "GoatCheese_Description": "Soft cheese made from goat's milk. / 用羊奶制成的柔软奶酪。",
        "Soapstone_Description": "Because of its relatively soft consistency, this stone is very popular for carving. / 因为它质地比较柔软，很适合用来雕刻。",
        "HopsStarter_Name": "Hops Starter / 啤酒花种子",
        "WarpTotemMountains_Name": "Warp Totem: Mountains / 传送图腾：山岭",
        "Emerald_Description": "A precious stone with a brilliant green color. / 一种亮绿色的珍贵宝石。",
        "TreasureChest_Description": "Wow, it's loaded with treasure! This is sure to fetch a good price. / 哇，里面塞满了财宝！肯定能卖个好价钱。",
        "ParsnipSeeds_Description": "Plant these in the spring. Takes 4 days to mature. / 春天播种。4 天成熟。",
        "Pike_Name": "Pike / 狗鱼",
        "BeanHotpot_Name": "Bean Hotpot / 豆类火锅",
        "CrystalFruit_Name": "Crystal Fruit / 水晶果",
        "Potato_Name": "Potato / 土豆",
        "Clay_Name": "Clay / 粘土",
        "GreenAlgae_Name": "Green Algae / 绿藻",
        "PinkCake_Name": "Pink Cake / 粉红蛋糕",
        "Acorn_Name": "Acorn / 橡子",
        "MossySeed_Description": "This can be planted to grow rare wild trees. / 可以种出稀有的野树。",
        "RainbowTrout_Description": "A freshwater trout with colorful markings. / 一种身上有彩虹带的淡水鳟鱼。",
        "SmallMagnetRing_Name": "Small Magnet Ring / 小型磁铁戒指",
        "SquidInk_Description": "Squid use this ink to confuse would-be predators. / 鱿鱼使用这种墨汁来迷惑掠食者。",
        "Sunfish_Name": "Sunfish / 太阳鱼",
        "AmaranthSeeds_Description": "Plant these in the fall. Takes 7 days to grow. Harvest with the scythe. / 秋天播种。7 天成熟。用镰刀收获。",
        "Dandelion_Description": "Not the prettiest flower, but the leaves make a good salad. / 虽然不算漂亮，但是叶子适合做沙拉。",
        "TreasureChest_Name": "Treasure Chest / 财宝箱",
        "Tigerseye_Name": "Tigerseye / 虎眼石",
        "MegaBomb_Name": "Mega Bomb / 超级炸弹",
        "LeadBobber_Description": "Adds weight to your \"fishing bar\", preventing it from bouncing along the bottom. / 为你的“钓鱼条”添加了重量，阻止它在触底的时候反弹。",
        "BrokenGlasses_Description": "It looks like someone lost their glasses. They're busted. / 看来是有人丢了眼镜。眼镜都碎了。",
        "FieldSnack_Name": "Field Snack / 工作小食",
        "GemStone_Description": "Break apart to obtain stone, ores, or geodes. / Break apart to obtain stone, ores, or geodes.",
        "Spaghetti_Name": "Spaghetti / 意大利面",
        "SummerSpangle_Name": "Summer Spangle / 夏季亮片",
        "Tortilla_Description": "Can be used as a vessel for food or eaten by itself. / 可以用来盛食物，也可以直接吃。",
        "Eggplant_Description": "A rich and wholesome relative of the tomato. Delicious fried or stewed. / 味道浓郁，营养丰富，是西红柿的近亲。炒着吃或者炖着吃味道都很不错。",
        "TopazStone_Name": "Topaz Stone / Topaz Stone",
        "Dandelion_Name": "Dandelion / 蒲公英",
        "LargeWhiteEgg_Name": "Large Egg / 大鸡蛋",
        "Glacierfish_Name": "Glacierfish / 冰川鱼",
        "Malachite_Name": "Malachite / 孔雀石",
        "Mead_Name": "Mead / 蜜蜂酒",
        "JournalScrap_Description": "A damp tattered page torn from an old journal... / 从一本旧日记上撕下的残页，破旧潮湿……",
        "CuriosityLure_Description": "Increases your chance to catch rare fish. / 提高你钓到珍稀鱼的几率。",
        "MidnightSquid_Description": "A strange and mysterious denizen of the ocean's twilight depths. / 海洋暮色深处陌生且神秘的居民。",
        "SquidInk_Name": "Squid Ink / 鱿鱼墨汁",
        "PrehistoricTibia_Description": "A thick and sturdy leg bone. / 又大又坚硬的腿骨。",
        "IronStone_Description": "Break apart to obtain iron ore. / Break apart to obtain iron ore.",
        "FossilizedTail_Description": "This tail has a club-like feature at the tip. / 这条尾巴的尖端像棍子。",
        "CopperBar_Description": "A bar of pure copper. / 一条纯铜锭。",
        "EggplantSeeds_Description": "Plant these in the fall. Takes 5 days to mature, and continues to produce after first harvest. / 秋天播种。5 天成熟，收获之后还能继续结果。",
        "GlassShards_Name": "Glass Shards / 玻璃碎片",
        "BlackberryCobbler_Description": "There's nothing quite like it. / 没有比这更好吃的了。",
        "SpecificBait_Description": "Increases your chance to catch {0}. / 增加钓到{0}的几率。",
        "SurvivalBurger_Name": "Survival Burger / 救生汉堡",
        "Beet_Name": "Beet / 甜菜",
        "CraftingRecipe_SummerSeeds": "Wild Seeds (Su) / 野生种子（夏季）",
        "PaleBroth_Description": "A delicate broth with a hint of sulfur. / 带有一点黄色的精致清汤。",
        "BrokenGlasses_Name": "Broken Glasses / 破损的眼镜",
        "Chowder_Description": "A perfect way to warm yourself after a cold night at sea. / 在寒冷的海边过夜后，用它来暖身再好不过了。",
        "CoffeeBean_Name": "Coffee Bean / 咖啡豆",
        "PrehistoricRib_Name": "Prehistoric Rib / 史前肋骨",
        "LargeBrownEgg_Name": "Large Egg / 大鸡蛋",
        "Rice_Name": "Rice / 大米",
        "Perch_Name": "Perch / 河鲈",
        "TopazStone_Description": "Break apart to obtain topaz. / Break apart to obtain topaz.",
        "Poi_Name": "Poi / 夏威夷芋泥",
        "ApricotSapling_Description": "Takes 28 days to produce a mature Apricot tree. Bears fruit in the spring. Only grows if the 8 surrounding \"tiles\" are empty. / 28 天成熟为成年杏子树。春天结果。只有在附近 8 块“地块”都空置的情况下才会成长。",
        "WarpTotemFarm_Description": "Warp directly to your house. Consumed on use. / 直接将你传送到农场。消耗品。",
        "MixedFlowerSeeds_Description": "An assortment of flower seeds. Plant them and see what grows! / 各类花的种子，种下去看看会长出什么！",
        "RedCabbageSeeds_Name": "Red Cabbage Seeds / 红叶卷心菜种子",
        "CactusSeeds_Name": "Cactus Seeds / 仙人掌种子",
        "Obsidian_Description": "A volcanic glass that forms when lava cools rapidly. / 一种火山岩，当岩浆极速冷却时就会形成。",
        "JazzSeeds_Description": "Plant in spring. Takes 7 days to produce a blue puffball flower. / 春天下种。7 天产出蓝色绒球花朵。",
        "SmokedFish_Flavored_Name": "Smoked {0} / 烟熏{0}",
        "GreenRainWeeds_Name": "Green Rain Weeds / 绿雨杂草",
        "Albacore_Description": "Prefers temperature \"edges\" where cool and warm water meet. / 喜欢温度的\"交界处\"，即指冷水与温水交界的地方。",
        "FrozenGeodeStone_Name": "Frozen Geode Stone / Frozen Geode Stone",
        "TaroTuber_Description": "Plant these in warm weather. Takes 10 days to mature. Grows faster if planted near a body of water. / 在温暖的天气里种下去。10 天成熟。种植在靠近水域的地方生长得更快。",
        "BasicRetainingSoil_Name": "Basic Retaining Soil / 初级保湿土壤",
        "PetLicense_Description": "Invite a new pet into your home. If you don't have enough outdoor pet bowls for your pets, they will become upset. / 邀请一只新宠物到你家。如果室外的宠物碗数量不够，宠物会不高兴。",
        "KaleSeeds_Description": "Plant these in the spring. Takes 6 days to mature. Harvest with the scythe. / 春天播种。6 天成熟。用镰刀收获。",
        "BeetSeeds_Description": "Plant these in the fall. Takes 6 days to mature. / 秋天播种。6 天成熟。",
        "CopperStone_Name": "Copper Stone / Copper Stone",
        "Slate_Description": "It's extremely resistant to water, making it a good roofing material. / 一种火山岩，当岩浆极速冷却时就会形成。",
        "SoulSapperRing_Name": "Soul Sapper Ring / 吸魂戒指",
        "Book_Friendship_Description": "You become friends with people a little faster. / 你与人增进友谊的速度变快了一点。",
        "TrimmedLuckyPurpleShorts_Description": "Purple silk shorts trimmed in luxurious gold... / 镶了金边的紫色丝织短裤……",
        "TigerSlimeEgg_Name": "Tiger Slime Egg / 老虎史莱姆蛋",
        "PlumPudding_Name": "Plum Pudding / 葡萄干布丁",
        "MixedSeeds_Name": "Mixed Seeds / 混合种子",
        "MysticSyrup_Description": "A very rare syrup that is said to have magic properties. / 非常罕见的糖浆，据说具有魔法属性。",
        "WarpTotemMountains_Description": "Warp directly to the mountains. Consumed on use. / 直接将你传送到山岭。消耗品。",
        "GoldStone_Description": "Break apart to obtain gold ore. / Break apart to obtain gold ore.",
        "SpiritTorch_Name": "Spirit Torch / 精灵火把",
        "CarpSurprise_Name": "Carp Surprise / 惊喜鲤鱼",
        "GoldenAnimalCracker_Name": "Golden Animal Cracker / 金色动物饼干",
        "RhubarbPie_Name": "Rhubarb Pie / 大黄派",
        "CheeseCauliflower_Name": "Cheese Cauliflower / 乳酪花椰菜",
        "GoldenWalnut_Name": "Golden Walnut / 金色核桃",
        "GhostCrystal_Name": "Ghost Crystal / 幽灵水晶",
        "Pineapple_Name": "Pineapple / 菠萝",
        "PotatoSeeds_Name": "Potato Seeds / 土豆种子",
        "FishTaco_Description": "It smells delicious. / 闻起来就很美味。",
        "Fluorapatite_Description": "Small amounts are found in human teeth. / 人类牙齿中含有少量的这种物质。",
        "CopperBar_Name": "Copper Bar / 铜锭",
        "Calcite_Description": "This yellow crystal is speckled with shimmering nodules. / 这个黄色的水晶上有星星点点的荧光突起。",
        "BerryBasket_Name": "Berry Basket / 浆果篮",
        "StarShards_Description": "No one knows how these form. Some scientists claim that the microscopic structure displays unnatural regularity. / 没有人知道它们拼起来是什么样子。有些科学家声称它们的分子架构不符合以往的自然规律。",
        "Catfish_Name": "Catfish / 鲶鱼",
        "Jagoite_Name": "Jagoite / 铁铅矿",
        "MapleSeed_Description": "This can be planted to grow a maple tree. / 可以种出一棵枫树。",
        "DriedFruit_Flavored_Name": "Dried {0} / {0}干",
        "UnmilledRice_Name": "Unmilled Rice / 未碾米",
        "DriedStarfish_Name": "Dried Starfish / 干海星",
        "SmokedFish_Description": "A whole {0}, smoked to perfection. / 一整条{0}，烟熏风味恰到好处。",
        "Salmonberry_Description": "A spring-time berry with the flavor of the forest. / 一种带有森林的味道的春天浆果。",
        "Cherry_Name": "Cherry / 樱桃",
        "Carrot_Description": "A fast-growing, colorful tuber that makes for a great snack. / 生长迅速、色彩鲜艳的块茎植物，可以当零食吃。",
        "MuscleRemedy_Name": "Muscle Remedy / 肌肉回复药",
        "MummifiedBat_Description": "The delicate wings have been perfectly preserved. / 精致的翅膀被完美地保存了下来。",
        "ChewingStick_Name": "Chewing Stick / 咀嚼洁齿棒",
        "CommonMushroom_Name": "Common Mushroom / 普通蘑菇",
        "Cloth_Description": "A bolt of fine wool cloth. / 一匹上好的羊毛布料。",
        "RedMullet_Description": "Long ago these were kept as pets. / 从前它们被当做宠物饲养。",
        "SavageRing_Name": "Savage Ring / 野蛮人戒指",
        "LargeMilk_Name": "Large Milk / 大壶牛奶",
        "MangoStickyRice_Description": "Sweet mango and coconut transforms this rice into something very special. / 甜芒果和椰子让糯米别具风味。",
        "GoldenBobber_Name": "Golden Bobber / 黄金浮漂",
        "LifeElixir_Name": "Life Elixir / 生命药水",
        "CuriosityLure_Name": "Curiosity Lure / 珍稀诱钩",
        "DinosaurMayonnaise_Name": "Dinosaur Mayonnaise / 恐龙蛋黄酱",
        "WildHorseradish_Description": "A spicy root found in the spring. / 春天生长的一种根茎香料。",
        "RubyStone_Name": "Ruby Stone / Ruby Stone",
        "MonsterMusk_Description": "Spray this on to draw more monsters out of hiding. / 喷上这个可以吸引更多的怪物出来。",
        "CornSeeds_Name": "Corn Seeds / 玉米种子",
        "Pyrite_Name": "Pyrite / 黄铁矿",
        "ExplosiveAmmo_Description": "Fire this with the slingshot. / 可以用弹弓进行发射。",
        "ScorpionCarp_Description": "It's like a regular carp but with a sharp stinger. / 它和普通的鲤鱼很像，但是它有锋利的毒刺。",
        "ChickenStatue_Name": "Chicken Statue / 鸡雕像",
        "PurpleBook_Description": "Read this to gain some experience in all skills. / 阅读即可获得所有技能的经验。",
        "Baryte_Description": "The best specimens resemble a desert rose. / 最好的重晶石看起来就像沙漠玫瑰。",
        "PinaColada_Name": "Piña Colada / 椰林飘香",
        "Trash_Description": "It's junk. / 这是垃圾。",
        "BlueberrySeeds_Description": "Plant these in the summer. Takes 13 days to mature, and continues to produce after first harvest. / 夏天播种。13 天成熟，收获之后还能继续结果。",
        "Snail_Description": "A wide-ranging mollusc that lives in a spiral shell. / 一种分布很广、居住在螺纹外壳中的软体生物。",
        "WinterSeeds_Name": "Winter Seeds / 冬季种子",
        "JadeStone_Description": "Break apart to obtain jade. / Break apart to obtain jade.",
        "Squid_Description": "A deep sea creature that can grow to enormous size. / 一种可以长得很大的深海生物。",
        "CoffeeBean_Description": "Plant in spring or summer to grow a coffee plant. Place five beans in a keg to make coffee. / 在春季和夏季种植。在小桶里放五颗咖啡豆可以制作咖啡。",
        "LuckyLunch_Description": "A special little meal. / 特别又简单的一餐。",
        "FossilizedLeg_Description": "A thick and sturdy leg bone. / 粗壮的腿骨。",
        "BakedFish_Name": "Baked Fish / 烤鱼",
        "Celestine_Name": "Celestine / 天青石",
        "StoneFence_Description": "Lasts longer than a wood fence. / 比木围栏更耐用。",
        "Jelly_Name": "Jelly / 果酱",
        "Bouquet_Name": "Bouquet / 花束",
        "Mango_Description": "A big, sweet tropical fruit with a unique flavor. / 大而甜的热带水果，有独特的味道。",
        "RadishSalad_Description": "The radishes are so crisp! / 萝卜真的太脆了！",
        "CopperStone_Description": "There's copper ore in this stone. / 这块石头里面有铜矿。",
        "PurpleSlimeEgg_Name": "Purple Slime Egg / 紫色史莱姆蛋",
        "PotatoSeeds_Description": "Plant these in the spring. Takes 6 days to mature, and has a chance of yielding multiple potatoes at harvest. / 春天播种。6 天成熟，有一定几率一次收获多个土豆。",
        "WoodFloor_Description": "Place on the ground to create paths or to decorate your floors. / 放在地上修建小路，也可以装饰地板。",
        "TreasureHunter_Name": "Treasure Hunter / 寻宝者",
        "PrehistoricTibia_Name": "Prehistoric Tibia / 史前胫骨",
        "FairyRose_Name": "Fairy Rose / 玫瑰仙子",
        "Strawberry_Name": "Strawberry / 草莓",
        "Fiber_Name": "Fiber / 纤维",
        "OakResin_Description": "A sticky, fragrant substance derived from oak sap. / 从橡树树液中提取的粘稠、芬芳的物质。",
        "TigerTrout_Name": "Tiger Trout / 虎纹鳟鱼",
        "Soapstone_Name": "Soapstone / 皂石",
        "BugSteak_Description": "The last resort of the hungry cave diver. / 洞穴探险家饥饿时最后的生存手段。",
        "Bait_Description": "Causes fish to bite faster. Must first be attached to a fishing rod. / 能让鱼更快上钩。要先挂在鱼杆上。",
        "Sunfish_Description": "A common river fish. / 一种常见的河鱼。",
        "Torch_Name": "Torch / 火把",
        "Tortilla_Name": "Tortilla / 墨西哥薄饼",
        "FriedEgg_Name": "Fried Egg / 煎鸡蛋",
        "DwarvishHelm_Description": "It's one of the helmets commonly worn by dwarves. The thick metal plating protects them from falling debris and stalactites. / 这是矮人常戴的头盔之一。厚厚的金属镀层能保护他们不受落石伤害。",
        "StrawFloor_Name": "Straw Floor / 稻草地板",
        "BroccoliSeeds_Description": "Plant in the fall. Takes 8 days to mature, and continues to produce after first harvest. / 秋天播种，8 天成熟，收获之后还能继续生长。",
        "AquamarineRing_Description": "Increases critical strike chance by 10%. / 增加 10% 的致命一击机会。",
        "RubyStone_Description": "Break apart to obtain rubies. / Break apart to obtain rubies.",
        "FairySeeds_Description": "Plant in fall. Takes 12 days to produce a mysterious flower. Assorted Colors. / 秋天下种。12 天产出神秘的花朵。多种颜色。",
        "Stingray_Description": "Despite having a toxic stinger, these fish are shy and prefer to avoid humans. / 虽然有毒刺，但这种鱼很害羞，喜欢避开人类。",
        "AncientSword_Name": "Ancient Sword / 古剑",
        "EnergyTonic_Description": "Restores a lot of energy. / 补充大量能量。",
        "Tuna_Name": "Tuna / 金枪鱼",
        "StrawberrySeeds_Description": "Plant these in spring. Takes 8 days to mature, and keeps producing strawberries after that. / 春天下种。8 天成熟，之后循环生产。",
        "Cookie_Name": "Cookies / 饼干",
        "MapleSyrup_Description": "A sweet syrup with a unique flavor. / 有着独特风味的甜浆。",
        "QiFruit_Description": "Mr. Qi has challenged you to ship 500 of these strange melons. / 齐先生要求你售出 500 个这种奇怪的瓜。",
        "Cauliflower_Description": "Valuable, but slow-growing. Despite its pale color, the florets are packed with nutrients. / 值钱，但是生长很慢。虽然它的颜色很浅，但是依然富含营养。",
        "Ectoplasm_Description": "A thick, slimy goop that the Wizard wants for some reason. / 厚实的粘液，法师不知道为何想要它。",
        "RubyRing_Description": "Increases attack by 10%. / 增加 10% 的攻击。",
        "MagmaCap_Name": "Magma Cap / 熔岩菇",
        "LuckyPurpleShorts_Name": "Lucky Purple Shorts / 幸运紫色短裤",
        "TeaSet_Name": "Tea Set / 茶具",
        "BeanHotpot_Description": "It sure is healthy. / 这绝对很健康。",
        "CombinedRing_Name": "Combined Ring / 组合戒指",
        "FishStew_Description": "It smells a lot like the sea. Tastes better, though. / 大海的味道扑面而来。不过尝起来更好。",
        "Stone_Description": "A common material with many uses in crafting and building. / 一种常见的材料，在加工和建筑中有很广泛的用途。",
        "Kale_Description": "The waxy leaves are great in soups and stir fries. / 拿这些柔软的叶子蔬菜什锦盖饭或者做汤，味道好极了！",
        "Poppy_Name": "Poppy / 虞美人花",
        "TopazRing_Name": "Topaz Ring / 黄水晶戒指",
        "Mussel_Description": "A common bivalve that often lives in clusters. / 结群生活的双壳类生物。",
        "CherryBomb_Name": "Cherry Bomb / 樱桃炸弹",
        "PineCone_Description": "This can be planted to grow a pine tree. / 可以种出一棵松树。",
        "TentKit_Description": "Use this to deploy a one-time-use tent for sleeping. Can only be used outdoors. / 可以放置一顶一次性帐篷用来睡觉，只能在户外使用。",
        "Hematite_Description": "An iron-based Mineral with interesting magnetic properties. / 一种主要成分为铁的矿石，带有一些特别的磁性。",
        "Bomb_Name": "Bomb / 炸弹",
        "MagmaGeode_Description": "A blacksmith can break this open for you. / 你可以找铁匠破开这块晶球。",
        "Honey_Wild_Name": "Wild Honey / 野蜂蜜",
        "PumpkinSeeds_Description": "Plant these in the fall. Takes 13 days to mature. / 秋天播种。13 天成熟。",
        "Peach_Description": "It's almost fuzzy to the touch. / 毛绒绒的感觉。",
        "DishOTheSea_Description": "This'll keep you warm in the cold sea air. / 让你在海上的寒风中保持温暖。",
        "QualitySprinkler_Description": "Waters the 8 adjacent tiles every morning. / 每天早晨灌溉临近的 8 个地块。",
        "Pearl_Name": "Pearl / 珍珠",
        "GoatMilk_Description": "The milk of a goat. / 羊的奶。",
        "MakiRoll_Description": "Fish and rice wrapped in seaweed. / 紫菜裹着的鱼和米饭。",
        "SoulSapperRing_Description": "Gain a little bit of energy every time you slay a monster. / 每次杀死一个怪物，都会获得一点能量。",
        "Tulip_Name": "Tulip / 郁金香",
        "WarpTotemBeach_Description": "Warp directly to the beach. Consumed on use. / 直接将你传送到海滩。消耗品。",
        "HotJavaRing_Description": "Greatly increases your chance to find coffee drinks when slaying monsters. / 大幅增加狩猎怪物时找到咖啡饮料的概率。",
        "ChocolateCake_Name": "Chocolate Cake / 巧克力蛋糕",
        "CampingStove_Name": "Camping Stove / 野营灶",
        "SmokedFish_CollectionsTabName": "Smoked Fish / 熏鱼",
        "DriedMushrooms_Description": "A package of gourmet mushrooms. / 一包美味蘑菇。",
        "GravelPath_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "Granite_Name": "Granite / 花岗岩",
        "MysteryBox_Name": "Mystery Box / 谜之盒",
        "GoldBar_Description": "A bar of pure gold. / 一条纯金锭。",
        "GrapeStarter_Description": "Plant these in the fall. Takes 10 days to grow, but keeps producing after that. Grows on a trellis. / 秋天播种。10 天成熟，之后循环生产。在架子上生长。",
        "Pike_Description": "A freshwater fish that's difficult to catch. / 一种很难捕捉的淡水鱼。",
        "MagmaGeodeStone_Name": "Magma Geode Stone / Magma Geode Stone",
        "Orpiment_Description": "Despite its high toxicity, this Mineral is widely used in manufacturing and folk medicine. / 尽管它毒性很强，它还是有广泛的加工以及制药用途。",
        "FallSeeds_Description": "An assortment of wild fall seeds. / 各种各样的秋季种子。",
        "HotPepper_Description": "Fiery hot with a hint of sweetness. / 超级辣，稍甜。",
        "SquidInkRavioli_Name": "Squid Ink Ravioli / 墨汁意大利饺",
        "WarriorRing_Name": "Warrior Ring / 战士戒指",
        "BlueDiscus_Name": "Blue Discus / 蓝铁饼鱼",
        "DishOTheSea_Name": "Dish O' The Sea / 海之菜肴",
        "Omelet_Description": "It's super fluffy. / 它超级松软。",
        "CorkBobber_Name": "Cork Bobber / 软木塞浮标",
        "BugMeat_Name": "Bug Meat / 虫肉",
        "TrapBobber_Description": "Causes fish to escape slower when you aren't reeling them in. / 让你没在拉钩的时候，鱼会逃跑的慢一些。",
        "AmethystStone_Name": "Amethyst Stone / Amethyst Stone",
        "FossilizedTail_Name": "Fossilized Tail / 尾巴化石",
        "AmphibianFossil_Description": "The relatively short hind legs suggest some kind of primordial toad. / 比较短的后腿说明它们是某种原始的蟾蜍。",
        "MusselStone_Description": "There's mussels in this stone. / 这石头里面有贻贝。",
        "Kyanite_Name": "Kyanite / 蓝晶石",
        "Oil_Name": "Oil / 油",
        "MossSoup_Description": "It's thick and slimy, but edible. / 浓稠而且黏糊糊，勉强能喝。",
        "Crayfish_Name": "Crayfish / 小龙虾",
        "BoneFlute_Name": "Bone Flute / 骨笛",
        "Woodskip_Name": "Woodskip / 木跃鱼",
        "HaleysLostBracelet_Name": "Haley's Lost Bracelet / Haley's Lost Bracelet",
        "SpookFish_Description": "The huge eyes can detect the faint silhouettes of prey. / 巨大的眼睛可以检测到猎物微弱的侧影。",
        "Book_PriceCatalogue_Description": "You can now see the value of your items. / 你可以看到物品的价值了。",
        "RedSnapper_Description": "A popular fish with a nice red color. / 一种身上是漂亮红色的受欢迎鱼类。",
        "TopazRing_Description": "You feel a little bit safer wearing this. / 戴着这个会感觉安全一点点。",
        "ImmunityBand_Name": "Immunity Band / 免疫指环",
        "Amaranth_Name": "Amaranth / 苋菜",
        "IridiumBar_Description": "A bar of pure iridium. / 一条纯铱锭。",
        "Squid_Name": "Squid / 鱿鱼",
        "MonsterMusk_Name": "Monster Musk / 怪兽香水",
        "GoldenBobber_Description": "Willy is looking for this. / 威利在寻找它。",
        "Salmonberry_Name": "Salmonberry / 美洲大树莓",
        "FairyStone_Description": "An old miner's song suggests these are made from the bones of ancient fairies. / 古老的矿工歌谣里说，这些石头是古代精灵的骨头做的。",
        "Ghostfish_Name": "Ghostfish / 鬼鱼",
        "Flounder_Description": "It lives on the bottom, so both eyes are on top of its head. / 它生活在底部，所以两只眼睛都在它的头顶上。",
        "Wine_Description": "Drink in moderation. / 请适度饮酒。",
        "BearPaw": "Bear's Knowledge / 熊的知识",
        "FurnitureCatalogueDescription": "Provides unlimited access to almost every furniture item... from the convenience of your home! / 让你不出门就能买到各种各样的家具！",
        "PalmFossil_Description": "Palm Fossils are relatively common, but this happens to be a particularly well-preserved specimen. / 棕榈化石比较常见，但这一个恰好是比较完整的。",
        "MidnightCarp_Description": "This shy fish only feels comfortable at night. / 这种害羞的鱼只在晚上感到舒适。",
        "Marble_Description": "A very popular material for sculptures and construction. / 一种非常受欢迎的雕塑和建筑原料。",
        "ArcticShard_Name": "Arctic Shard / 极寒碎片",
        "LuckyRing_Name": "Lucky Ring / 幸运戒指",
        "Perch_Description": "A freshwater fish of the winter. / 一种冬季淡水鱼。",
        "Stone_Node_Name": "Stone / 石头",
        "Eggplant_Name": "Eggplant / 茄子",
        "QualityBobber_Name": "Quality Bobber / 优质浮标",
        "SpicyEel_Name": "Spicy Eel / 香辣鳗鱼",
        "Flounder_Name": "Flounder / 比目鱼",
        "StrangeBun_Description": "What's inside? / 里面放了什么？",
        "MangoSapling_Description": "Takes 28 days to produce a mature Mango tree. Bears fruit in the summer, or all year round when planted on Ginger Island. / 28 天成熟为芒果树。夏季结果实；种在姜岛上，一年四季都会结果实。",
        "NautilusShell_Name": "Nautilus Shell / 鹦鹉螺",
        "DwarvishHelm_Name": "Dwarvish Helm / 矮人头盔",
        "Crayfish_Description": "A small freshwater relative of the lobster. / 龙虾的小型淡水亲属。",
        "FireworksGreen_Description": "An old tradition for celebrations and festivities. Handle with care! / 一种庆祝节日和活动的传统习俗。小心燃放！",
        "LegendII_Name": "Legend II / 传说之鱼二代",
        "GoldOre_Name": "Gold Ore / 黄金矿石",
        "WiltedBouquet_Name": "Wilted Bouquet / 枯萎的花束",
        "TaroTuber_Name": "Taro Tuber / 芋头块茎",
        "ProtectionRing_Name": "Protection Ring / 保护戒指",
        "AncientSeed_Description": "It's a dry old seed from some ancient plant. By all appearances it's long since dead... / 某个古代植物的干老种子。它显然早就死了……",
        "Book_Defense_Name": "Jack Be Nimble, Jack Be Thick / 铜墙铁壁",
        "RadioactiveStone_Name": "Radioactive Stone / Radioactive Stone",
        "DwarfScrollIV_Name": "Dwarf Scroll IV / 矮人卷轴 IV",
        "SpringOnion_Name": "Spring Onion / 大葱",
        "MapleSyrup_Name": "Maple Syrup / 枫糖浆",
        "SmokedFish_Name": "Smoked / Smoked",
        "CrystalPath_Name": "Crystal Path / 水晶小径",
        "ChocolateCake_Description": "Rich and moist with a thick fudge icing. / 香甜柔软，还有厚厚的软糖糖衣。",
        "RootsPlatter_Name": "Roots Platter / 块茎拼盘",
        "Leek_Name": "Leek / 韭葱",
        "RusticPlankFloor_Name": "Rustic Plank Floor / 乡村木地板",
        "Carp_Name": "Carp / 鲤鱼",
        "Wood_Name": "Wood / 木材",
        "Book_Void_Name": "Monster Compendium / 怪物图鉴",
        "RiceShoot_Description": "Plant these in the spring. Takes 8 days to mature. Grows faster if planted near a body of water. Harvest with the scythe. / 春天下种。8 天成熟。如果种植在水体附近，生长会更快。用镰刀收获。",
        "SkeletalHand_Name": "Skeletal Hand / 手部骨骼",
        "RustySpur_Description": "An old spur that was once attached to a cowboy's boot. People must have been raising animals in this area for many generations. / 曾经连在某个牛仔靴子上的旧靴刺。肯定已经有好几代的人在此饲养动物了。",
        "TomatoSeeds_Name": "Tomato Seeds / 西红柿种子",
        "FairyDust_Name": "Fairy Dust / 仙尘",
        "FossilizedLeg_Name": "Fossilized Leg / 腿骨化石",
        "Holly_Description": "The leaves and bright red berries make a popular winter decoration. / 它的叶子和鲜红的浆果让它成为了极受欢迎的冬天饰品。",
        "IceCream_Name": "Ice Cream / 冰淇淋",
        "WarpTotemDesert_Name": "Warp Totem: Desert / 传送图腾：沙漠",
        "CactusSeedsOutside": "Must be planted indoors or on Ginger Island. / 必须种在室内或者姜岛上。",
        "Periwinkle_Description": "A tiny freshwater snail that lives in a blue shell. / 一种居住在蓝色贝壳里的小型淡水蜗牛。",
        "RubyRing_Name": "Ruby Ring / 红宝石戒指",
        "Bomb_Description": "Generates an explosion. Watch out! / 会发生爆炸。小心了！",
        "LargeWhiteEgg_Description": "It's an uncommonly large white egg! / 这是个非常大的白色鸡蛋！",
        "CraftingRecipe_GoldBar": "Transmute (Au) / 金锭",
        "ElvishJewelry_Description": "Dirty but still beautiful. On the side is a flowing script thought by some to be the ancient language of the elves. No Elvish bones have ever been found. / 很脏但是依然美丽。上边有被认为是古代精灵语的流畅字迹。但还没有人见过精灵的遗骸。",
        "TreasureHunter_Description": "Fish don't escape while collecting treasures. Also slightly increases the chance to find treasures. / 在收集宝藏的时候鱼是不会逃走的。并且它能够稍微增加找到宝藏的几率。",
        "Quartz_Name": "Quartz / 石英",
        "IridiumStone_Name": "Iridium Stone / Iridium Stone",
        "Geminite_Description": "Occurs in brilliant clusters. / 出现时总是大量聚集在一起。",
        "PoppyseedMuffin_Description": "It has a soothing effect. / 有种镇定的效果。",
        "Chanterelle_Name": "Chanterelle / 鸡油菌",
        "Banana_Name": "Banana / 香蕉",
        "PlumPudding_Description": "A traditional holiday treat. / 传统的节日小吃。",
        "StirFry_Name": "Stir Fry / 蔬菜什锦盖饭",
        "ButterflyPowder_Description": "Sprinkle on a pet to remove them from your farm. The process is irreversible. / 撒在宠物身上即可将它驱逐出农场，驱逐后无法复原。",
        "CrystalFruit_Description": "A delicate fruit that pops up from the snow. / 一种在冬天出现的美味水果。",
        "ApricotSapling_Name": "Apricot Sapling / 杏子树苗",
        "Bouquet_Description": "A gift that shows your romantic interest. / 一件能够充分展示你浪漫情怀的礼物。",
        "Crimsonfish_Description": "Lives deep in the ocean but likes to lay its eggs in the warm summer water. / 它住在深海里但是喜欢在温暖的夏天产卵。",
        "Juice_Flavored_Name": "{0} Juice / {0}果汁",
        "ConcernedApeMask_Name": "??? / ???",
        "Corn_Description": "One of the most popular grains. The sweet, fresh cobs are a summer favorite. / 最常见的庄稼之一。甜甜的新鲜玉米棒是夏天最好的小吃。",
        "TruffleOil_Name": "Truffle Oil / 松露油",
        "DwarfScrollIII_Description": "A yellowed scroll of parchment filled with dwarven script. This one's tied with a blue rope. / 一个写满矮人语的黄色羊皮卷轴。这一个上面系着蓝色绳子。",
        "CrystalPath_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "Garlic_Description": "Adds a wonderful zestiness to dishes. High quality garlic can be pretty spicy. / 给菜肴增加一些风味。质量好的大蒜可能会特别辣。",
        "TreasureTotem_Description": "Use on diggable terrain to summon a ring of treasure spots. / 在可挖掘的地形上使用即可召唤一圈宝藏挖掘点。",
        "GarlicSeeds_Description": "Plant these in the spring. Takes 4 days to mature. / 春天播种。4 天成熟。",
        "BlueGrassStarter_Description": "Place this on your farm to plant a clump of blue grass. / 播撒在农场上即可种出蓝色草丛。",
        "SecretNote_Name": "Secret Note / 秘密纸条",
        "FrozenTear_Description": "A crystal fabled to be the frozen tears of a yeti. / 传说是由雪怪眼泪结成的晶体。",
        "Poppy_Description": "In addition to its colorful flower, the Poppy has culinary and medicinal uses. / 虞美人花颜色鲜艳，有药用价值。",
        "EarthCrystal_Name": "Earth Crystal / 地晶",
        "AquamarineStone_Name": "Aquamarine Stone / Aquamarine Stone",
        "FishTaco_Name": "Fish Taco / 鱼肉卷",
        "Roe_Flavored_Name": "{0} Roe / {0}鱼籽",
        "ConcernedApeMask_Description": "??? / ???",
        "PhoenixRing_Name": "Phoenix Ring / 凤凰戒指",
        "GrapeStarter_Name": "Grape Starter / 葡萄种子",
        "Neptunite_Description": "A jet-black crystal that is unusually reflective. / 一种黝黑的晶石，反光性一般都比较好。",
        "CactusSeeds_Description": "Can only be grown indoors. Takes 12 days to mature, and then produces fruit every 3 days. / 只能在室内种植。需要 12 天才能成熟，然后每 3 天结一次果。",
        "BlueGrassStarter_Name": "Blue Grass Starter / 蓝色草籽",
        "CaveCarrot_Name": "Cave Carrot / 山洞萝卜",
        "Aquamarine_Name": "Aquamarine / 海蓝宝石",
        "PurpleSlimeEgg_Description": "Can be hatched in a slime incubator. / 可以在史莱姆孵化器中孵化。",
        "CranberryCandy_Description": "It's sweet enough to mask the bitter fruit. / 其中的甜味足以掩盖水果的苦味。",
        "Bread_Description": "A crusty baguette. / 硬皮法式面包。",
        "MagicInkDescription": "You've found the Wizard's lost {0}! Better return it to him. / 你找到了法师丢失的{0}！最好把它还给法师。",
        "PrizeTicket_Description": "Bring this to the prize machine in Lewis' house for a special reward. / 在刘易斯家的兑奖机领取特殊奖励。",
        "CinderShardStone_Name": "Cinder Shard Stone / Cinder Shard Stone",
        "LargemouthBass_Name": "Largemouth Bass / 大嘴鲈鱼",
        "Machine_NeedsInputCount": "Requires {0} pieces. / 需要 {0} 个。",
        "Sturgeon_Name": "Sturgeon / 鲟鱼",
        "MidnightCarp_Name": "Midnight Carp / 午夜鲤鱼",
        "Artichoke_Name": "Artichoke / 洋蓟",
        "Apricot_Description": "A tender little fruit with a rock-hard pit. / 一种柔嫩的水果，但是果核硬如石头。",
        "FireOpal_Description": "A rare variety of opal, named for its red spots. / 一种非常罕见的猫眼石，它得名于它上面的红色斑点。",
        "Calcite_Name": "Calcite / 方解石",
        "SkillBook1_Description": "Read this to gain some fishing experience. / 阅读即可获得钓鱼经验。",
        "BasicFertilizer_Name": "Basic Fertilizer / 初级肥料",
        "Salmon_Description": "Swims upstream to lay its eggs. / 它会游到上游产卵。",
        "WarpTotemDesert_Description": "Warp directly to Calico Desert. Consumed on use. / 直接将你传送到卡利科沙漠。消耗品。",
        "GeodeStone_Name": "Geode Stone / Geode Stone",
        "SunflowerSeeds_Description": "Plant in summer or fall. Takes 8 days to produce a large sunflower. Yields more seeds at harvest. / 夏天或秋天播种。8 天产出巨大向日葵。收割时产出更多种子。",
        "Caviar_Name": "Caviar / 鱼籽酱",
        "Hematite_Name": "Hematite / 赤铁矿",
        "MummifiedFrog_Description": "This ancient frog may have lived in the jungle canopy. / 这只古老的青蛙可能生活在丛林的树冠里。",
        "Magnet_Name": "Magnet / 磁铁",
        "GlazedYams_Description": "Sweet and satisfying... The sugar gives it a hint of caramel. / 又香又甜……加糖让它有了一点焦糖味。",
        "Topaz_Name": "Topaz / 黄水晶",
        "ImmunityBand_Description": "The top of the ring is made from enchanted purple wool. / 戒指的顶部是由附魔的紫色毛绒制成的。",
        "CaveJelly_Name": "Cave Jelly / 洞穴凝胶",
        "Grape_Name": "Grape / 葡萄",
        "RottenPlant_Name": "Rotten Plant / 腐烂的植物",
        "Book_Speed2_Name": "Way Of The Wind pt. 2 / 风之道 第二部分",
        "PumpkinPie_Name": "Pumpkin Pie / 南瓜派",
        "GlowRing_Description": "Emits a constant light. / 发出非常绚丽的光芒。",
        "HopsStarter_Description": "Plant these in the summer. Takes 11 days to grow, but keeps producing after that. Grows on a trellis. / 夏天播种。11 天成熟，之后循环生产。在架子上生长。",
        "Limestone_Description": "A very common type of stone. It's not worth very much. / 非常常见的一种石头。价值不高。",
        "NautilusFossil_Description": "This must've washed up ages ago from an ancient coral reef.  / 这肯定是在亿万年前从一个古老的珊瑚礁上被冲上岸的。",
        "PaleAle_Description": "Drink in moderation. / 请适度饮酒。",
        "Dolomite_Name": "Dolomite / 白云石",
        "Cheese_Description": "It's your basic cheese. / 你的普通的奶酪。",
        "YamSeeds_Name": "Yam Seeds / 山药种子",
        "SturdyRing_Description": "Cuts the duration of negative status effects in half. / 减少负状态影响持续时间的一半。",
        "EggplantSeeds_Name": "Eggplant Seeds / 茄子种子",
        "SecretNote_Description": "It's old and crumpled, but if you look closely you can make out the details... / 虽然古老且皱皱巴巴，但是如果你仔细观察，你方能弄清细节……",
        "Dorado_Description": "A fierce carnivore with brilliant orange scales. / 凶猛的肉食鱼，有着绚烂的橙色鳞片。",
        "SummerSquashSeeds_Name": "Summer Squash Seeds / 金皮西葫芦种子",
        "ScorpionCarp_Name": "Scorpion Carp / 蝎鲤鱼",
        "Sandfish_Name": "Sandfish / 沙鱼",
        "Honey_Description": "It's a sweet syrup produced by bees. / 蜜蜂们产出的甜汁。",
        "MagnifyingGlassDescription": "You received the {0}! You now have the ability to find 'Secret Notes'. These notes reveal rare and useful information, and can be reviewed in your collections tab. / 你收到了{0}！你现在有能力找到“秘密纸条”。这些纸条揭示了珍贵且实用的信息，可在你的收藏选项卡中查看。",
        "FireQuartz_Description": "A glowing red crystal commonly found near hot lava. / 一种常见于熔岩附近的火红色晶体。",
        "BoneFragment_Description": "A small piece of bone. / 一小块骨头。",
        "RedPlate_Name": "Red Plate / 红之盛宴",
        "VolcanoGoldNode_Name": "Gold Stone / 金矿原石",
        "OmniGeode_Description": "A blacksmith can break this open for you. These geodes contain a wide variety of minerals. / 铁匠能帮你把它敲开。这种晶球包含了多种多样的矿物。",
        "RadioactiveCarp_Description": "A carp that spent one too many years in toxic sludge. / 在有毒淤泥里待了很多年的鲤鱼。",
        "SpookFish_Name": "Spook Fish / 幽灵鱼",
        "MysticTreeSeed_Name": "Mystic Tree Seed / 神秘树种",
        "AncientFruit_Name": "Ancient Fruit / 上古水果",
        "WarpTotemQisArena_Name": "Warp Totem: Qi's Arena / 传送图腾：齐先生的场地",
        "ArtifactSpot_Description": "How did you get this in your inventory? / 呃……你是怎么弄到这个的？猿猴撞伤了。",
        "RadishSeeds_Description": "Plant these in the summer. Takes 6 days to mature. / 夏天播种。6 天成熟。",
        "FairyRose_Description": "An old folk legend suggests that the sweet smell of this flower attracts fairies. / 传言这种花朵的香味会吸引小仙女而来。",
        "BokChoy_Description": "The leafy greens and fibrous stalks are healthy and delicious. / 绿绿的菜叶丰满的根茎，健康又美味。",
        "Marble_Name": "Marble / 大理石",
        "Banana_Description": "A sweet, starchy tropical fruit. / 一种甜的热带水果，富含淀粉。",
        "JukeboxRing_Name": "Jukebox Ring / 点唱机戒指",
        "WheatFlour_Name": "Wheat Flour / 大麦粉",
        "Lunarite_Name": "Lunarite / 酸性月岩",
        "Mead_Description": "A fermented beverage made from honey. Drink in moderation. / 蜂蜜制成的发酵饮料。适度饮用。",
        "SnowyStone_Name": "Snowy Stone / Snowy Stone",
        "GoldCoin_Description": "1 Gold coin. / 1 枚金币。",
        "Yam_Name": "Yam / 山药",
        "CraftingRecipe_SpringSeeds": "Wild Seeds (Sp) / 野生种子（春季）",
        "ShrimpCocktail_Description": "A sumptuous appetizer made with freshly-caught shrimp. / 用新鲜捕获的虾制成的豪华开胃菜。",
        "StirFry_Description": "Julienned vegetables on a bed of rice. / 放在大米上的蔬菜条。",
        "ParsnipSeedPackage_SomeoneElse": "This package belongs to someone else. / 这个包裹属于其他人。",
        "BeetSeeds_Name": "Beet Seeds / 甜菜种子",
        "PrismaticJelly_Description": "Harvested from the rare and elusive prismatic slime. / 稀有且容易逃跑的五彩史莱姆会掉落。",
        "CrabCakes_Description": "Crab, bread crumbs, and egg formed into patties then fried to a golden brown. / 蟹肉、面包屑和鸡蛋做成饼状，然后油炸至金棕色。",
        "CrabCakes_Name": "Crab Cakes / 蟹黄糕",
        "Pineapple_Description": "A sweet and tangy tropical treat. / 热带美食，甜香扑鼻。",
        "SummerSeeds_Description": "An assortment of wild summer seeds. / 各种各样的夏季种子。",
        "SpangleSeeds_Description": "Plant in summer. Takes 8 days to produce a vibrant tropical flower. Assorted colors. / 夏天下种。8 天产出夺目的热带花朵。多种颜色。",
        "Walleye_Description": "A freshwater fish caught at night. / 一种在夜间捕捉的淡水鱼。",
        "PhoenixRing_Description": "Once a day, regain some health after being knocked out in combat. / 在战斗中被击倒后恢复些许生命值，一天仅限一次。",
        "CherryBomb_Description": "Generates a small explosion. Stand back! / 会发生小爆炸。靠后站！",
        "PrizeTicket_Name": "Prize Ticket / 兑奖券",
        "Crab_Name": "Crab / 螃蟹",
        "SpiceBerry_Name": "Spice Berry / 香味浆果",
        "IridiumMilk_Description": "A powerful 'milk' of unknown origin... / 来源不明的强大“奶汁”……",
        "PomegranateSapling_Description": "Takes 28 days to produce a mature Pomegranate tree. Bears fruit in the fall. Only grows if the 8 surrounding \"tiles\" are empty. / 28 天成熟为成年石榴树。秋天结果。只有在附近 8 块“地块”都空置的情况下才会成长。",
        "WhiteEgg_Description": "A regular white chicken egg. / 一个普通的白色鸡蛋。",
        "Rhubarb_Name": "Rhubarb / 大黄",
        "FossilizedRibs_Description": "Long ago, these ribs protected the body of a large animal. / 很久以前，这些肋骨保护着一个大型动物的身体。",
        "Crab_Description": "A marine crustacean with two powerful pincers. / 长着两个强壮螯的海生甲壳纲生物。",
        "TomKhaSoup_Description": "These flavors are incredible! / 这味道好极了！",
        "FrozenGeodeStone_Description": "Break apart to obtain frozen geodes. / Break apart to obtain frozen geodes.",
        "IronBar_Name": "Iron Bar / 铁锭",
        "TroutSoup_Name": "Trout Soup / 鳟鱼汤",
        "Book_AnimalCatalogue_Description": "You can access Marnie's shop when she's not around. / 玛妮不在的时候也可以进入她的商店。",
        "Mayonnaise_Name": "Mayonnaise / 蛋黄酱",
        "SturdyRing_Name": "Sturdy Ring / 结实戒指",
        "RainTotem_Description": "Activate to greatly increase the chance for rain tomorrow. Consumed on use. / 激活后，大大增加明天下雨的概率。消耗品。",
        "Blackberry_Description": "An early-fall treat. / 早秋的食物。",
        "MidnightSquid_Name": "Midnight Squid / 午夜鱿鱼",
        "Salad_Name": "Salad / 沙拉",
        "RicePudding_Description": "It's creamy, sweet, and fun to eat. / 有浓郁的奶油，又甜，并且吃起来也很有意思。",
        "Kyanite_Description": "The geometric faces are as smooth as glass. / 几何面如同玻璃般光滑。",
        "IcePip_Description": "A rare fish that thrives in extremely cold conditions. / 一种在极寒条件下生长的稀有鱼类。",
        "AlgaeSoup_Name": "Algae Soup / 海藻汤",
        "StoneFloor_Name": "Stone Floor / 石头地板",
        "BrickFloor_Name": "Brick Floor / 红砖地板",
        "FarmersLunch_Description": "This'll keep you going. / 保证你能够继续工作。",
        "IceCrystal_Name": "Ice Crystal / Ice Crystal",
        "ParsnipSeeds_Name": "Parsnip Seeds / 防风草种子",
        "GreenSlimeEgg_Name": "Green Slime Egg / 绿色史莱姆蛋",
        "PumpkinSoup_Name": "Pumpkin Soup / 南瓜汤",
        "CampingStove_Description": "This allows you to cook anywhere, and is not consumed on use. / 让你可以随处烹饪，可多次使用。",
        "Hops_Description": "A bitter, tangy flower used to flavor beer. / 带苦味刺鼻的花朵，用于酿酒。",
        "WildHorseradish_Name": "Wild Horseradish / 野山葵",
        "FiddleheadFern_Name": "Fiddlehead Fern / 蕨菜",
        "Eel_Name": "Eel / 鳗鱼",
        "Slate_Name": "Slate / 板岩",
        "MysticTreeSeed_Description": "This can be planted to grow a special tree. / 可以种出特别的树。",
        "MusselStone_Name": "Mussel Stone / Mussel Stone",
        "PetrifiedSlime_Name": "Petrified Slime / 石化史莱姆",
        "Angler_Name": "Angler / 鮟鱇鱼",
        "Gate_Name": "Gate / 大门",
        "DuckMayonnaise_Name": "Duck Mayonnaise / 鸭蛋黄酱",
        "SuperCucumber_Description": "A rare, purple variety of sea cucumber. / 一种稀有紫色品种的海参。",
        "TigerSlimeEgg_Description": "Can be hatched in a slime incubator. Use with extreme caution! / 可以在史莱姆孵化器中孵化。使用时请额外小心！",
        "CatalogueDescription": "Provides unlimited access to all wallpapers and floors... from the convenience of your home! / 让你不出门就能买到各种各样的墙纸和地板！",
        "FireworksPurple_Name": "Fireworks (Purple) / 烟花（紫色）",
        "GreenTea_Name": "Green Tea / 绿茶",
        "DriedMushrooms_CollectionsTabDescription": "A package of gourmet mushrooms. / 一包美味蘑菇。",
        "PomegranateSapling_Name": "Pomegranate Sapling / 石榴树苗",
        "SpangleSeeds_Name": "Spangle Seeds / 夏季亮片种子",
        "CrystalFloor_Description": "Place on the ground to create paths or to spruce up your floors. / 放在地上修建小路，也可以装饰地板。",
        "Blobfish_Name": "Blobfish / 水滴鱼",
        "BrokenCD_Name": "Broken CD / 破损的 CD",
        "Bream_Name": "Bream / 鲷鱼",
        "RedMushroom_Name": "Red Mushroom / 红蘑菇",
        "GrassStarter_Description": "Place this on your farm to start a new patch of grass. / 把它种在你的农场上，来得到一块新的草坪。",
        "RadioactiveStone_Description": "Contains radioactive ore. / 含有放射性矿石。",
        "SonarBobber_Description": "Shows what fish is on the line before it's caught. / 在钓到鱼之前显示上钩的鱼种。",
