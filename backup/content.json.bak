        "595": {
          "DisplayName": "Fairy Rose / 玫瑰仙子",
          "Description": "An old folk legend suggests that the sweet smell of this flower attracts fairies. / 传言这种花朵的香味会吸引小仙女而来。"
        },
        "277": {
          "DisplayName": "Wilted Bouquet / 枯萎的花束",
