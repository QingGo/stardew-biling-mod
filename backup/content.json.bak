        "Pam": {
          "0": "Hey, hey! Now this is really something! Thanks a million, kid. | 嘿，嘿！真是太棒了！万分感谢，孩子。",
          "2": "You did good with this one, kid. Thanks! | 这次你做的很好，孩子。谢谢！",
          "4": "This just ain't my thing. | 这不是我想要的。",
          "6": "Now this is just absolutely despicable.$u#$e#(Is this some kind of mean joke?) | 这样真的很恶劣。$u#$e#（这是什么恶作剧吗？）",
          "8": "Thanks, kid. | 谢谢，孩子。"
        },
        "Clint": {
          "0": "Yes! This is exactly what I've been looking for! | 没错！我一直在找的就是这个！",
          "2": "This is a fun gift. Thanks! | 有趣的礼物。谢谢！",
          "4": "*Sigh*... | *唉*……",
          "6": "This makes me depressed. | 这让我很失望。",
          "8": "Thanks. | 谢谢你啊。"
