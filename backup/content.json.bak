        "12": {
          "DisplayName": "Emerald Stone / Emerald Stone",
          "Description": "Break apart to obtain emeralds. / Break apart to obtain emeralds."
        },
        "96": {
          "DisplayName": "Dwarf Scroll I / 矮人卷轴 I",
          "Description": "A yellowed scroll of parchment filled with dwarven script. This one's tied with a red bow. / 一个写满矮人语的黄色羊皮卷轴。这一个上面系着红色蝴蝶结。"
        },
        "MysticTreeSeed": {
          "DisplayName": "Mystic Tree Seed / 神秘树种",
          "Description": "This can be planted to grow a special tree. / 可以种出特别的树。"
        },
        "Carrot": {
          "DisplayName": "Carrot / 胡萝卜",
          "Description": "A fast-growing, colorful tuber that makes for a great snack. / 生长迅速、色彩鲜艳的块茎植物，可以当零食吃。"
        },
        "196": {
          "DisplayName": "Salad / 沙拉",
          "Description": "A healthy garden salad. / 健康的田园沙拉。"
        },
        "848": {
          "DisplayName": "Cinder Shard / 火山晶石",
          "Description": "You can feel a warm glow from within this stone. / 你可以从石头里感受到温度。"
        },
        "0": {
          "DisplayName": "Weeds / 杂草",
          "Description": "A bunch of obnoxious weeds. / 一束令人讨厌的野草。"
        },
        "432": {
          "DisplayName": "Truffle Oil / 松露油",
          "Description": "A gourmet cooking ingredient. / 佳肴必备的原料。"
        },
        "805": {
          "DisplayName": "Tree Fertilizer / 树肥",
          "Description": "Sprinkle on a wild tree to ensure rapid growth, even in winter. Doesn't work on fruit trees. / 洒在野树上，使其快速生长，冬天也一样。在果树上不起作用。"
        },
        "849": {
          "DisplayName": "Copper Stone / Copper Stone",
          "Description": "There's copper ore in this stone. / 这块石头里面有铜矿。"
        },
        "749": {
          "DisplayName": "Omni Geode / 万象晶球",
          "Description": "A blacksmith can break this open for you. These geodes contain a wide variety of minerals. / 铁匠能帮你把它敲开。这种晶球包含了多种多样的矿物。"
        },
        "232": {
          "DisplayName": "Rice Pudding / 大米布丁",
          "Description": "It's creamy, sweet, and fun to eat. / 有浓郁的奶油，又甜，并且吃起来也很有意思。"
        },
        "Book_Roe": {
          "DisplayName": "Jewels Of The Sea / 海之宝石",
          "Description": "Fishing treasure chests have a chance to yield roe. / 钓鱼宝箱有几率开出鱼籽。"
        },
        "129": {
          "DisplayName": "Anchovy / 鳀鱼",
          "Description": "A small silver fish found in the ocean. / 一种海里的小银鱼。"
        },
        "125": {
          "DisplayName": "Golden Relic / 黄金遗物",
          "Description": "It's a golden slab with hieroglyphs and pictures emblazoned onto the front. / 是一个黄金板，它的正面刻绘着象形文字和图画。"
        },
        "828": {
          "DisplayName": "Mummified Frog / 青蛙木乃伊",
          "Description": "This ancient frog may have lived in the jungle canopy. / 这只古老的青蛙可能生活在丛林的树冠里。"
        },
        "577": {
          "DisplayName": "Fairy Stone / 精灵石",
          "Description": "An old miner's song suggests these are made from the bones of ancient fairies. / 古老的矿工歌谣里说，这些石头是古代精灵的骨头做的。"
        },
        "120": {
          "DisplayName": "Prehistoric Handaxe / 史前手斧",
          "Description": "One of the earliest tools employed by humans. This \"crude\" tool was created by striking one rock with another to form a sharp edge. / 人类最早的工具之一。用两块石头互相撞击以形成锋利的边缘，这种\"粗糙的\"工具就是这样造出来的。"
        },
        "310": {
          "DisplayName": "Maple Seed / 枫树种子",
          "Description": "This can be planted to grow a maple tree. / 可以种出一棵枫树。"
        },
        "614": {
          "DisplayName": "Green Tea / 绿茶",
          "Description": "A pleasant, energizing beverage made from lightly processed tea leaves. / 由轻加工的茶叶制成的令人愉快的提神饮料。"
        },
        "559": {
          "DisplayName": "Pyrite / 黄铁矿",
          "Description": "Commonly known as \"Fool's Gold\". / 常被称为“蠢材的黄金”。"
        },
        "248": {
          "DisplayName": "Garlic / 蒜",
          "Description": "Adds a wonderful zestiness to dishes. High quality garlic can be pretty spicy. / 给菜肴增加一些风味。质量好的大蒜可能会特别辣。"
        },
        "799": {
          "DisplayName": "Spook Fish / 幽灵鱼",
          "Description": "The huge eyes can detect the faint silhouettes of prey. / 巨大的眼睛可以检测到猎物微弱的侧影。"
        },
        "774": {
          "DisplayName": "Wild Bait / 万能鱼饵",
          "Description": "A unique recipe from Linus that gives you a chance to catch two fish at once. / 用莱纳斯的独特配方制作，有机会一次钓到两条鱼。"
        },
        "477": {
          "DisplayName": "Kale Seeds / 甘蓝种子",
          "Description": "Plant these in the spring. Takes 6 days to mature. Harvest with the scythe. / 春天播种。6 天成熟。用镰刀收获。"
        },
        "794": {
          "DisplayName": "Weeds / 杂草",
          "Description": "Ugly weeds. Cut to obtain wild seeds. / 一束令人讨厌的野草。 Cut to obtain wild seeds."
        },
        "295": {
