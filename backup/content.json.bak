      "Entries": {
        "HaveBabyQuestion_Adoption": "Should we adopt a baby, {0}? / 我们要不要收养个宝宝，{0}？",
        "BirthMessage_Adoption": "During the night, the adoption agency dropped off your new baby {0}. / 夜间，收养机构送来了你的新生{0}婴儿。",
        "BeachNightMarket_NowOpen": "The Night Market is now open. / 夜市正在进行。",
        "ElliottBook_mystery": "Blue Tower / 蓝塔",
        "HavePlayerBabyQuestion_Adoption": "Do you want to adopt a baby with {0}? / 你想和{0}一起收养个宝宝吗？",
        "Maru_comet2": "A rare wonder of the cosmos... / 宇宙中罕见的奇迹……",
        "Maru_comet3": "Here for one fleeting moment on its infinite journey. / 这是它无限的旅程中短暂的一刻。",
        "SoundInTheNight_UFO": "A strange sound was heard in the night... / 夜间传来一道奇怪的声音……",
        "BirthMessage_SpouseMother": "During the night, {1} gave birth to a baby {0}. / 夜间，{1}生下了一个{0}婴儿。",
        "AnimalNamingTitle": "Name your new baby {0}: / 为您的新生{0}宝宝起名：",
        "Maru_comet1": "Beautiful, isn't it? / 很漂亮，不是吗？",
        "ElliottBook_romance": "Camellia Station / 茶花车站",
        "ElliottBook_default": "The Rise And Fall Of Planet Yazzo / 亚索行星的兴旺史",
        "AnimalBirth": "During the night, {0} gave birth to a baby {1}. / 夜间，{0}生下了一个{1}婴儿。",
        "SoundInTheNight_Meteorite": "An explosion was heard in the night... / 夜间传来一道爆炸声……",
        "BirthMessage_SpouseNaming_Male": "{0} is naming your baby boy. / {0}正在给你的男宝宝取名字。",
        "HaveBabyAnswer_No": "Not now... / 暂时没这个打算……",
        "BirthMessage_PlayerMother": "During the night, you gave birth to a baby {0}. / 夜间，你生下了一个{0}婴儿。",
        "HaveBabyAnswer_Yes": "Yes / 是",
        "BirthMessage_SpouseNaming_Female": "{0} is naming your baby girl. / {0}正在给你的女宝宝取名字。",
        "BabyNamingTitle_Female": "What should we name her? / 该给他取什么名字？",
        "Maru_comet5": "It makes me glad to live on this vibrant world with you! / 这让我感受到，能和你一起生活在这个充满活力的世界上，是多么快乐的事情！",
        "HaveBabyQuestion": "Should we have a baby, {0}? / 我们要不要生个宝宝，{0}？",
        "HavePlayerBabyQuestion": "Do you want to have a baby with {0}? / 你想和{0}一起生个宝宝吗？",
        "BabyNamingTitle_Male": "What should we name him? / 该给他取什么名字？",
        "Maru_comet4": "So empty, so lonely... / 如此空虚而孤独……",
        "SoundInTheNight_Earthquake": "There was an earthquake during the night. / 夜间发生了一场地震。"
      }
