        "SailorShirt_Name": "Sailor Shirt / 水手服",
        "SteelBreastplate_Description": "Decorative armor made from steel. / 钢制的装饰铠甲。",
        "WhiteGi_Name": "White Gi / 白色武术服",
        "CropTankTop_Name_Male": "Crop Tank Top (M) / 短背心（男）",
        "ShirtAndTie_Description": "A white dress shirt and a tie. / 有领带的白衬衫。",
        "80sShirt_Name_Male": "80's Shirt (M) / 80's衬衣（男）",
        "YellowSuit_Description": "It's a bold statement to wear this suit. / 敢穿这套西装说明你大胆自信。",
        "CopperBreastplate_Description": "Decorative armor made from copper. / 铜质的装饰铠甲。",
        "RedFlannelShirt_Description": "A flannel shirt with a red and blue pattern. / 红蓝相间的法兰绒上衣。",
        "YellowandGreenShirt_Name": "Yellow and Green Shirt / 黄绿上衣",
        "CollaredShirt_Name": "Collared Shirt / 有领衬衫",
        "FancyRedBlouse_Name": "Fancy Red Blouse / 靓红女式衬衫",
        "DarkStripedShirt_Name": "Dark Striped Shirt / 深色条纹衫",
        "ClassicOveralls_Name": "Classic Overalls / 经典背带裤",
        "DarkHighlightShirt_Name": "Dark Highlight Shirt / 深色荧光衬衫",
        "GreenVest_Description": "A neat green vest over a shirt. / 衬衣外面再穿一件绿色背心。",
        "BikiniTop_Description": "A summer staple. / 夏季必备。",
        "StuddedVest_Description": "A black vest studded with metal spikes. / 装有金属刺的黑色背心。",
        "MorelShirt_Name": "Morel Shirt / 羊肚菌 T 恤",
        "SuitTop_Description": "A formal top for fancy events and celebrations. / 活动和庆典时穿的正式上衣。",
        "GoodnightShirt_Name": "Goodnight Shirt / 晚安睡衣",
        "CowboyPoncho_Description": "A legendary outfit from the old west. / 旧时西部的传奇装备。",
        "MidnightDogJacket_Name": "Midnight Dog Jacket / 午夜狗 T 恤",
        "BlacksmithApron_Name": "Blacksmith Apron / 铁匠围裙",
        "WhiteOveralls_Description": "A nice clean variant of the classic farmer look. / 经典的农夫衣装，换上漂亮的白色设计。",
        "GreenVest_Name": "Green Vest / 绿色背心",
        "DarkShirt_Name": "Dark Shirt / 深色上衣",
        "WorkShirt_Description": "For long days in the fields. / 为持久的田间劳作而生。",
        "GrayVest_Description": "A gray vest over a white shirt. / 白色衬衣外面再穿一件灰色背心。",
        "ToastedShirt_Name": "Toasted Shirt / 烤面包 T 恤",
        "CarpShirt_Description": "A big carp head adorns the front. / 正面饰有一个大鲤鱼头。",
        "DarknessSuit_Name": "Darkness Suit / 暗色西装",
        "RetroRainbowShirt_Description": "A simple shirt with a faded rainbow pattern. / 有暗淡彩虹图案的 T 恤衫。",
        "GreenFlannelShirt_Description": "A flannel shirt with a green and brown pattern. / 棕绿相间的法兰绒上衣。",
        "DarkBandanaShirt_Description": "A dark shirt with a colorful bandana. / 围有多彩丝巾的深色上衣。",
        "SkeletonShirt_Name": "Skeleton Shirt / 骨架 T 恤",
        "SleevelessOveralls_Description": "Classic overalls with a sleeveless shirt that can be dyed. / 经典的背带裤，上衣无袖可以染色。",
        "MagicSprinkleShirt_Name": "Magic Sprinkle Shirt / 魔法斑点衣",
        "TogaShirt_Name": "Toga Shirt / 托加长袍",
        "RedStripedShirt_Description": "A red shirt with white stripes. / 有白色条纹的红色上衣。",
        "ShirtAndTie_Name": "Shirt And Tie / 领带衬衫",
        "PolkaDotShirt_Name": "Polka Dot Shirt / 圆点上衣",
        "ArcaneShirt_Name": "Arcane Shirt / 神秘衣",
        "RedHoodie_Name": "Red Hoodie / 红色卫衣",
        "GoodGriefShirt_Description": "A good ol' shirt... / 过去的好 T 恤衫……",
        "FakeMusclesShirt_Description": "You could hit the gym, or you could just wear this instead. / 要是你没时间去健身房，那就穿这件吧。",
        "FriedEggShirt_Name": "Fried Egg Shirt / 煎蛋 T 恤",
        "CrabCakeShirt_Name": "Crab Cake Shirt / 蟹黄糕上衣",
        "TankTop_Description": "A sleeveless shirt. / 无袖上衣。",
        "SailorShirt_1261_Description": "Unlike most sailor shirts, this one has a dyeable body and a white collar. / 与一般的水手服不同，这件的衣领是白色的，而且衣身可以染色。",
        "SoftArrowShirt_Description": "A soft-colored shirt with an upward arrow pattern. / 颜色淡雅的 T 恤衫，上面有一个朝上的箭头图案。",
        "ClassicOveralls_Description": "A farming classic. / 农场经典。",
        "ClassyTop_Description": "It feels like the softest velvet. / 面料是触感最柔软的天鹅绒。",
        "GreenOveralls_Description": "A slightly less popular farming classic. / 稍稍不那么受人欢迎的农场经典。",
        "GlobbyShirt_Description": "It's got an indistinguishable glob pattern. / 图案杂乱，难以辨认。",
        "SportsShirt_Name": "Sports Shirt / 运动衫",
        "TrashCanShirt_Name": "Trash Can Shirt / 垃圾桶 T 恤",
        "SunsetShirt_Description": "A shirt inspired by the most evocative time of day. / 这件 T 恤衫的灵感来自于一天中最引人共鸣的时刻。",
        "LeafyTop_Description": "Real leaves adorn this garment. / 用真的叶子装饰的衣服。",
        "PrismaticShirt_LightSleeves_Name": "Prismatic Shirt / 五彩上衣",
        "LimeGreenStripedShirt_Name": "Lime Green Striped Shirt / 黄绿色条纹衫",
        "JesterShirt_Name": "Jester Shirt / 丑角上衣",
        "CropTopShirt_Name": "Crop Top Shirt / 短上衣",
        "SuitTop_Name": "Suit Top / 西装上衣",
        "FlannelShirt_Description": "A nice thick button down shirt with a cross-hatch pattern. Perfect for cold winters. / 有网格图案的带纽扣外衣，很漂亮，也很厚实。非常适合寒冬时穿。",
        "SauceStainedShirt_Description": "It's already covered in spaghetti sauce so you don't have to feel guilty about it! / 上面的意面酱汁是本来就有的，所以你不用感到内疚！",
        "ShrimpEnthusiastShirt_Description": "For those whose appetites demand a steady supply of shrimp. / 为那些天天吃虾的人设计。",
        "RegalMantle_Description": "A regal purple garment / 紫色的皇室披风。",
        "StoreOwnersJacket_Name": "Store Owner's Jacket / 店主的夹克衫",
        "GoodGriefShirt_Name": "\"Good Grief\" Shirt / “Good Grief”衫",
        "TortillaShirt_Description": "A shirt that looks like the surface of a tortilla. / 看起来像是墨西哥薄馅饼表皮的 T 恤衫。",
        "OmniShirt_Description": "It's speckled with rainbow flecks! / 有斑驳的彩虹斑点！",
        "Cardigan_Name": "Cardigan / 开衫",
        "BrownJacket_Name": "Brown Jacket / 棕色夹克衫",
        "GraySuit_Description": "It's a custom-tailored gray suit. / 专门定做的灰色西装。",
        "TomatoShirt_Description": "A shirt that answers the big question: 'Tomatoes are'... (but the rest is smudged). / 这件 T 恤解答了重大难题：“番茄是”……（剩余部分被抹去）",
        "BlueHoodie_Name": "Blue Hoodie / 蓝色卫衣",
        "GoldBreastplate_Name": "Gold Breastplate / 金胸甲",
        "RangerUniform_Name": "Ranger Uniform / 护林员制服",
        "YobaShirt_Description": "A shirt featuring a prominent 'sign of the vessel'. / 这件上衣的特色是显眼的“舰形符号”。",
        "IslandBikini_Description": "A Fern Islands classic. / 芬群岛的经典款。",
        "HappyShirt_Name": "Happy Shirt / 笑脸 T 恤",
        "StoreOwnersJacket_Description": "A jacket that looks like it'd be worn by a small town merchant. / 看起来像是小镇的商人会穿的夹克衫。",
        "BasicPullover_Description": "It's a plain pullover. / 纯色的套头衫。",
        "HotPinkShirt_Description": "A silky shirt in tropical pink. / 热带粉色的丝绸衬衫。",
        "ShortJacket_Name": "Short Jacket / 短夹克",
        "CavemanShirt_Description": "A stone-age classic! / 石器时代的经典！",
        "RedFlannelShirt_Name": "Red Flannel Shirt / 红色法兰绒上衣",
        "DollShirt_Name": "Doll Shirt / 玩偶 T 恤",
        "StrappedTop_Description": "A top with a thin strap. / 有细吊带的上衣。",
        "SportsShirt_Description": "Knock it out of the park with this classic look. / 经典样式可以让你表现出彩。",
        "BlackLeatherJacket_Description": "A cool jacket made of dark black leather. / 很酷的深黑色皮夹克。",
        "SlimeShirt_Description": "A shirt that looks like a big slime. / 看起来像一个超大史莱姆的 T 恤衫。",
        "MayoralSuspenders_Name": "Mayoral Suspenders / 镇长吊带衫",
        "GreenTunic_Description": "A shirt fit for an adventurer. / 适合冒险者穿的上衣。",
        "CaptainsUniform_Description": "The classic uniform of a ship's captain. / 经典的船长制服。",
        "PourOverShirt_Description": "A familiar zig-zag pattern adorns this shirt. Ahhh... that smell. / 上面有熟悉的锯齿状图案。啊……这个味道。",
        "BrownOveralls_Description": "It's hard to see the dirt stains on this one. / 这件衣服沾了泥也看不出来。",
        "GreenBeltedShirt_1011_Description": "A green, belted shirt. / 绿色的、有腰带的上衣。",
        "BeltedCoat_Description": "A velvety black coat with a prominent belt. / 光滑柔软的黑色外套，配有一根显眼的皮带。",
        "CollaredShirt_Description": "A shirt with a starchy white collar. / 有着严肃的白衣领的衬衫。",
        "FlamesShirt_Name": "Flames Shirt / 火焰 T 恤",
        "SkeletonShirt_Description": "A shirt with a skeletal rib cage printed on it. / 印有骷髅肋骨架的 T 恤衫。",
        "BikiniTop_Name": "Bikini Top / 比基尼上装",
        "GreenButtonedVest_Name": "Green Buttoned Vest / 绿色纽扣汗衫",
        "PlainShirt_Description": "A simple shirt. / 简单的 T 恤衫。",
        "SunsetShirt_Name": "Sunset Shirt / 日落 T 恤",
        "MagicSprinkleShirt_Description": "A shirt with prismatic sprinkles. / 有五彩斑点的上衣。",
        "MayoralSuspenders_Description": "A pair of suspenders that looks awfully familiar... / 看起来贼熟悉的吊带衫……",
        "ButtonDownShirt_Name": "Button Down Shirt / 纽扣衬衫",
        "IridiumBreastplate_Description": "Decorative armor made from pure iridium. / 纯铱制的装饰胸甲。"
      }
    },
    {
      "Action": "EditData",
      "Target": "Strings/SimpleNonVillagerDialogues",
      "When": {
        "BilingualMode": "true"
      },
      "Entries": {
        "derby_contestent7": "Fisherman: Trying to get away from the crowds? I had the same idea. / 钓鱼人：你想避开人群是吧？我也是。",
        "winter_derby_contestent7": "Fisherman: My wife sent me off with a thermos of hot coffee. What a gal! / 钓鱼人：出发的时候我老婆给我带了热咖啡，还是用保温瓶装的，多贴心！",
        "winter_derby_contestent10": "Fisherman: My fingers are frozen solid, so I'm just going to enjoy a hot cup o' cider over here. Good luck out there! / 钓鱼人：我手指都冻僵了，得先喝一杯苹果汁热热身子。祝你好运啊！",
        "winter_derby_contestent5": "Angler: Brrr... It's cold! Maybe I'm not cut out for winter ocean fishing.||Angler: I'm more of a CarpFest kind of guy... / 垂钓者：嘶……好冷啊！或许我就不适合在冬天海钓。||垂钓者：要是有一个鲤鱼节就好了……",
        "winter_derby_contestent2": "Mariner: Come here, squiddy squiddy... / 水手：小鱿鱼乖乖，快点过来……",
        "winter_derby_contestent8": "Fishing Pro: Shhh... I don't want to scare the squid.||Fishing Pro: I came over here to get away from the crowd. Squid can be shy.||Fishing Pro: You can fish here if you want, though. Just try to be quiet. / 钓鱼高手：嘘……我不想吓到鱿鱼。||钓鱼高手：我待在这里就是为了避开人群，鱿鱼挺怕人的。||钓鱼高手：你想在这钓鱼的话也行，就是别吵闹。",
        "winter_derby_contestent0": "Fisherman: Squid usually only show up at night. But they threw some special bait in the water that's making them active all day. / 钓鱼人：鱿鱼通常只在晚上出现，不过他们在水里扔了特殊的鱼饵，所以它们一整天都在活动。",
        "winter_derby_contestent1": "Mariner: The cold air makes me feel tough, like a piece of jerky.||Mariner: When the air is too warm I feel like a pudding. / 水手：大冷天我感觉自己很坚韧，像是一块肉干。||水手：天气太热的话，我就会感觉像个布丁。",
        "derby_contestent4": "Fishing Sisters: We're the famous fishing sisters!||Fishing Sisters: We'll fish as many fish as we wish! Nah Nah Nah! / 钓鱼姐妹：我们是著名的钓鱼姐妹！||钓鱼姐妹：志在必得，舍我其谁！耶！耶！耶！",
        "winter_derby_contestent3": "Fisherman: You're a local, huh? Hope you don't mind if I pinch a few of your fine squid... / 钓鱼人：你是本地人吧？我就抓一些这里的好鱿鱼，希望你们不要介意……",
        "derby_contestent9": "Fisherman: Ah, now this is the life. Nothing is more tranquil than a day of trout fishing. / 钓鱼人：哎，这才是人生嘛。钓上一整天鳟鱼，这日子别提有多宁静了。",
        "derby_contestent2": "Mariner: Of course... some guy shows up wearing the same outfit as me. How embarassing! / 水手：呵呵……居然有人跟我穿一样的衣服。尴尬死了！",
        "derby_contestent6": "Trout Man: Where I come from, they call me 'Trout Man'.||Trout Man: Yep, I spent five years learning how to think like a trout. Pretty simple, actually: food, food, food, lay eggs, rest, eat more food.||Trout Man: I happen to like food, myself. Not so good at laying eggs, though. / 鳟鱼侠：我老家那边都喊我“鳟鱼侠”。||鳟鱼侠：没错，这五年我一直在学习鳟鱼的思维方式。其实很简单：吃了睡，睡了吃，吃饱了再产个卵。||鳟鱼侠：碰巧我也很喜欢吃，就是不太会产卵。",
        "winter_derby_contestent4": "Fishing Sisters: We're the famous fishing sisters.||Fishing Sisters: We've been fishing squids since we were kids. Nah nah nah! / 钓鱼姐妹：我们是著名的钓鱼姐妹。||钓鱼姐妹：鱿鱼鱿鱼，绝不犹豫！耶！耶！耶！",
        "derby_contestent3": "Fisherman: Excuse me, I'm trying to enjoy the peace and quiet.||Fisherman: ...||Fisherman: ...||Fisherman: ...||Fisherman: Can't you take a hint?||Fisherman: ...||Fisherman: ...||Fisherman: ...||Fisherman: Someone's about to get battered, and it ain't the trout.||Fisherman:... / 钓鱼人：不好意思，我想安静地钓鱼。||钓鱼人：……||钓鱼人：……||钓鱼人：……||钓鱼人：你就没点眼力见吗？||钓鱼人：……||钓鱼人：……||钓鱼人：……||钓鱼人：看来我不得不动手了。||钓鱼人：……",
        "derby_contestent0": "Fisherman: I came all the way from Grampleton for this.||Fisherman: I'm not leaving without a bag full of trout! / 钓鱼人：我从格兰普顿大老远赶过来就是为了参加这个比赛。||钓鱼人：我可不会空手而归，肯定要钓满一背包的鳟鱼！",
        "winter_derby_contestent9": "Fisherman: I'm not too worried about winning the competition. I just want to enjoy the ambience.||Fisherman: Summer's weather is nicer, but there's something special about a rugged winter. And what would life be without contrast? / 钓鱼人：我不在意比赛能不能获胜，我就是想感受一下氛围。||钓鱼人：夏天的天气固然好，但是凛冽的冬天也不错。没有反差，人生会变成什么样？",
        "derby_contestent5": "Angler: Any luck? Most of the bites I'm getting are from the mosquitos... / 钓客：你怎么样？我没喂到鱼，光顾着喂蚊子了……",
        "winter_derby_contestent6": "Trout Man: Welp, squid are a bit different than trout, but I can catch them all the same.||Trout Man: You better get to fishing if you want a shot at the prize! / 鳟鱼侠：唉，鱿鱼跟鳟鱼有点不一样，但我还是可以钓到的。||鳟鱼侠：如果你想获得奖品就赶紧去钓鱼吧！",
        "winter_derby_contestent11": "Squid Chef: Oh, don't mind me... I'm just here for the bulk squid prices!||Squid Chef: Well, what are you waiting for? Those squid aren't going to catch themselves! / 鱿鱼厨师：啊，不用管我……我就是来批发鱿鱼的！||鱿鱼厨师：哎，你还愣着做什么？你不去钓，鱿鱼可不会自己上来！",
        "derby_contestent1": "Mariner: I think I'm a little overdressed for this event. / 水手：我好像穿得太正式了。",
        "derby_contestent8": "Fishing Pro: I know it's not a competition, but still... whoever gets the most tags will have bragging rights for the rest of the year!||Fishing Pro: I'll be back in winter for SquidFest... Now that's a real challenge!||Fishing Pro: The secret to catching trout is, you gotta give them a presentation that looks so delicious, they can't help but take a bite... / 钓鱼高手：虽然这个不是淘汰赛，但是……如果我拿到的标签最多，肯定要到处炫耀一番！||钓鱼高手：冬天的鱿鱼节我也会来的……那才是真正的挑战！||钓鱼高手：钓鳟鱼的秘诀在于，你的鱼饵要看起来非常好吃，让鱼忍不住咬一口……"
      }
    },
    {
      "Action": "EditData",
      "Target": "Strings/SpecialOrderStrings",
      "When": {
        "BilingualMode": "true"
      },
      "Entries": {
        "Robin_Objective_0_Text": "Gather 80 pieces of hardwood. / 收集 80 块硬木。",
        "Demetrius_Name": "Aquatic Overpopulation / 水生物泛滥",
        "Robin2_Text": "I'm putting on a little promotion, just for fun. If anyone can collect 1000 pieces of {Resource:Text} in a week, they'll earn a reward. And you can keep the {Resource:Text}!             -Robin / 我想搞一次小小的促销活动，当然只是为了娱乐。如果有人能在一周内收集到 1000 份{Resource:Text}，就能获得一份奖赏。而且你可以留着收集到的{Resource:Text}！——罗宾",
        "QiChallenge8_Objective_4_Text": "Catch The Legend II. / 捕获传说之鱼二代。",
        "QiChallenge11_Text": "There's a second version of me, hiding somewhere in town. Can you catch him? / 有另一个我藏在镇上的某个地方。你能抓住他吗？",
        "Wizard2_Objective_1_Message": "Ah... you've returned from the hunt. I sense that you were successful!$h / 啊……你已经狩猎回来了。我感觉得到这是一次成功的狩猎！$h#$b#Now, hand over the jelly and begone! I have important work to do. / 来，把胶冻给我然后就走吧！我还有重要的工作要做。",
        "Demetrius2_Objective_0_Text": "Catch 20 {FishType:Text}. / 捕获 20 条{FishType:Text}。",
        "Clint_RE_Monster_2_LocalizedName": "Skeletons / 骨头",
        "QiChallenge7_Name": "Qi's Kindness / 齐先生的善意",
        "QiChallenge5_Objective_0_Text": "Make it to level 100 in the Skull Cavern. / 在骷髅洞穴到达 100 层。",
        "Gunther_Text": "Calling all amateur paleontologists! I need 100 pieces of bone for my studies. Please drop them off at the museum counter!          -Gunther / 全体古生物爱好者们！我的研究需要 100 块骨头。请把它们放在博物馆柜台！——冈瑟",
        "QiChallenge_Name": "FivePlagues / 五灾",
        "Lewis_Text": "{Text} Anyone who ships 100 {Crop:TextPlural} by the end of the season will earn a substantial reward from the Pelican Town Agricultural Fund. / {Text}所有在本季度结束前售出 100 份{Crop:TextPlural}的人都将获得一份由鹈鹕镇农业基金提供的丰厚奖励。",
        "Pam_Objective_1_Text": "Place the product in Pam's kitchen. / 把东西放在潘姆的厨房里。",
        "Caroline_Objective_0_Text": "Ship 100 {Crop:Text}. / 售出 100 份{Crop:Text}。",
        "Willy2_Objective_0_Text": "Catch 5 Lionfish. / 捕获 5 条狮子鱼。",
        "QiChallenge2_Text": "I've hidden Qi Beans throughout the world. Find them, grow them, propagate them, and ship 500 Qi Fruit within the time limit. / 我把齐豆藏到了世界各地。把它们找出来，然后种下去，在期限内售出 500 个齐瓜。",
        "Pam_Name": "The Strong Stuff / 烈酒",
        "QiChallenge8_Objective_1_Text": "Catch Glacierfish Jr. / 捕获小冰川鱼。",
        "Pierre_Text": "Hello there. For an upcoming promotion, I'm thinking of offering some high-quality vegetables at a slight premium... Know where a thrifty shopkeep might find 25 gold-star vegetables? / 你好。为了即将到来的促销活动，我打算售卖一些价格稍高的高品质蔬菜……考虑到我是节俭的店主，有谁知道哪里可以找到 25 份金星品质的蔬菜吗？",
        "QiChallenge4_Name": "Four Precious Stones / 四颗宝石",
        "Clint_Text": "The number of {Monster:LocalizedName} in the local caves have made mining dangerous... for other people, not me! There's good money for anyone willing to slay 50 of them.          -Clint / 当地洞穴中的{Monster:LocalizedName}数量已经导致我……不对，是其他人——其他人采矿变得十分危险。凡是愿意杀死 50 只怪物的人都能得到一笔可观的报酬。——克林特",
        "Clint_RE_Monster_1_LocalizedName": "Dust Sprites / 灰尘精灵",
        "Willy_Text": "Hey there, I'm looking for a big wad o' bug guts. The juicier the better... at least that's what the crabs seem to like... 100 pieces should do the trick. / 你好啊，我需要大量的虫子内脏。越多汁越好……至少，螃蟹似乎喜欢多汁的虫子……100 块应该就够用了。",
        "Gunther_Objective_1_Text": "Gather 100 pieces of bone. / 收集 100 块骨头。",
        "QiChallenge9_Text": "The mine elevator system has been reset, and new dangers have emerged from deep underground. Make it to the bottom of the mines in one week. / 矿井的电梯系统已重置，地底深处出现了新的危险。在一周内到达矿井底部。",
        "Clint_Name": "Cave Patrol / 洞穴巡查",
        "Pierre_Name": "Pierre's Prime Produce / 皮埃尔优选",
        "Emily_Objective_2_Text": "Deliver an Emerald to Emily / 给艾米丽送一个绿宝石",
        "Marlon_DF_Item_1_LocalizedName": "pieces of Iridium Ore / 铱矿石",
        "Willy_Objective_0_Text": "Collect a bunch of bug meat / 收集一些虫肉。",
        "QiChallenge7_Text": "Give 50 loved gifts in one week. / 在一周内送出 50 份受喜爱的礼物。",
        "Pam_Text": "Heard there's a spirit made out of potatoes that really packs a whallop, if you know what I mean. Mind dropping a few taters into a keg and bringing me a batch or two? / 我听说有一种用土豆做的烈酒，超级猛——你懂的。可以帮我在小桶里放一点土豆，然后给我送来几桶吗？",
        "Gunther_Objective_0_Text": "Place the bones in the drop box at the museum counter. / 把骨头放在博物馆柜台的投递箱里。",
        "Gus_RE_Greeting_0": "I've got the urge to make my famous giant omelet / 我想要做一份我出了名的巨型煎蛋卷",
        "Gus_Name": "Gus' Famous Omelet / 格斯的著名煎蛋卷",
        "Marlon_DF_2_Name": "Treasure Hunt / 寻宝",
        "Demetrius2_RE_FishType_1_Text": "ocean fish / 海鱼",
        "Lewis_Objective_1_Text": "Harvest 100 {Crop:Text}. / 收获 100 份{Crop:Text}。",
        "QiChallenge9_Name": "Danger In The Deep / 深处的危险",
        "QiChallenge2_Name": "Qi's Crop / 齐先生的作物",
        "QiChallenge3_Text": "Think you can score 50,000 points in Junimo Kart endless mode? Prove it. / 你能在祝尼魔赛车无限模式下得 5 万分吗？证明给我看。",
        "Wizard_Text": "I seek an extremely rare and powerful goop, known as 'ectoplasm'. It can be found in the remains of slain ghosts.      -M. Rasmodius / 我在寻找一种极为罕见的粘液，即所谓的“灵外质”，它有很强的力量，可以在杀死的鬼魂的遗骸中找到。——M·拉斯莫迪斯",
        "QiChallenge3_Objective_0_Text": "Score 50,000 points in Junimo Kart endless mode. / 在祝尼魔赛车无限模式下得 5 万分。",
        "Wizard2_Name": "Prismatic Jelly / 五彩胶冻",
        "QiChallenge6_Text": "Ship 100,000g worth of freshly cooked items. / 售出价值 100,000 金的新鲜烹饪食品。",
        "QiChallenge_Text": "I will provide you with 600 Qi Beans. Plant these, grow them, and ship at least 500 of them in a week or less. But beware, Five plagues will descend upon you, threatening your crop... / 我会给你 600 个齐豆。把它们种下去，好好栽培，然后在一周指内给售出至少 500 个果实。但要小心，五场灾害会降临，威胁到你的农作物……",
        "Willy2_Name": "Tropical Fish / 热带鱼",
        "Emily_Objective_3_Text": "Deliver a Jade to Emily / 给艾米丽送一个翡翠",
        "Demetrius2_RE_FishType_0_Text": "river fish / 河鱼",
        "QiChallenge2_Objective_0_Text": "Ship 500 Qi Fruit / 售出 500 个齐瓜。",
        "QiChallenge11_Name": "Find Qi's Double / 找到齐先生的分身",
        "Pierre_Objective_0_Text": "Harvest gold-quality vegetables / 收获金星品质的蔬菜。",
        "Evelyn_Objective_1_Text": "Place the leeks in Evelyn's kitchen. / 把韭葱放在艾芙琳的厨房里。",
        "QiChallenge5_Name": "Qi's Hungry Challenge / 齐先生的饥饿挑战",
        "QiChallenge8_Objective_2_Text": "Catch Son of Crimsonfish. / 捕获绯红鱼之子。",
        "Evelyn_Objective_0_Text": "Gather 12 leeks. / 收集 12 份韭葱。",
        "Lewis_RE_Text_2": "There's a new beauty craze in Zuzu City... apparently, a lotion made from {Crop:Text} is said to remove wrinkles.  / 祖祖市掀起了一股新的美容热潮……据说，一种由{Crop:Text}制成的乳液可以去除皱纹。",
        "Marlon_DF_0_Name": "Monster Hunt / 怪物狩猎",
        "QiChallenge10_Text": "The Skull Cavern has been invaded by powerful monsters. Make it to level 100 in one piece. / 骷髅洞穴受到强大怪物的入侵。安全抵达 100 层吧。",
        "Linus_Name": "Community Cleanup / 社区清理",
        "Gunther_Name": "Fragments of the past / 历史的碎片",
        "Demetrius_Objective_0_Text": "Catch 10 {FishType:Text}. / 捕获 10 条{FishType:Text}。",
        "QiChallenge4_Text": "Find 4 prismatic shards. Place them in my collection box. / 找到 4 个五彩碎片。放到我的收集箱里。",
        "Marlon_DF_Item_2_LocalizedName": "Prismatic Shards / 个五彩碎片",
        "Robin_Name": "Robin's Project / 罗宾的项目",
        "Caroline_Text": "I want to experiment with tropical cooking, but it's hard to find any ingredients. If someone could ship 100 {Crop:TextPlural}, it might help!  / 我想尝试烹饪热带菜肴，但是寻找食材真的很困难。如果有人能售出 100 份{Crop:TextPlural}，应该能帮上忙！",
        "Lewis_RE_Text_1": "Apparently, {Crop:TextPlural} are considered the latest 'superfood' in Zuzu City.  / {Crop:TextPlural}在祖祖市似乎得到了最新的“健康食物”称号。",
        "Marlon_DF_1_Objective": "Reach level 30 of the Skull Cavern. / 到达骷髅洞穴第 30 层。",
        "QiChallenge12_Objective_5_Text": "Place 100 purple items into Qi's collection box. / 把 100 个紫色的物品放进齐先生的收集箱里。",
        "Lewis_Objective_0_Text": "Ship 100 {Crop:Text}. / 售出 100 份{Crop:Text}。",
        "QiChallenge9_Objective_0_Text": "Reach the bottom of the mines, again. / 再次抵达矿井底部。",
        "QiChallenge11_Objective_0_Text": "Catch Qi's double. / 抓住齐先生的分身。",
        "Wizard2_Text": "I require assistance in tracking down the rare and dangerous prismatic slime, within the local caves. Bring me a jar of its prismatic jelly and you will be duly rewarded.        -M. Rasmodius / 我需要人手协助追查当地洞穴内罕见而危险的五彩史莱姆。给我拿一罐它的五彩胶冻来，你会得到应有的奖励的。——M·拉斯莫迪斯",
        "Willy2_Objective_2_Text": "Catch 5 Stingray. / 捕获 5 条黄貂鱼。",
        "Marlon_DF_2_Text": "Collect {Treasure:Count} {Treasure:LocalizedName} from the Skull Cavern. / 在骷髅洞穴中收集 {Treasure:Count} 个{Treasure:LocalizedName}。",
        "QiChallenge12_Text": "Find 100 each of red, orange, yellow, green, blue, and purple items. Place them in my collection box. / 找到红色、橙色、黄色、绿色、蓝色、紫色的物品各 100 个，把它们放进我的收集箱里。",
        "QiChallenge12_Objective_1_Text": "Place 100 orange items into Qi's collection box. / 把 100 个橙色的物品放进齐先生的收集箱里。",
        "Marlon_DF_1_Name": "Deep Dive / 深层探险",
        "QiChallenge_Objective_0_Text": "Ship 500 Qi Fruit. / 售出 500 个齐瓜。",
        "QiChallenge8_Objective_3_Text": "Catch Radioactive Carp. / 捕获放射性鲤鱼。",
        "Marlon_DF_Monster_2_LocalizedName": "Mummies / 木乃伊",
        "Linus_Objective_1_Text": "Dump the trash in the recycling bin behind the train platform. / 把垃圾倒在火车站台后面的回收桶里。",
        "QiChallenge12_Objective_4_Text": "Place 100 blue items into Qi's collection box. / 把 100 个蓝色的物品放进齐先生的收集箱里。",
        "Willy2_Text": "There's nothin' like tropical fishing... To keep the art alive, I'm offering a reward for whoever can bring in a good island haul. / 在热带地区钓鱼的体验是无与伦比的……为了让这项技艺得到传承，所有带来大量岛屿渔获的人都能得到我的奖励。",
        "QiChallenge12_Name": "Qi's Prismatic Grange / 齐先生的五彩农场",
        "QiChallenge8_Name": "Extended Family / 大家族",
        "QiChallenge6_Name": "Qi's Cuisine / 齐先生的菜肴",
        "Caroline_Name": "Island Ingredients / 岛屿食材",
        "Marlon_DF_0_Text": "Descend into the Skull Cavern and slay 10 {Monster:LocalizedName}. / 进入骷髅洞穴，杀掉 10 只{Monster:LocalizedName}。",
        "Emily_Text": "Hey! I'm going to invite some friends over to do a \"rock rejuvenation\" ceremony, but I'll need some crystals to channel the right energies. Do you think you could lend me a hand? / 嘿！我打算邀请一些朋友过来，办一个“宝石能量”仪式，但我需要一些水晶才能聚集相应的能量。你能帮把手吗？",
        "Demetrius2_Text": "For unknown reasons, the local population of {FishType:Text} has grown to an unsustainable level. I need a local angler to help reduce their numbers. / 本地的{FishType:Text}数量泛滥成灾，具体原因不明。我需要一名本地的垂钓者帮忙减少鱼群数量。",
        "Clint_RE_Monster_3_LocalizedName": "Grubs / 蛆",
        "QiChallenge8_Objective_0_Text": "Catch Ms. Angler. / 捕获雌鮟鱇鱼。",
        "Emily_Objective_0_Text": "Deliver a Ruby to Emily / 给艾米丽送一个红宝石",
        "QiChallenge5_Text": "Your task is to make it to level 100 in the Skull Cavern. However, you can't eat or drink anything while there. / 你的任务是在骷髅洞穴到达 100 层，而且不能吃不能喝。",
        "Evelyn_Name": "Gifts for George / 给乔治的礼物",
        "Pierre_Objective_1_Text": "Place the crops in the empty produce box in Pierre's shop. / 把农作物放进皮埃尔商店里的空箱子中。",
        "QiChallenge10_Name": "Skull Cavern Invasion / 骷髅洞穴入侵",
        "Demetrius2_Name": "Biome Balance / 生态平衡",
        "Willy_Objective_1_Text": "Place the bug meat in the barrel next to Willy's house. / 把虫肉放进威利房子旁边的桶里。",
        "Gus_Objective_1_Text": "Put the eggs in Gus' fridge. / 把蛋放到格斯的冰箱里。",
        "Lewis_RE_Text_0": "{Crop:TextPluralCapitalized} are in high demand this year.  / 今年{Crop:TextPlural}的需求量很大。",
        "QiChallenge7_Objective_0_Text": "Give 50 loved gifts in one week. / 在一周内送出 50 份受喜爱的礼物。",
        "Wizard_Objective_0_Message": "Ah, it's brimming with the energy of forgotten souls... perfect.$h / 啊，它充满了被遗忘的灵魂的能量……太完美了。$h#$b#Now, begone! I shall require perfect silence to discern the true nature of this substance. / 现在你可以走了！我需要绝对的安静来辨别这种物质的真实性质。",
        "QiChallenge4_Objective_0_Text": "Place 4 Prismatic Shards into Qi's collection box. / 把 4 个五彩碎片放到齐先生的收集箱里。",
        "Robin_Objective_1_Text": "Add the hardwood to the stockpile in Robin's house. / 把硬木放到罗宾房子的库存中。",
        "Gus_Text": "{Greeting}... but I'll need two dozen eggs. Any takers?                -Gus / {Greeting}……我需要 24 个蛋。有人帮忙吗？——格斯",
        "Robin2_Objective_0_Text": "Gather 1000 pieces of {Resource:Text}. / 收集 1000 份{Resource:Text}。",
        "Robin_Text": "Hey! I have an idea for a new style of bed, but I'll need 80 hardwood to make it happen. Can anyone help?                     -Robin / 嗨！我构思了一种新造型的床，但我需要 80 块硬木才能做出来。有人能帮把手吗？——罗宾",
        "QiChallenge8_Text": "Family members of the legendary fish have returned to the valley. You have three days to catch Ms. Angler, Glacierfish Jr., Son of Crimsonfish, Radioactive Carp, and The Legend II. / 传说鱼类的家族成员回到了山谷里。你要在三天内捕捉到雌鮟鱇鱼、小冰川鱼、绯红鱼之子、放射性鲤鱼，还有传说之鱼二代。",
        "Wizard2_Objective_0_Text": "Slay a prismatic slime. / 杀死一只五彩史莱姆。",
        "QiChallenge12_Objective_0_Text": "Place 100 red items into Qi's collection box. / 把 100 个红色的物品放进齐先生的收集箱里。",
        "Marlon_DF_Item_0_LocalizedName": "Omni Geodes / 万象晶球",
        "Wizard_Objective_0_Text": "Deliver an ectoplasm to Wizard / 给法师送去一份灵外质。",
        "QiChallenge12_Objective_3_Text": "Place 100 green items into Qi's collection box. / 把 100 个绿色的物品放进齐先生的收集箱里。",
        "Willy_Name": "Juicy Bugs Wanted! / 需要多汁的虫子！",
        "Wizard2_Objective_1_Text": "Deliver a prismatic jelly to Wizard / 给法师送去一份五彩胶冻。",
        "QiChallenge12_Objective_2_Text": "Place 100 yellow items into Qi's collection box. / 把 100 个黄色的物品放进齐先生的收集箱里。",
        "Gus_RE_Greeting_1": "I've got the urge to make another giant omelet / 我想要再做一份巨型煎蛋卷",
        "QiChallenge6_Objective_0_Text": "Ship 100,000g worth of freshly cooked items. / 售出价值 100,000 金的新鲜烹饪食品。",
        "Emily_Objective_1_Text": "Deliver a Topaz to Emily / 给艾米丽送一个黄水晶",
        "QiChallenge3_Name": "Let's Play A Game / 来玩游戏吧",
        "Lewis_RE_Text_4": "The Governor is holding a banquet, and his Chefs are ordering huge numbers of {Crop:TextPlural}. / 州长正在举行宴会，他的厨师订购了大量的{Crop:TextPlural}。",
        "Clint_RE_Monster_0_LocalizedName": "Bats / 蝙蝠",
        "Lewis_Name": "Crop Order / 农作物订单",
        "Willy2_Objective_1_Text": "Catch 5 Blue Discus. / 捕获 5 条蓝铁饼鱼。",
        "Marlon_DF_Monster_1_LocalizedName": "Purple Slimes / 紫色史莱姆",
        "Demetrius_Text": "For unknown reasons, the local population of {FishType:Text} has grown to an unsustainable level. I need a local angler to help reduce their numbers. / 本地的{FishType:Text}数量泛滥成灾，具体原因不明。我需要一名本地的垂钓者帮忙减少鱼群数量。",
        "Clint_Objective_0_Text": "Slay 50 {Monster:LocalizedName}. / 杀死 50 只{Monster:LocalizedName}。",
        "Robin2_Name": "Robin's Resource Rush / 罗宾的资源活动",
        "Pam_Objective_0_Text": "Keg a few potatoes and collect 12 batches / 在小桶里装一些土豆，收集 12 桶。",
        "Wizard_Name": "A Curious Substance / 奇特物质",
        "Marlon_DF_Monster_0_LocalizedName": "Serpents / 飞蛇",
        "Marlon_DF_1_Text": "Reach level 30 of the Skull Cavern. / 到达骷髅洞穴第 30 层。",
        "Emily_Objective_4_Text": "Deliver an Amethyst to Emily / 给艾米丽送一个紫水晶",
        "Evelyn_Text": "George thinks no one in town cares about him. I'd like to prove him wrong! A dozen leeks should do the trick... they're his favorite.                      -Evelyn / 乔治认为镇子上没人在乎他，我想要证明他是错的！一打韭葱应该就足够了……他最喜欢韭葱了。——艾芙琳",
        "Linus_Objective_0_Text": "Gather 20 pieces of trash. / 钓起 20 件垃圾。",
        "Demetrius2_RE_FishType_2_Text": "lake fish / 湖鱼",
        "Gus_Objective_0_Text": "Gather 24 eggs. / 收集 24 个蛋。",
        "Emily_Name": "Rock Rejuvenation / 宝石能量",
        "QiChallenge10_Objective_0_Text": "Make it to level 100 of the Skull Cavern. / 在骷髅洞穴抵达 100 层。",
        "Lewis_RE_Text_3": "The Queen of Sauce was recently spotted dining on fresh {Crop:Text}. Now everyone in the world wants one! / 最近有人看到酱汁女王在吃新鲜的{Crop:Text}。现在全世界都想尝尝看！",
        "Marlon_DF_2_Objective": "Collect {Treasure:Count} {Treasure:LocalizedName}. / 收集 {Treasure:Count} 个{Treasure:LocalizedName}。",
        "Linus_Text": "I have an idea. There's a lot of trash in the water. Why don't we fish some out to make the valley more beautiful?                     -Linus / 我有个主意。水里有很多垃圾，我们为什么不钓一些出来，使山谷更美丽呢？——莱纳斯",
        "Marlon_DF_0_Objective": "Slay 10 {Monster:LocalizedName}. / 杀掉 10 只{Monster:LocalizedName}。"
      }
    },
    {
      "Action": "EditData",
      "Target": "Strings/SpeechBubbles",
      "When": {
        "BilingualMode": "true"
      },
      "Entries": {
        "Hospital_Maru_Greeting5": "Here to see the doctor? / 来看医生的吗？",
        "ScienceHouse_Robin_RareGreeting": "Lew...? Oh... / 刘……？噢！",
        "ArchaeologyHouse_Gunther_Greeting2": "Dig anything up? / 挖出什么了吗？",
        "AnimalShop_Marnie_Greeting3": "Hey! How's {1} Farm doin'? / 嗨！{1}农场最近如何了？",
        "SeedShop_Pierre_Greeting1": "Hello! / 你好！",
        "ManorHouse_Lewis_Afternoon": "Good afternoon. / 下午好。",
        "SandyHouse_Sandy_Greeting1": "You poor burnt thing! / 真可怜，都被晒伤了！",
        "Saloon_Gus_NotSummer": "What can I get for ya? / 您需要点什么？",
        "AnimalShop_Marnie_NotRaining": "Hey! How's the weather? / 嗨！最近天气还好吗？",
        "Saloon_Gus_Raining": "Need a hot drink? / 需要一杯热饮吗？",
        "ScienceHouse_Robin_NotRaining2": "Hey! / 嘿！",
        "Hospital_Maru_Spouse": "Hi, honey < / 嗨，甜心<",
        "AnimalShop_Marnie_NotCloseFriends": "Looking for some supplies? / 是想来购置补给品吗？",
        "Hospital_Maru_Greeting2": "Can I help you? / 我能帮您吗？",
        "Saloon_Gus_Summer": "Need a cold drink? / 想要喝点什么吗？",
        "Hospital_Maru_Greeting1": "Do you have an appointment? / 您有预约吗？",
        "ScienceHouse_Robin_Raining1": "Some weather, huh? / 这天气真让人遭罪啊，是吧？",
        "Hospital_Maru_Greeting4": "Is it an emergency? / 是紧急情况吗？",
        "SandyHouse_Sandy_Greeting4": "Rare seeds for sale! / 出售稀有种子！",
        "AnimalShop_Marnie_Greeting1": "Hello! / 你好！",
        "ArchaeologyHouse_Gunther_Greeting4": "Hello there. / 你好。",
        "SeedShop_Pierre_RareGreeting": "Did you remember your wallet? / 你带钱包了吧？",
        "SeedShop_Pierre_Raining": "It's a good day to shop! / 今天风和日丽，适合购物！",
        "ScienceHouse_Robin_CloseFriends": "Hi {0}! / 嗨，{0}！",
        "ManorHouse_Lewis_Morning": "Good morning! / 早上好！",
        "ArchaeologyHouse_Gunther_Greeting3": "Need my expertise? / 需要我帮忙是吗？",
        "Saloon_Gus_Greeting": "Come in, come in! / 请进请进！",
        "ArchaeologyHouse_Gunther_Greeting1": "Find anything new? / 找到什么了吗？",
        "SandyHouse_Sandy_Greeting3": "You look parched! / 你看上去口干舌燥！",
        "AdventureGuild_Marlon_Greeting3": "Gil, wake up! We have a visitor. / 吉尔，醒醒！有客人来了。",
        "SeedShop_Pierre_NotSummer": "Seeds for sale! / 种子出售！",
        "ScienceHouse_Robin_NotCloseFriends": "Need something built? / 需要建造些什么东西吗？",
        "AdventureGuild_Marlon_Greeting2": "Greetings. / 你好啊。",
        "Saloon_Gus_NotRaining": "Need a drink? / 想要喝点什么吗？",
        "AdventureGuild_Marlon_Greeting4": "Good evening. / 晚上好。",
        "Saloon_Gus_RareGreeting": "You look like you need a drink. / 你似乎需要喝点东西。",
        "SandyHouse_Sandy_Greeting5": "Sweetie, won't you buy something? / 亲爱的，你不买点什么吗？",
        "AnimalShop_Marnie_Greeting2": "Howdy! / 你好！",
        "ScienceHouse_Robin_NotRaining1": "Hey, have a nice walk? / 嘿，散步回来了吗？",
        "LeahHouse_Leah_Greeting3": "Hi, {0} / 你好，{0}",
        "AnimalShop_Marnie_Raining": "Wipe your feet! / 把你的脚擦干！",
        "SandyHouse_Sandy_Greeting2": "Oh, a visitor! / 哦，有客人来了！",
        "ManorHouse_Lewis_Evening": "Good evening. / 晚上好。",
        "SeedShop_Pierre_NotRaining": "Welcome! / 欢迎！",
        "AnimalShop_Marnie_CloseFriends": "Hi, {0} / 你好，{0}",
        "ArchaeologyHouse_Gunther_RareGreeting": "You smell like dirt... good! / 你身上有泥土的味道……不错！",
        "SeedShop_Pierre_Greeting2": "It's farmer {0}! / 是农夫{0}！",
        "SeedShop_Pierre_Summer": "Summer seeds available! / 夏季种子有售！",
        "ElliottHouse_Elliott_Greeting3": "Hello, {0} / 你好，{0}",
        "Saloon_Gus_NotSnowing1": "Need a hot meal? / 想要吃点热食吗？",
        "ScienceHouse_Robin_Snowing": "Nice and warm in here! / 这里好暖和好舒适！",
        "LeahHouse_Leah_Greeting1": "Oh, hi! / 啊，你好！",
        "ScienceHouse_Robin_Greeting": "Welcome! / 欢迎！",
        "SeedShop_Pierre_Winter": "Welcome to Pierre's heated shop! / 欢迎来到热气腾腾的皮埃尔种子店！",
        "Saloon_Gus_Snowing1": "It's cold outside but the coffee's hot! / 外面很冷，咖啡很暖和！",
        "ScienceHouse_Robin_Raining2": "Oh no, you're soaked! / 糟糕，你全身湿透了！",
        "SeedShop_Pierre_NotWinter": "Welcome to Pierre's! / 欢迎来到皮埃尔种子店！",
        "AdventureGuild_Marlon_Greeting_Male": "He's back! / 他回来了！",
        "AdventureGuild_Marlon_Greeting1": "Need a new sword? / 是来买剑的吗？",
        "ScienceHouse_Robin_NotSnowing": "Hi there! / 你好啊！",
        "ElliottHouse_Elliott_Greeting1": "It's nice of you to visit. / 谢谢光临。",
        "JojaMart_Morris_Greeting": "Welcome to JojaMart! / 欢迎来到 Joja 超市！",
        "Hospital_Maru_Greeting3": "We've got medicine for sale! / 我们这里出售药物！",
        "AdventureGuild_Marlon_Greeting_Female": "She's back! / 她回来了！",
        "Saloon_Gus_NotSnowing2": "Welcome! / 欢迎！",
        "ArchaeologyHouse_Gunther_Greeting5": "Brought me something? / 有东西带给我是吗？",
        "Saloon_Gus_Snowing2": "Come in out of the cold! / 进来御寒吧！",
        "AnimalShop_Marnie_RareGreeting": "Lew...? Oh... / 刘……？噢！",
        "LeahHouse_Leah_Greeting2": "Hello. / 你好。",
        "ElliottHouse_Elliott_Greeting2": "Hello. / 你好。"
      }
