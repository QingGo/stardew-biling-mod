        "303": {
          "DisplayName": "Pale Ale / 淡啤酒",
          "Description": "Drink in moderation. / 请适度饮酒。"
        },
        "535": {
          "DisplayName": "Geode / 晶球",
          "Description": "A blacksmith can break this open for you. / 你可以找铁匠破开这块晶球。"
        },
        "873": {
          "DisplayName": "Piña Colada / 椰林飘香",
          "Description": "Drink in moderation. / 请适度饮酒。"
        },
        "151": {
          "DisplayName": "Squid / 鱿鱼",
          "Description": "A deep sea creature that can grow to enormous size. / 一种可以长得很大的深海生物。"
        },
        "531": {
          "DisplayName": "Aquamarine Ring / 海蓝宝石戒指",
          "Description": "Increases critical strike chance by 10%. / 增加 10% 的致命一击机会。"
        },
        "402": {
          "DisplayName": "Sweet Pea / 甜豌豆",
          "Description": "A fragrant summer flower. / 芬香的夏天花朵。"
        },
        "86": {
          "DisplayName": "Earth Crystal / 地晶",
          "Description": "A resinous substance found near the surface. / 在地表附近发现的树脂状物质。"
        },
        "208": {
          "DisplayName": "Glazed Yams / 琉璃山药",
          "Description": "Sweet and satisfying... The sugar gives it a hint of caramel. / 又香又甜……加糖让它有了一点焦糖味。"
        },
        "4": {
          "DisplayName": "Ruby Stone / Ruby Stone",
          "Description": "Break apart to obtain rubies. / Break apart to obtain rubies."
        },
        "384": {
          "DisplayName": "Gold Ore / 黄金矿石",
          "Description": "A precious ore that can be smelted into bars. / 一种珍贵的矿石，能被熔炼成金锭。"
        },
        "597": {
          "DisplayName": "Blue Jazz / 蓝爵",
          "Description": "The flower grows in a sphere to invite as many butterflies as possible. / 这种花朵为圆球状，以便吸引更多的蝴蝶而来。"
        },
        "335": {
          "DisplayName": "Iron Bar / 铁锭",
          "Description": "A bar of pure iron. / 一条纯铁锭。"
        },
        "732": {
          "DisplayName": "Crab Cakes / 蟹黄糕",
          "Description": "Crab, bread crumbs, and egg formed into patties then fried to a golden brown. / 蟹肉、面包屑和鸡蛋做成饼状，然后油炸至金棕色。"
        },
        "239": {
          "DisplayName": "Stuffing / 塞料面包",
          "Description": "Ahh... the smell of warm bread and sage. / 啊……热面包和鼠尾草的香味。"
        },
        "581": {
          "DisplayName": "Prehistoric Skull / 史前头骨",
          "Description": "This is definitely a mammalian skull. / 这绝对是一个哺乳类动物的头盖骨。"
        },
        "823": {
          "DisplayName": "Fossilized Leg / 腿骨化石",
          "Description": "A thick and sturdy leg bone. / 粗壮的腿骨。"
        },
        "538": {
          "DisplayName": "Alamite / 透闪石",
          "Description": "Its distinctive fluorescence makes it a favorite among rock collectors. / 它与众不同的荧光使它成为许多岩石收集爱好者的最爱。"
        },
        "300": {
          "DisplayName": "Amaranth / 苋菜",
          "Description": "A purple grain cultivated by an ancient civilization. / 远古文明广泛耕种的一种紫色谷物。"
        },
        "706": {
          "DisplayName": "Shad / 西鲱",
          "Description": "Lives in a school at sea, but returns to the rivers to spawn. / 结群生活在海里，但会回到河里产卵。"
        },
        "VolcanoCoalNode1": {
          "DisplayName": "Stone / 石头",
          "Description": "Break apart to obtain stone with a chance of coal. / Break apart to obtain stone with a chance of coal."
        },
        "336": {
          "DisplayName": "Gold Bar / 金锭",
          "Description": "A bar of pure gold. / 一条纯金锭。"
        },
        "691": {
          "DisplayName": "Barbed Hook / 倒刺钩",
          "Description": "Makes your catch more secure, causing the \"fishing bar\" to cling to your catch. Works best on slow, weak fish. / 上钩的鱼更不容易跑掉，使“钓鱼条”靠紧猎物。对速度慢、弱小的鱼最有效。"
        },
        "723": {
          "DisplayName": "Oyster / 牡蛎",
          "Description": "Constantly filters water to find food. In the process, it removes dangerous toxins from the environment. / 以滤水的方式觅食。在这个过程中，会清除环境中的有毒有害物质。"
        },
        "557": {
          "DisplayName": "Petrified Slime / 石化史莱姆",
          "Description": "This little guy may be 100,000 years old. / 这小家伙也许有十万岁了。"
        },
        "262": {
          "DisplayName": "Wheat / 小麦",
          "Description": "One of the most widely cultivated grains. Makes a great flour for breads and cakes. / 被广泛种植的谷物之一。能做成制作蛋糕和面包的上好面粉。"
        },
        "PurpleBook": {
          "DisplayName": "Book Of Stars / 星之书",
          "Description": "Read this to gain some experience in all skills. / 阅读即可获得所有技能的经验。"
        },
        "104": {
          "DisplayName": "Elvish Jewelry / 精灵珠宝",
          "Description": "Dirty but still beautiful. On the side is a flowing script thought by some to be the ancient language of the elves. No Elvish bones have ever been found. / 很脏但是依然美丽。上边有被认为是古代精灵语的流畅字迹。但还没有人见过精灵的遗骸。"
        },
        "Broccoli": {
          "DisplayName": "Broccoli / 西蓝花",
          "Description": "The flowering head of a broccoli plant. The tiny buds give it a unique texture. / 西蓝花的花球，微小的花蕾口感独特。"
        },
        "198": {
          "DisplayName": "Baked Fish / 烤鱼",
          "Description": "Baked fish on a bed of herbs. / 香草烤鱼。"
        },
        "370": {
          "DisplayName": "Basic Retaining Soil / 初级保湿土壤",
          "Description": "This soil has a chance of staying watered overnight. Mix into tilled soil. / 这种土壤有一定几率隔夜依然保持湿润。使用时加到犁过的土地中。"
        },
        "698": {
          "DisplayName": "Sturgeon / 鲟鱼",
          "Description": "An ancient bottom-feeder with a dwindling population. Females can live up to 150 years. / 古老的生物链底层生物，数量一直在减少。雌性的寿命长达 150 年。"
        },
        "771": {
          "DisplayName": "Fiber / 纤维",
          "Description": "Raw material sourced from plants. / 源自植物的原生材料。"
        },
        "267": {
          "DisplayName": "Flounder / 比目鱼",
          "Description": "It lives on the bottom, so both eyes are on top of its head. / 它生活在底部，所以两只眼睛都在它的头顶上。"
        },
        "548": {
          "DisplayName": "Jamborite / 绿水镍矿",
          "Description": "The crystals are so tightly packed it almost looks fuzzy. / 这些晶石是如此紧密地排列在一起，以至于它们看起来都有些模糊了。"
        },
        "731": {
          "DisplayName": "Maple Bar / 枫糖棒",
          "Description": "It's a sweet doughnut topped with a rich maple glaze. / 浇上枫糖的甜甜圈。"
        },
        "218": {
          "DisplayName": "Tom Kha Soup / 椰汁汤",
          "Description": "These flavors are incredible! / 这味道好极了！"
        },
        "766": {
          "DisplayName": "Slime / 史莱姆泥",
          "Description": "A shimmering, gelatinous glob with no smell. / 没有气味、发着微光的一团凝胶。"
        },
        "554": {
          "DisplayName": "Lemon Stone / 柠檬石",
          "Description": "Some claim the powdered crystal is a dwarvish delicacy. / 有些人说这种粉状的晶石是矮人的佳肴。"
        },
        "585": {
          "DisplayName": "Skeletal Tail / 尾部骨骼",
          "Description": "It's pretty short for a tail. / 这尾巴还真短。"
        },
        "837": {
          "DisplayName": "Lionfish / 狮子鱼",
          "Description": "An aggressive, predatory fish with venomous spines. / 好斗的食肉性鱼，有毒刺。"
        },
        "913": {
          "DisplayName": "Enricher / 施肥器",
          "Description": "Place on a sprinkler and load with fertilizer to automatically apply it when planting seeds nearby. / 安装在洒水器上并装入肥料，在其附近播撒种子时便会自动施肥。"
        },
        "709": {
          "DisplayName": "Hardwood / 硬木",
          "Description": "A special kind of wood with superior strength and beauty. / 一种特殊的木材，有更高的强度和观赏性。"
        },
        "Book_Diamonds": {
          "DisplayName": "The Diamond Hunter / 钻石猎人",
          "Description": "All stones have a chance to drop a diamond when mined by hand. / 手动凿开石头时有几率掉落钻石。"
        },
        "2": {
          "DisplayName": "Diamond Stone / Diamond Stone",
          "Description": "Break apart to obtain diamonds. / Break apart to obtain diamonds."
        },
        "674": {
          "DisplayName": "Weeds / 杂草",
          "Description": "Ugly weeds. Might contain fibers or mixed seeds. / 一束令人讨厌的野草。 Might contain fibers or mixed seeds."
        }
      }
    },
