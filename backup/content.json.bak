        "Harvey": {
          "0": "It's for me? This is my favorite stuff! It's like you read my mind. | 这是为我准备的吗？这是我最喜欢的东西！就好像你和我有心灵感应一样。",
          "2": "That's such a nice gift. Thank you! | 真是个不错的礼物。非常感谢！",
          "4": "Hmm... Are you sure this is healthy? | 唔……你确定这个健康？",
          "6": "...I think I'm allergic to this. | ……我想我对它过敏。",
          "8": "Thanks. That's very kind of you. | 谢谢你啊。你人真好。"
        },
        "Elliott": {
          "0": "@, this is a beautiful gift! Thank you! | @，好漂亮的礼物！非常感谢！",
          "2": "This is for me? Marvelous! | 这是给我的吗？棒呆了！",
          "4": "Hmm... I'm not a huge fan of this. | 唔……我不太喜欢这个。",
          "6": "This item gives me a terrible feeling. I'll have to dispose of it. | 这东西让我感觉很糟糕。我只能扔掉它了。",
          "8": "Oh, a present! Thank you! | 噢，礼物！非常感谢！"
        },
        "Jas": {
          "0": "*gasp*...Wow!! Thank you!$h | *惊喜*……哇哦！非常感谢！$h",
          "2": "I love presents! Thank you! | 我爱礼物！非常感谢！",
          "4": "Is this a gift? Oh...$s | 这是礼物吗？噢！$s",
          "6": "Ew. This is icky.$s | 呕。好恶心。$s",
          "8": "Thank you! | 非常感谢！"
        },
        "Evelyn": {
          "0": "*gasp*... This is absolutely marvelous!$u#$e#You've made an old lady very happy. | *喘气*……这真是了不起的礼物！$u#$e#你可真会逗老太太开心。",
          "2": "Oh my, it looks wonderful! That's very kind of you. | 哎呀，它看上去棒极了！你人真好。",
          "4": "Um, Where will I put this? | 呃，我该把它放在哪儿呢？",
          "6": "...it smells awful. | ……它的味道好难闻。",
          "8": "How nice. Thank you, dear. | 真好啊。谢谢你，亲爱的。"
        },
        "Dwarf": {
          "0": "Hey, I really love this stuff. You can find great things in the mines. | 嘿，我太喜欢这个了。你可以在矿洞里找到好东西。",
          "2": "Ah, this reminds me of home. | 啊，这让我想起了家。",
          "4": "Hmm... Is this what humans like? | 唔……这就是人类喜欢的东西吗？",
          "6": "I don't care what species you are. This is worthless garbage. | 我才不在乎你是什么物种。这就是一文不值的垃圾。",
